<%# enrollment 탭 내용 partial %>
<div class="card bg-base-100 shadow-sm mt-0 rounded-tl-none" id="enrollment-<%= enrollment.id %>">
  <div class="card-body p-4">

    <%# 클래스 헤더 %>
    <div class="flex items-center gap-3 mb-3 pb-3 border-b border-base-200">
      <span class="font-semibold"><%= enrollment.subject %></span>
      <span class="text-base-content/50 text-sm"><%= enrollment.teacher.name %></span>
      <span class="text-base-content/50 text-sm"><%= lesson_day_ko(enrollment.lesson_day) %>요일 <%= enrollment.lesson_time.strftime("%H:%M") %></span>
      <%= status_badge(enrollment.status) %>
      <% if enrollment.minus_lesson_count > 0 %>
        <span class="badge badge-sm badge-error">마이너스 <%= enrollment.minus_lesson_count %>회</span>
      <% end %>
      <div class="ml-auto flex gap-2">
        <%= link_to "상세", enrollment_path(enrollment), class: "btn btn-xs btn-ghost" %>
        <button type="button" onclick="document.getElementById('edit-enrollment-<%= enrollment.id %>').classList.toggle('hidden')" class="btn btn-xs btn-ghost">수정</button>
        <% if enrollment.payments.empty? %>
          <%= button_to "삭제", enrollment_path(enrollment), method: :delete,
                class: "btn btn-xs btn-error btn-outline",
                form: { onsubmit: "return confirm('클래스를 삭제하시겠습니까?')" } %>
        <% end %>
        <% if enrollment.status == "active" %>
          <button type="button" onclick="document.getElementById('leave-dialog-<%= enrollment.id %>').showModal()" class="btn btn-xs btn-warning btn-outline">휴원</button>
        <% elsif enrollment.status == "leave" %>
          <button type="button" onclick="document.getElementById('return-dialog-<%= enrollment.id %>').showModal()" class="btn btn-xs btn-success btn-outline">복귀</button>
        <% end %>
      </div>
    </div>

    <%# 인라인 클래스 수정 폼 %>
    <div id="edit-enrollment-<%= enrollment.id %>" class="hidden mb-3 p-3 bg-base-200/50 rounded-lg border border-base-300">
      <%= form_with url: enrollment_path(enrollment), method: :patch, scope: :enrollment, class: "flex flex-wrap gap-3 items-end" do |f| %>
        <div>
          <label class="block text-xs text-base-content/60 mb-1">선생님</label>
          <%= f.select :teacher_id, Teacher.by_position.map { |t| [t.name, t.id] },
                { selected: enrollment.teacher_id },
                class: "select select-bordered select-sm text-sm" %>
        </div>
        <div>
          <label class="block text-xs text-base-content/60 mb-1">요일</label>
          <%= f.select :lesson_day, Enrollment::LESSON_DAYS.map { |d| [ApplicationHelper::LESSON_DAY_KO[d] + "요일", d] },
                { selected: enrollment.lesson_day },
                class: "select select-bordered select-sm text-sm" %>
        </div>
        <div>
          <label class="block text-xs text-base-content/60 mb-1">시간</label>
          <%= f.select :lesson_time, (13..22).map { |h| ["#{h}:00", "#{h.to_s.rjust(2,'0')}:00:00"] },
                { selected: enrollment.lesson_time.strftime("%H:%M:%S") },
                class: "select select-bordered select-sm text-sm" %>
        </div>
        <button type="submit" class="btn btn-sm btn-primary">저장</button>
        <button type="button" onclick="document.getElementById('edit-enrollment-<%= enrollment.id %>').classList.add('hidden')" class="btn btn-sm btn-ghost">취소</button>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-6">

      <%# 왼쪽: 현황 + 결제 내역 %>
      <div>
        <%# 현황 통계 %>
        <%= render "students/enrollment_stats", student: student, enrollment: enrollment %>

        <%# 결제 내역 (최근 1건 기본, 접기/펼치기) %>
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-sm font-semibold">결제 내역</h4>
          <% first_payment = enrollment.payments.order(:created_at).first %>
          <% if first_payment %>
            <%= link_to "상세", payment_path(first_payment), class: "btn btn-xs btn-ghost" %>
          <% end %>
        </div>
        <% payments = enrollment.payments.order(created_at: :desc) %>
        <% if payments.any? %>
          <% payments.each_with_index do |payment, idx| %>
            <div class="<%= idx > 0 ? 'payment-extra-' + enrollment.id.to_s + ' hidden' : '' %>">
              <div class="text-sm bg-base-200 rounded-lg p-3 mb-2">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium"><%= payment.months %>개월 / <%= payment.total_lessons %>회</span>
                  <span class="font-bold"><%= format_amount(payment.amount) %></span>
                  <% badge_label = payment.refunded? ? "환불됨" : (payment.fully_paid? ? "완납" : (payment.payment_type == "deposit" ? "예약금" : "미납")) %>
                  <% badge_color = payment.refunded? ? "badge-neutral" : (payment.fully_paid? ? "badge-success" : (payment.payment_type == "deposit" ? "badge-warning" : "badge-error")) %>
                  <span class="badge badge-xs <%= badge_color %>"><%= badge_label %></span>
                  <div class="ml-auto flex items-center gap-1">
                    <div class="dropdown dropdown-end">
                      <label tabindex="0" class="btn btn-xs btn-ghost">⋯</label>
                      <ul tabindex="0" class="dropdown-content z-20 menu shadow bg-base-100 rounded-box text-xs border w-32">
                        <% unless payment.refunded? %>
                          <li>
                            <%= button_to "환불 처리", refund_payment_path(payment), method: :post,
                                  class: "text-error text-left w-full px-3 py-1.5 hover:bg-base-200",
                                  form: { onsubmit: "return confirm('환불 금액: #{format_amount(payment.refund_amount_calculated)}\\n환불 처리하시겠습니까?')" } %>
                          </li>
                        <% end %>
                        <% unless payment.fully_paid? %>
                          <li>
                            <%= button_to "잔금 납부", pay_balance_payment_path(payment), method: :patch,
                                  class: "text-success text-left w-full px-3 py-1.5 hover:bg-base-200",
                                  form: { onsubmit: "return confirm('잔금 납부 완료 처리하시겠습니까?')" } %>
                          </li>
                        <% end %>
                        <li>
                          <%= button_to "삭제", payment_path(payment), method: :delete,
                                class: "text-error text-left w-full px-3 py-1.5 hover:bg-base-200",
                                form: { onsubmit: "return confirm('결제를 삭제하면 관련 수업 일정(#{payment.schedules.count}회)도 모두 삭제됩니다.\\n삭제하시겠습니까?')" } %>
                        </li>
                      </ul>
                    </div>
                  </div>
                </div>
                <div class="text-xs text-base-content/50">
                  <%= payment.starts_at&.strftime("%Y.%m.%d") %>
                  <% if payment.ends_at %> ~ <%= payment.ends_at.strftime("%Y.%m.%d") %><% end %>
                </div>
                <% if payment.discounts.any? %>
                  <div class="text-xs text-secondary mt-1">
                    <%= payment.discounts.map { |d| "#{d.memo}" }.join(" / ") %>
                  </div>
                <% end %>
                <% voucher = enrollment.gift_vouchers.order(:issued_at).last %>
                <% if voucher %>
                  <div class="text-xs mt-1">
                    <span class="text-accent font-medium">🎟 지류상품권</span>
                    <span class="text-base-content/50 ml-1">
                      <%= voucher.issued_at.strftime("%Y.%m.%d") %> 발급
                      <% if voucher.used? %>
                        · <span class="text-success">사용완료 (<%= voucher.used_class %>)</span>
                      <% elsif voucher.expires_at < Date.today %>
                        · <span class="text-error">만료</span>
                      <% else %>
                        · <span class="text-success">사용가능</span>
                      <% end %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if payments.count > 1 %>
            <button onclick="togglePayments('<%= enrollment.id %>')" id="payment-toggle-<%= enrollment.id %>"
                    class="btn btn-xs btn-ghost text-base-content/50 w-full">
              전체보기 (<%= payments.count %>건) ∨
            </button>
          <% end %>
          <% if enrollment.status == "active" %>
            <div class="flex gap-1 mt-1">
              <%= link_to "+ 연장 결제", new_payment_path(enrollment_id: enrollment.id), class: "btn btn-xs btn-outline btn-primary" %>
              <%= button_to "+ 1회 추가", add_lesson_enrollment_path(enrollment), method: :patch,
                    class: "btn btn-xs btn-outline btn-secondary",
                    form: { onsubmit: "return confirm('수업 1회를 추가하시겠습니까?')" } %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-base-content/40">결제 내역 없음</p>
          <%= link_to "+ 결제 등록", new_payment_path(enrollment_id: enrollment.id), class: "btn btn-xs btn-primary mt-1" %>
        <% end %>
      </div>

      <%# 오른쪽: 수업 이력 (필터) %>
      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-sm font-semibold">수업 이력
            <%
              fmt_w = ->(w) {
                m = w / 4; wk = w % 4
                [m > 0 ? "#{m}개월" : nil, wk > 0 ? "#{wk}주" : nil].compact.join(' ')
              }
              teacher_week_pairs = enrollment.schedules
                                             .where(status: %w[attended makeup_done deducted])
                                             .group(:teacher_id).count
              total_weeks = teacher_week_pairs.values.sum
              period_str = if teacher_week_pairs.size > 1
                teachers_map = Teacher.where(id: teacher_week_pairs.keys).index_by(&:id)
                per = teacher_week_pairs.map { |tid, w| "#{teachers_map[tid]&.name} #{fmt_w.(w)}" }.join(' / ')
                "#{per} · 도합 #{fmt_w.(total_weeks)}"
              elsif total_weeks > 0
                "재원 #{fmt_w.(total_weeks)}"
              end
            %>
            <% if period_str %>
              <span class="text-xs font-normal text-base-content/40 ml-1">(<%= period_str %>)</span>
            <% end %>
          </h4>
          <%# 필터 버튼 %>
          <div class="flex gap-1" id="filter-btns-<%= enrollment.id %>">
            <% filters = [["전체", "all"], ["예정", "scheduled"], ["출석", "attended"], ["보강", "makeup"]]
               filters << ["패스", "pass"] unless enrollment.subject.include?("믹싱") %>
            <% filters.each do |label, key| %>
              <button onclick="filterSchedules('<%= enrollment.id %>', '<%= key %>')"
                      class="btn btn-xs <%= key == 'all' ? 'btn-neutral' : 'btn-ghost' %>"
                      data-filter="<%= key %>"
                      id="filter-<%= enrollment.id %>-<%= key %>">
                <%= label %>
              </button>
            <% end %>
          </div>
        </div>

        <%# 결제분 단위 아코디언 %>
        <% leave_at = enrollment.leave_at %>
        <% leave_badge_shown = false %>
        <% payments_ordered = enrollment.payments.order(:starts_at).map { |p| [p, p.schedules.includes(:attendance).order(:lesson_date).to_a] }.reject { |_, s| s.empty? } %>
        <% payments_ordered.each_with_index do |(payment, schedules), idx| %>
          <% is_last = idx == payments_ordered.size - 1 %>
          <% cnt_attended  = schedules.count { |s| s.status.in?(%w[attended late makeup_done]) } %>
          <% cnt_pass      = schedules.count { |s| s.status.in?(%w[pass emergency_pass holiday]) } %>
          <% cnt_deducted  = schedules.count { |s| s.status == "deducted" } %>
          <% cnt_remaining = schedules.count { |s| s.status.in?(%w[scheduled makeup_scheduled]) } %>
          <div class="mb-1 border border-base-200 rounded-lg overflow-hidden">
            <%= render "students/payment_chunk_header", payment: payment, is_open: is_last %>
            <div id="chunk-body-<%= payment.id %>" class="<%= is_last ? '' : 'hidden' %> px-3 pb-2">
              <div class="flex flex-wrap gap-1 pt-1">
                <% schedules.each do |s| %>
                  <%# 휴원배지: 당일 출석했으면 출석 뒤에, 아니면 앞에 %>
                  <% attended_on_leave = leave_at && s.lesson_date == leave_at && s.status.in?(%w[attended late makeup_done]) %>
                  <% if leave_at && !leave_badge_shown && s.lesson_date >= leave_at && !attended_on_leave %>
                    <% leave_badge_shown = true %>
                    <div class="badge badge-sm badge-warning">휴원 <%= leave_at.strftime("%-m/%-d") %></div>
                  <% end %>
                  <%= render "students/schedule_badge", s: s, enrollment: enrollment %>
                  <%# 당일 출석 후 휴원한 경우: 수업 뒤에 배지 %>
                  <% if attended_on_leave && !leave_badge_shown %>
                    <% leave_badge_shown = true %>
                    <div class="badge badge-sm badge-warning">휴원 <%= leave_at.strftime("%-m/%-d") %></div>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>

<%# 휴원 사유 dialog %>
<% if enrollment.status == "active" %>
<dialog id="leave-dialog-<%= enrollment.id %>" class="modal">
  <div class="modal-box max-w-sm">
    <h3 class="font-bold text-base mb-1">휴원 처리</h3>
    <p class="text-sm text-base-content/60 mb-4"><%= enrollment.subject %></p>
    <form action="<%= leave_enrollment_path(enrollment) %>" method="post" data-turbo="false">
      <input type="hidden" name="_method" value="patch">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <div class="space-y-3">
        <div>
          <label class="text-xs font-medium text-base-content/60 mb-1 block">휴원 사유 (선택)</label>
          <textarea name="leave_reason" rows="2"
                    class="textarea textarea-bordered w-full text-sm"
                    placeholder="예: 여행, 개인 사정 등"></textarea>
        </div>
        <div class="flex gap-2 justify-end">
          <button type="button" onclick="document.getElementById('leave-dialog-<%= enrollment.id %>').close()" class="btn btn-sm btn-ghost">취소</button>
          <button type="submit" class="btn btn-sm btn-warning">휴원 확정</button>
        </div>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
<% end %>

<%# 복귀 슬롯피커 dialog %>
<% if enrollment.status == "leave" %>
<dialog id="return-dialog-<%= enrollment.id %>" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-base mb-1">복귀 처리</h3>
    <p class="text-sm text-base-content/60 mb-4">
      <%= enrollment.subject %> — 동결된 수업 <%= enrollment.frozen_scheduled_count %>회
    </p>

    <form id="return-form-<%= enrollment.id %>"
          action="<%= return_enrollment_path(enrollment) %>" method="post"
          data-turbo="false">
      <input type="hidden" name="_method" value="patch">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <input type="hidden" id="return-date-val-<%= enrollment.id %>" name="return_date" value="">
      <input type="hidden" id="return-day-val-<%= enrollment.id %>"  name="lesson_day"  value="<%= enrollment.lesson_day %>">
      <input type="hidden" id="return-time-val-<%= enrollment.id %>" name="lesson_time" value="<%= enrollment.lesson_time.strftime('%H:%M') %>">

      <div class="space-y-3">
        <%# 요일 / 시간 선택 %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-medium text-base-content/60 mb-1 block">요일</label>
            <select id="return-day-<%= enrollment.id %>"
                    class="select select-sm select-bordered w-full"
                    onchange="updateReturnTimes('<%= enrollment.id %>')">
              <% [['monday','월'],['tuesday','화'],['wednesday','수'],['thursday','목'],['friday','금'],['saturday','토'],['sunday','일']].each do |val, ko| %>
                <option value="<%= val %>" <%= enrollment.lesson_day == val ? 'selected' : '' %>><%= ko %>요일</option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="text-xs font-medium text-base-content/60 mb-1 block">시간</label>
            <select id="return-time-<%= enrollment.id %>"
                    class="select select-sm select-bordered w-full"
                    onchange="clearReturnDate('<%= enrollment.id %>')">
              <% current_time_str = enrollment.lesson_time.strftime('%H:%M') %>
              <% hours = enrollment.lesson_day == 'monday' ? (14..17) : (13..22) %>
              <% hours.each do |h| %>
                <% [0, 30].each do |min| %>
                  <% t = "#{h.to_s.rjust(2,'0')}:#{min.to_s.rjust(2,'0')}" %>
                  <option value="<%= t %>" <%= current_time_str == t ? 'selected' : '' %>><%= t %></option>
                <% end %>
              <% end %>
            </select>
          </div>
        </div>

        <%# 선생님 선택 %>
        <div>
          <label class="text-xs font-medium text-base-content/60 mb-1 block">선생님</label>
          <select id="return-teacher-<%= enrollment.id %>" name="teacher_id" class="select select-sm select-bordered w-full">
            <% Teacher.joins(:teacher_subjects).where(teacher_subjects: { subject: enrollment.subject }).by_position.each do |t| %>
              <option value="<%= t.id %>" <%= enrollment.teacher_id == t.id ? 'selected' : '' %>><%= t.name %></option>
            <% end %>
          </select>
        </div>

        <%# 날짜 조회 버튼 %>
        <button type="button"
                onclick="fetchReturnSlots('<%= enrollment.id %>', '<%= enrollment.subject %>')"
                class="btn btn-sm btn-outline w-full">
          날짜 조회
        </button>

        <%# 날짜 그리드 %>
        <div id="return-slot-body-<%= enrollment.id %>" class="hidden"></div>

        <%# 선택된 날짜 표시 %>
        <div id="return-selected-<%= enrollment.id %>" class="hidden text-sm bg-success/10 border border-success/30 rounded-lg px-3 py-2 text-success font-medium"></div>

        <div class="flex gap-2 justify-end pt-1">
          <button type="button"
                  onclick="document.getElementById('return-dialog-<%= enrollment.id %>').close()"
                  class="btn btn-sm btn-ghost">취소</button>
          <button type="submit" id="return-submit-<%= enrollment.id %>"
                  class="btn btn-sm btn-success" disabled>복귀 확정</button>
        </div>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
<% end %>

<%# 수업 처리 모달 (DaisyUI modal) — 보강 시 시간표 표시를 위해 max-w-2xl %>
<dialog id="schedule-modal-<%= enrollment.id %>" class="modal">
  <div class="modal-box max-w-2xl w-full">
    <h3 class="font-bold text-lg" id="modal-title-<%= enrollment.id %>">출결 처리</h3>
    <p class="text-sm text-base-content/60 mb-4" id="modal-date-<%= enrollment.id %>"></p>
    <div id="modal-actions-<%= enrollment.id %>" class="space-y-2">
      <%# JS로 채워짐 %>
    </div>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">닫기</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
(function() {
  // Per-enrollment reschedule data
  window._enrollmentData = window._enrollmentData || {};
  window._enrollmentData['<%= enrollment.id %>'] = {
    lessonDay:  '<%= enrollment.lesson_day %>',
    lessonTime: '<%= enrollment.lesson_time.strftime("%H:%M") %>',
    teachers:   <%= Teacher.joins(:teacher_subjects).where(teacher_subjects: { subject: enrollment.subject }).by_position.map { |t| { id: t.id, name: t.name } }.to_json.html_safe %>
  };

  // 결제 접기/펼치기
  window.togglePayments = window.togglePayments || function(enrollmentId) {
    const extras = document.querySelectorAll('.payment-extra-' + enrollmentId);
    const btn    = document.getElementById('payment-toggle-' + enrollmentId);
    const hidden = extras[0]?.classList.contains('hidden');
    extras.forEach(el => el.classList.toggle('hidden', !hidden));
    if (btn) btn.textContent = hidden ? '접기 ∧' : `전체보기 (${extras.length + 1}건) ∨`;
  };

  // 결제분 아코디언 토글
  window.toggleChunk = window.toggleChunk || function(paymentId) {
    const body  = document.getElementById('chunk-body-'  + paymentId);
    const arrow = document.getElementById('chunk-arrow-' + paymentId);
    const hidden = body.classList.toggle('hidden');
    if (arrow) arrow.textContent = hidden ? '∨' : '∧';
  };

  // 수업이력 필터
  window.filterSchedules = window.filterSchedules || function(enrollmentId, filterKey) {
    const items = document.querySelectorAll('.schedule-item-' + enrollmentId);
    items.forEach(el => {
      const match = filterKey === 'all' || el.dataset.filter === filterKey;
      el.style.display = match ? '' : 'none';
    });
    document.querySelectorAll('#filter-btns-' + enrollmentId + ' button').forEach(btn => {
      btn.classList.toggle('btn-neutral', btn.dataset.filter === filterKey);
      btn.classList.toggle('btn-ghost',   btn.dataset.filter !== filterKey);
    });
  };

  // 수업 처리 모달
  window.openScheduleAction = function(scheduleId, dateLabel, status, lessonDateStr, subject, checkedIn, checkedOut, teacherId) {
    const el = document.querySelector(`[onclick*="openScheduleAction('${scheduleId}'"]`);
    if (!el) return;
    const classMatch = el.className.match(/schedule-item-(\d+)/);
    if (!classMatch) return;
    const enrollmentId = classMatch[1];
    const modal     = document.getElementById('schedule-modal-' + enrollmentId);
    if (!modal) return;
    const titleEl   = document.getElementById('modal-title-'   + enrollmentId);
    const dateEl    = document.getElementById('modal-date-'    + enrollmentId);
    const actionsEl = document.getElementById('modal-actions-' + enrollmentId);
    const csrf      = document.querySelector('meta[name="csrf-token"]').content;

    dateEl.textContent = dateLabel;

    // 공통 form submit 헬퍼 (window에 노출 — inline onclick에서 호출)
    window._mkPatchForm = function(url, extra) {
      const f = document.createElement('form');
      f.method = 'POST'; f.action = url;
      f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                     <input type="hidden" name="_method" value="patch">` + (extra || '');
      document.body.appendChild(f);
      f.submit();
    };
    function patchForm(url, extra) { window._mkPatchForm(url, extra); }

    // ── 날짜 유틸 ──────────────────────────────────────────
    function parseDate(str) {
      const [y, m, d] = str.split('-').map(Number);
      return new Date(y, m - 1, d);
    }
    function toDateStr(d) {
      return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }
    function getMonday(date) {
      const d   = new Date(date);
      const day = d.getDay();
      const diff = day === 0 ? -6 : 1 - day;
      return new Date(d.getFullYear(), d.getMonth(), d.getDate() + diff);
    }

    // ── 메인 화면 ──────────────────────────────────────────
    function showMain() {
      titleEl.textContent = '출결 처리';
      let html = '';
      if (['scheduled', 'pass', 'emergency_pass', 'holiday', 'makeup_scheduled'].includes(status)) {
        if (status === 'makeup_scheduled') {
          html += `<p class="text-xs text-blue-600 mb-2">보강 예정 — 출석 처리 또는 전환 가능</p>`;
        } else if (status !== 'scheduled') {
          const labelMap = { emergency_pass: '긴급패스', holiday: '공휴일패스', pass: '패스' };
          html += `<p class="text-xs text-secondary mb-2">${labelMap[status] || '패스'} 처리됨 — 변경 가능</p>`;
        }
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/attend','${csrf}','${enrollmentId}')" class="btn btn-sm btn-success w-full">출석</button>`;
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/late','${csrf}','${enrollmentId}')"   class="btn btn-sm btn-warning w-full">지각</button>`;
        html += `<button onclick="showMakeup()" class="btn btn-sm btn-info btn-outline w-full">보강</button>`;
        if (['scheduled', 'makeup_scheduled'].includes(status) && !(subject || '').includes('믹싱')) {
          html += `<button onclick="showPass()" class="btn btn-sm btn-secondary btn-outline w-full">패스</button>`;
        }
        html += `<button onclick="if(confirm('결석 차감 처리하시겠습니까?')) submitPatch('/schedules/${scheduleId}/deduct','${csrf}','${enrollmentId}')"
                         class="btn btn-sm btn-error btn-outline w-full">결석 차감</button>`;
        html += `<button onclick="showReschedule()" class="btn btn-sm btn-outline w-full mt-1">수업 일자 변경</button>`;
        if (['pass', 'emergency_pass', 'holiday'].includes(status)) {
          html += `<button onclick="if(confirm('패스를 취소하고 예정 상태로 되돌리시겠습니까?')) submitPatch('/schedules/${scheduleId}/cancel_pass','${csrf}','${enrollmentId}')"
                           class="btn btn-sm btn-ghost btn-outline w-full mt-1 text-secondary">패스 취소</button>`;
        }
        if (status === 'makeup_scheduled') {
          html += `<a href="/schedules/${scheduleId}" class="btn btn-sm btn-ghost btn-outline w-full mt-1">보강 상세 보기</a>`;
        }
        html += `<button onclick="if(confirm('이 스케줄을 삭제하시겠습니까?')) submitDelete('/schedules/${scheduleId}','${csrf}','${enrollmentId}')" class="btn btn-sm btn-error btn-outline w-full mt-1">삭제</button>`;
      } else if (status === 'deducted') {
        html += `<p class="text-xs text-error mb-1">결석 차감 처리됨</p>`;
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/undo_deduct','${csrf}','${enrollmentId}')" class="btn btn-sm btn-warning btn-outline w-full">차감 취소</button>`;
        html += `<a href="/schedules/${scheduleId}" class="btn btn-sm btn-ghost w-full mt-1">수업 상세 보기</a>`;
        html += `<button onclick="showReschedule()" class="btn btn-sm btn-outline w-full mt-1">수업 일자 변경</button>`;
        html += `<button onclick="if(confirm('이 스케줄을 삭제하시겠습니까?')) submitDelete('/schedules/${scheduleId}','${csrf}','${enrollmentId}')" class="btn btn-sm btn-error btn-outline w-full mt-1">삭제</button>`;
      } else if (status === 'makeup_scheduled') {
        html += `<a href="/schedules/${scheduleId}" class="btn btn-sm btn-primary w-full">수업 상세 / 전환</a>`;
      } else if (['attended', 'late', 'makeup_done'].includes(status)) {
        titleEl.textContent = status === 'late' ? '지각' : status === 'makeup_done' ? '보강 출석 완료' : '출석 완료';
        html += `<div class="space-y-2 text-sm py-1">`;
        html += `<div class="flex justify-between"><span class="text-base-content/50">등원</span><span class="font-medium text-success">${checkedIn || '미기록'}</span></div>`;
        html += `<div class="flex justify-between"><span class="text-base-content/50">하원</span><span class="font-medium text-info">${checkedOut || '미기록'}</span></div>`;
        html += `</div>`;
        const undoLabel = status === 'makeup_done' ? '보강 출석 취소' : '등원 취소';
        const undoMsg   = status === 'makeup_done'
          ? '보강 출석을 취소하시겠습니까?\\n출석 기록이 삭제되고 보강예정 상태로 돌아갑니다.'
          : '등원 취소하시겠습니까?\\n출석 기록이 삭제되고 예정 상태로 돌아갑니다.';
        html += `<button onclick="if(confirm('${undoMsg}')) submitPatch('/schedules/${scheduleId}/undo_attend','${csrf}','${enrollmentId}')"
                         class="btn btn-sm btn-warning btn-outline w-full mt-2">${undoLabel}</button>`;
        html += `<button onclick="showReschedule()" class="btn btn-sm btn-outline w-full mt-1">수업 일자 변경</button>`;
        html += `<button onclick="if(confirm('이 스케줄을 삭제하시겠습니까?')) submitDelete('/schedules/${scheduleId}','${csrf}','${enrollmentId}')" class="btn btn-sm btn-error btn-outline w-full mt-1">삭제</button>`;
      }
      actionsEl.innerHTML = html;
    }

    // ── 보강: 시간표 그리드 ────────────────────────────────
    function showMakeup() {
      titleEl.textContent = '보강 등록';
      window._mkMilitary = false;
      actionsEl.innerHTML = '<p class="text-xs text-base-content/50 py-4 text-center">슬롯 불러오는 중…</p>';

      fetch(`/schedules/${scheduleId}/makeup_slots`)
        .then(r => r.json())
        .then(data => {
          window._mkData = data;
          window._mkWeekStart = getMonday(parseDate(lessonDateStr));
          window._mkTeacherId = (teacherId && data.teachers.find(t => t.id === teacherId)) ? teacherId : (data.teachers[0]?.id ?? null);
          if (!data.range_min && !window._mkMilitary) {
            actionsEl.innerHTML = `
              <label class="flex items-center gap-2 mb-3 cursor-pointer">
                <input type="checkbox" class="checkbox checkbox-sm checkbox-warning"
                       onchange="window._mkMilitary=this.checked; window._mkRender();">
                <span class="text-sm">군보강 <span class="text-xs text-base-content/50">(날짜 제한 없음)</span></span>
              </label>
              <p class="text-sm text-error py-2">보강 가능 기간이 없습니다.</p>
              <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>`;
            return;
          }
          window._mkRender();
        });
    }

    // ── 주간 시간표 렌더 ────────────────────────────────────
    // 가로: 요일(월~토), 세로: 시간대, 탭: 선생님
    window._mkRender = function() {
      const data     = window._mkData;
      const ws       = window._mkWeekStart;
      const military = !!window._mkMilitary;
      const rangeMin = military ? new Date(2000, 0, 1) : parseDate(data.range_min);
      const rangeMax = (military || !data.range_max) ? null : parseDate(data.range_max);
      const inRangeFn = d => military || (d >= rangeMin && (rangeMax === null || d <= rangeMax));
      const DAY_KO   = ['일','월','화','수','목','금','토'];

      // 월~일 7일
      const days = Array.from({length: 7}, (_, i) =>
        new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + i));

      // 이전/다음 주 이동 가능 여부
      const prevWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() - 7);
      const nextWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + 7);
      const prevDays = Array.from({length:7}, (_,i) => new Date(prevWs.getFullYear(), prevWs.getMonth(), prevWs.getDate()+i));
      const nextDays = Array.from({length:7}, (_,i) => new Date(nextWs.getFullYear(), nextWs.getMonth(), nextWs.getDate()+i));
      const prevOk   = military || prevDays.some(d => inRangeFn(d));
      const nextOk   = military || rangeMax === null || nextDays.some(d => inRangeFn(d));

      const weekEnd   = days[6];
      const weekLabel = `${ws.getMonth()+1}/${ws.getDate()} ~ ${weekEnd.getMonth()+1}/${weekEnd.getDate()}`;

      // 선생님 탭
      const teacherTabs = data.teachers.map(t => {
        const active = window._mkTeacherId === t.id;
        return `<button onclick="window._mkTeacherId=${t.id};window._mkRender();"
                        class="btn btn-xs ${active ? 'btn-primary' : 'btn-ghost'}">${t.name}</button>`;
      }).join('');

      // 현재 선생님 그리드 (grid[tid][date][time] = count)
      const tid         = String(window._mkTeacherId);
      const tGrid       = (data.grid || {})[tid] || {};
      const tConflict   = ((data.conflict_grid || {})[tid]) || {};

      const teacher     = data.teachers.find(t => t.id === window._mkTeacherId);
      const teacherName = teacher?.name || '';

      // 운영시간 고정: 13:00 ~ 22:00, 정시만
      const times = [];
      for (let m = 13 * 60; m <= 22 * 60; m += 60) {
        const h   = String(Math.floor(m / 60)).padStart(2, '0');
        const min = String(m % 60).padStart(2, '0');
        times.push(`${h}:${min}`);
      }

      // 날짜 헤더 (열)
      const thCells = days.map(d => {
        const inRange = inRangeFn(d);
        return `<th class="text-xs font-normal text-center px-1 py-1 ${inRange ? '' : 'opacity-25'}">
          ${d.getMonth()+1}/${d.getDate()}<br>
          <span class="text-base-content/60">${DAY_KO[d.getDay()]}</span>
        </th>`;
      }).join('');

      // 시간대 행 (행)
      const rows = times.map(time => {
        const tds = days.map(d => {
          const inRange = inRangeFn(d);
          const ds      = toDateStr(d);
          if (!inRange) return `<td class="text-center opacity-20 text-xs select-none px-1 py-1">—</td>`;

          const slots    = ((tGrid[ds] || {})[time]) || 0;
          const conflict = ((tConflict[ds] || {})[time]) === "conflict";
          if (conflict) {
            return `<td class="text-center text-xs select-none px-1 py-1 rounded"
                        style="background:rgba(251,146,60,0.12);color:rgba(251,146,60,0.5);"
                        title="다른 과목 수업 있음">✕</td>`;
          }
          if (slots >= 3) {
            return `<td class="text-center text-xs select-none px-1 py-1 rounded"
                        style="background:rgba(239,68,68,0.12);color:rgba(239,68,68,0.5);"
                        title="마감 (3/3)">✕</td>`;
          }
          const filled   = '●'.repeat(slots);
          const empty    = '○'.repeat(3 - slots);
          const colorCls = slots === 0 ? 'text-success' : 'text-warning';
          return `<td class="text-center cursor-pointer rounded px-1 py-1"
                      style="background:rgba(34,197,94,0.12);"
                      onmouseover="this.style.background='rgba(34,197,94,0.25)'"
                      onmouseout="this.style.background='rgba(34,197,94,0.12)'"
                      onclick="window._mkConfirm('${ds}',${window._mkTeacherId},'${time}','${teacherName}')"
                      title="${teacherName} — ${slots}/3명">
                    <span class="font-mono text-xs ${colorCls}">${filled}</span><span class="font-mono text-xs opacity-30">${empty}</span>
                  </td>`;
        }).join('');

        return `<tr>
          <td class="text-xs text-base-content/50 text-right pr-2 py-1 whitespace-nowrap font-mono w-12">${time}</td>
          ${tds}
        </tr>`;
      }).join('');

      actionsEl.innerHTML = `
        <label class="flex items-center gap-2 mb-3 cursor-pointer">
          <input type="checkbox" class="checkbox checkbox-sm checkbox-warning" ${military ? 'checked' : ''}
                 onchange="window._mkMilitary=this.checked; window._mkRender();">
          <span class="text-sm">군보강 <span class="text-xs text-base-content/50">(날짜 제한 없음)</span></span>
        </label>
        <div class="text-xs text-base-content/50 mb-2">${military ? '날짜 제한 없음 (군보강)' : `보강 가능: ${data.range_min} ~ ${data.range_max || '상한 없음'}`}</div>
        <div class="flex flex-wrap gap-1 mb-3">${teacherTabs}</div>
        <div class="flex items-center justify-between mb-2">
          <button onclick="window._mkNav(-1)" class="btn btn-xs btn-ghost" ${!prevOk ? 'disabled' : ''}>←</button>
          <span class="text-sm font-medium">${weekLabel}</span>
          <button onclick="window._mkNav(1)"  class="btn btn-xs btn-ghost" ${!nextOk  ? 'disabled' : ''}>→</button>
        </div>
        <div class="overflow-x-auto">
          <table class="table table-xs w-full">
            <thead><tr><th class="w-12"></th>${thCells}</tr></thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
        <button onclick="showMain()" class="btn btn-sm btn-ghost w-full mt-3">← 돌아가기</button>`;
    };

    window._mkNav = function(dir) {
      const ws = window._mkWeekStart;
      window._mkWeekStart = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + dir * 7);
      window._mkRender();
    };

    window._mkConfirm = function(date, teacherId, time, teacherName) {
      actionsEl.innerHTML = `
        <div class="border rounded-lg p-4 space-y-3">
          <div class="text-sm font-semibold">${date} · ${teacherName} 선생님</div>
          <div class="flex items-center gap-2">
            <label class="text-sm text-base-content/60 w-16 shrink-0">보강 시간</label>
            <input type="time" id="makeup-confirm-time-${scheduleId}" value="${time}"
                   class="input input-bordered input-sm flex-1">
          </div>
          <div class="flex gap-2 pt-1">
            <button onclick="
              const t = document.getElementById('makeup-confirm-time-${scheduleId}').value;
              window._mkPatchForm('/schedules/${scheduleId}/makeup',
                '<input type=\\'hidden\\' name=\\'makeup_date\\' value=\\'${date}\\'>' +
                '<input type=\\'hidden\\' name=\\'makeup_time\\' value=\\'' + t + '\\'>' +
                '<input type=\\'hidden\\' name=\\'makeup_teacher_id\\' value=\\'${teacherId}\\'>' +
                (window._mkMilitary ? '<input type=\\'hidden\\' name=\\'military\\' value=\\'1\\'>' : ''));
            " class="btn btn-sm btn-primary flex-1">보강 등록</button>
            <button onclick="window._mkRender()" class="btn btn-sm btn-ghost flex-1">← 취소</button>
          </div>
        </div>`;
    };

    // ── 패스 처리 ───────────────────────────────────────────
    function showPass() {
      titleEl.textContent = '패스 처리';
      actionsEl.innerHTML = `
        <div class="space-y-3">

          <div class="border rounded-lg p-3 space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold text-purple-700">일반 패스</span>
              <span class="badge badge-xs badge-warning">횟수 1회 소진 · 개근 리셋</span>
            </div>
            <div class="flex gap-2">
              <input type="text" id="passreason-pass-${scheduleId}" placeholder="사유 (선택)"
                     class="input input-bordered input-sm flex-1 text-sm">
              <button onclick="submitPass('pass')" class="btn btn-sm bg-purple-100 text-purple-700 hover:bg-purple-200 border-0">패스</button>
            </div>
          </div>

          <div class="border rounded-lg p-3 space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold text-pink-700">긴급 패스</span>
              <span class="badge badge-xs badge-ghost">횟수 소진 없음</span>
            </div>
            <div class="flex gap-2">
              <input type="text" id="passreason-emergency-${scheduleId}" placeholder="사유 (선택)"
                     class="input input-bordered input-sm flex-1 text-sm">
              <button onclick="submitPass('emergency_pass')" class="btn btn-sm bg-pink-100 text-pink-700 hover:bg-pink-200 border-0">긴급패스</button>
            </div>
          </div>

          <div class="border rounded-lg p-3 space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold text-green-700">공휴일 패스</span>
              <span class="badge badge-xs badge-ghost">횟수 소진 없음</span>
            </div>
            <div class="flex gap-2">
              <input type="text" id="passreason-holiday-${scheduleId}" placeholder="공휴일명 (예: 삼일절)"
                     class="input input-bordered input-sm flex-1 text-sm">
              <button onclick="submitPass('holiday')" class="btn btn-sm bg-green-100 text-green-700 hover:bg-green-200 border-0">공휴일</button>
            </div>
          </div>

          <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>
        </div>`;
    }

    function submitPass(type) {
      const keyMap = { pass: 'pass', emergency_pass: 'emergency', holiday: 'holiday' };
      const reason = document.getElementById(`passreason-${keyMap[type]}-${scheduleId}`)?.value || '';
      patchForm(`/schedules/${scheduleId}/${type}`,
        `<input type="hidden" name="pass_reason" value="${reason}">`);
    }

    // ── 수업 일자 변경 ─────────────────────────────────────
    function showReschedule() {
      titleEl.textContent = '수업 일자 변경';
      const ed = (window._enrollmentData || {})[enrollmentId] || {};
      const teachers = ed.teachers || [];
      const DAY_LIST = [['monday','월'],['tuesday','화'],['wednesday','수'],['thursday','목'],['friday','금'],['saturday','토'],['sunday','일']];
      const dayOptions = DAY_LIST.map(([val, ko]) =>
        `<option value="${val}" ${val === ed.lessonDay ? 'selected' : ''}>${ko}요일</option>`
      ).join('');
      const teacherOptions = teachers.map(t =>
        `<option value="${t.id}">${t.name}</option>`
      ).join('');

      actionsEl.innerHTML = `
        <div class="space-y-3 text-sm">
          <div class="space-y-2">
            <p class="text-xs font-semibold">이 수업만 날짜 변경</p>
            <div class="flex items-center gap-2">
              <span class="text-sm font-mono">${lessonDateStr}</span>
              <span class="text-base-content/50">→</span>
              <input type="date" id="rs-single-date" value="${lessonDateStr}" class="input input-sm input-bordered flex-1">
            </div>
            <button onclick="submitMoveDate()" class="btn btn-sm btn-primary w-full">이 수업만 변경</button>
          </div>
          <div class="divider my-1 text-xs text-base-content/40">또는 이후 수업 전체 변경</div>
          <div class="space-y-2">
            <p class="text-xs text-base-content/50">이 날짜 이후 예정된 수업이 모두 변경됩니다.</p>
            <div>
              <p class="text-xs font-medium mb-1">변경 기준 날짜</p>
              <input type="date" id="rs-date" value="${lessonDateStr}" class="input input-sm input-bordered w-full">
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <p class="text-xs font-medium mb-1">새 요일</p>
                <select id="rs-day" class="select select-sm select-bordered w-full" onchange="updateRescheduleTimes()">${dayOptions}</select>
              </div>
              <div>
                <p class="text-xs font-medium mb-1">새 시간</p>
                <select id="rs-time" class="select select-sm select-bordered w-full"></select>
              </div>
            </div>
            <div>
              <p class="text-xs font-medium mb-1">선생님</p>
              <select id="rs-teacher" class="select select-sm select-bordered w-full">${teacherOptions}</select>
            </div>
            <button onclick="submitReschedule()" class="btn btn-sm btn-outline btn-primary w-full">전체 변경 적용</button>
          </div>
          <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>
        </div>`;
      updateRescheduleTimes();
    }

    function updateRescheduleTimes() {
      const day = document.getElementById('rs-day')?.value;
      const sel = document.getElementById('rs-time');
      if (!sel || !day) return;
      const ed  = (window._enrollmentData || {})[enrollmentId] || {};
      let start = 13 * 60, end = 22 * 60;
      if (day === 'monday') { start = 14 * 60; end = 17 * 60; }
      const opts = [];
      for (let m = start; m <= end; m += 30) {
        const h   = String(Math.floor(m / 60)).padStart(2, '0');
        const min = String(m % 60).padStart(2, '0');
        const t   = `${h}:${min}`;
        opts.push(`<option value="${t}" ${t === ed.lessonTime ? 'selected' : ''}>${t}</option>`);
      }
      sel.innerHTML = opts.join('');
    }

    function submitMoveDate() {
      const newDate = document.getElementById('rs-single-date')?.value;
      if (!newDate) { alert('변경할 날짜를 선택해주세요.'); return; }
      if (!confirm(`${lessonDateStr} 수업을 ${newDate}로 변경합니다. 계속하시겠습니까?`)) return;
      const f = document.createElement('form');
      f.method = 'POST'; f.action = `/schedules/${scheduleId}/move_date`;
      f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                     <input type="hidden" name="_method" value="patch">
                     <input type="hidden" name="new_date" value="${newDate}">`;
      document.body.appendChild(f);
      f.submit();
    }

    function submitReschedule() {
      const date      = document.getElementById('rs-date')?.value;
      const day       = document.getElementById('rs-day')?.value;
      const time      = document.getElementById('rs-time')?.value;
      const teacherId = document.getElementById('rs-teacher')?.value;
      if (!date || !day || !time || !teacherId) { alert('모든 항목을 입력해주세요.'); return; }
      const DAY_KO = { monday:'월', tuesday:'화', wednesday:'수', thursday:'목', friday:'금', saturday:'토', sunday:'일' };
      if (!confirm(`${date} 이후 예정 수업을 ${DAY_KO[day] || day}요일 ${time}으로 변경합니다. 계속하시겠습니까?`)) return;
      const f = document.createElement('form');
      f.method = 'POST'; f.action = `/enrollments/${enrollmentId}/reschedule`;
      f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                     <input type="hidden" name="_method" value="patch">
                     <input type="hidden" name="change_date" value="${date}">
                     <input type="hidden" name="lesson_day" value="${day}">
                     <input type="hidden" name="lesson_time" value="${time}">
                     <input type="hidden" name="teacher_id" value="${teacherId}">`;
      document.body.appendChild(f);
      f.submit();
    }

    // window에 노출 (동적 HTML onclick에서 접근 가능하도록)
    window.showMain              = showMain;
    window.showMakeup            = showMakeup;
    window.showPass              = showPass;
    window.submitPass            = submitPass;
    window.showReschedule        = showReschedule;
    window.updateRescheduleTimes = updateRescheduleTimes;
    window.submitMoveDate        = submitMoveDate;
    window.submitReschedule      = submitReschedule;

    showMain();
    modal.showModal();
  };

  window.submitDelete = function(url, csrf, enrollmentId) {
    const f = document.createElement('form');
    f.method = 'POST'; f.action = url;
    f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                   <input type="hidden" name="_method" value="delete">`;
    document.body.appendChild(f);
    f.submit();
  };

  window.submitPatch = function(url, csrf, enrollmentId) {
    const studentId = <%= student.id %>;
    const params = { authenticity_token: csrf, _method: 'patch' };
    if (enrollmentId) { params.from_enrollment_id = enrollmentId; params.from_student_id = studentId; }
    const body = new URLSearchParams(params);
    fetch(url, {
      method: 'POST',
      headers: { 'Accept': 'text/vnd.turbo-stream.html, text/html', 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body.toString()
    }).then(res => {
      const ct = res.headers.get('Content-Type') || '';
      if (ct.includes('turbo-stream')) {
        res.text().then(html => {
          if (typeof Turbo !== 'undefined') Turbo.renderStreamMessage(html);
          if (enrollmentId) {
            const modal = document.getElementById('schedule-modal-' + enrollmentId);
            if (modal) modal.close();
          }
        });
      } else {
        // HTML 리디렉트 → Turbo 페이지 이동
        if (typeof Turbo !== 'undefined') {
          Turbo.visit(res.url);
        } else {
          location.href = res.url;
        }
      }
    });
  };
})();

  // 복귀 팝업 슬롯피커 (첫 enrollment 렌더 시 한번만 정의)
  if (!window._returnPickerDefined) {
    window._returnPickerDefined = true;
    const RETURN_DAY_KO = { monday:'월', tuesday:'화', wednesday:'수', thursday:'목', friday:'금', saturday:'토', sunday:'일' };

  window.updateReturnTimes = function(eid) {
    const day = document.getElementById('return-day-' + eid)?.value;
    const sel = document.getElementById('return-time-' + eid);
    if (!sel || !day) return;
    let start = 13 * 60, end = 22 * 60;
    if (day === 'monday') { start = 14 * 60; end = 17 * 60; }
    const opts = [];
    for (let m = start; m <= end; m += 30) {
      const h   = String(Math.floor(m / 60)).padStart(2, '0');
      const min = String(m % 60).padStart(2, '0');
      opts.push(`<option value="${h}:${min}">${h}:${min}</option>`);
    }
    sel.innerHTML = opts.join('');
    clearReturnDate(eid);
  };

  window.clearReturnDate = function(eid) {
    const dateVal   = document.getElementById('return-date-val-' + eid);
    const submitBtn = document.getElementById('return-submit-' + eid);
    const selectedEl = document.getElementById('return-selected-' + eid);
    if (dateVal)    dateVal.value = '';
    if (submitBtn)  submitBtn.disabled = true;
    if (selectedEl) { selectedEl.textContent = ''; selectedEl.classList.add('hidden'); }
  };

  window.fetchReturnSlots = function(eid, subject) {
    const day       = document.getElementById('return-day-'     + eid)?.value;
    const time      = document.getElementById('return-time-'    + eid)?.value;
    const teacherId = document.getElementById('return-teacher-' + eid)?.value;
    const body      = document.getElementById('return-slot-body-' + eid);
    if (!day || !time || !teacherId || !body) return;

    document.getElementById('return-day-val-'  + eid).value = day;
    document.getElementById('return-time-val-' + eid).value = time;

    body.innerHTML = '<p class="text-xs text-base-content/50 text-center py-2">불러오는 중…</p>';
    body.classList.remove('hidden');
    clearReturnDate(eid);

    fetch(`/slot_check?teacher_id=${teacherId}&subject=${encodeURIComponent(subject)}&lesson_day=${day}&lesson_time=${encodeURIComponent(time)}`)
      .then(r => r.json())
      .then(data => {
        const count    = typeof data.enrollment_count === 'number' ? data.enrollment_count : 0;
        const max      = data.max || 3;
        const dayLabel = RETURN_DAY_KO[day] || day;
        const pct      = Math.round((count / max) * 100);
        const barColor = count >= max ? 'bg-error' : (count > 0 ? 'bg-warning' : 'bg-success');

        let html = `
          <div class="mb-3 p-2 bg-base-200 rounded-lg">
            <div class="flex justify-between text-xs mb-1">
              <span class="text-base-content/60">현재 정규 수강인원</span>
              <span class="font-bold ${count >= max ? 'text-error' : ''}">${count} / ${max}명</span>
            </div>
            <div class="w-full bg-base-300 rounded-full h-1.5">
              <div class="${barColor} h-1.5 rounded-full" style="width:${pct}%"></div>
            </div>
          </div>
          <p class="text-xs text-base-content/50 mb-2">${dayLabel}요일 ${time} — 복귀 시작일 선택</p>
          <div class="grid grid-cols-2 gap-2">`;

        Object.entries(data.date_slots || {}).forEach(([ds, taken]) => {
          const d        = new Date(ds + 'T00:00:00');
          const label    = `${d.getMonth()+1}/${d.getDate()} (${dayLabel})`;
          const filled   = '●'.repeat(taken);
          const empty    = '○'.repeat(Math.max(0, max - taken));
          if (taken >= max) {
            html += `<div class="rounded border border-error/30 bg-error/10 px-3 py-2 text-center select-none opacity-60">
              <div class="text-sm font-medium text-error">${label}</div>
              <div class="font-mono text-xs mt-0.5 text-error">${filled} 마감</div>
            </div>`;
          } else {
            const colorCls = taken === 0 ? 'border-success/40 bg-success/10 hover:bg-success/20' : 'border-warning/40 bg-warning/10 hover:bg-warning/20';
            html += `<div class="rounded border ${colorCls} px-3 py-2 text-center cursor-pointer"
                          onclick="selectReturnDate('${ds}', '${eid}')">
              <div class="text-sm font-medium">${label}</div>
              <div class="font-mono text-xs mt-0.5">
                <span class="text-base-content/70">${filled}</span><span class="opacity-30">${empty}</span>
                <span class="ml-1 text-base-content/40">${taken}/${max}</span>
              </div>
            </div>`;
          }
        });
        html += '</div>';
        body.innerHTML = html;
      })
      .catch(() => {
        body.innerHTML = '<p class="text-xs text-error text-center py-2">슬롯 조회 실패</p>';
      });
  };

  window.selectReturnDate = function(dateStr, eid) {
    document.getElementById('return-date-val-' + eid).value = dateStr;
    document.getElementById('return-submit-'   + eid).disabled = false;
    const selectedEl = document.getElementById('return-selected-' + eid);
    if (selectedEl) {
      selectedEl.textContent = `✓ ${dateStr} 선택됨`;
      selectedEl.classList.remove('hidden');
    }
  };
  } // end _returnPickerDefined guard

  // 통계 더블클릭 편집
  if (!window._statEditDefined) {
    window._statEditDefined = true;
    window.openStatEdit = function(statEl) {
      const url    = statEl.dataset.updateUrl;
      const stat   = statEl.dataset.stat;
      const csrf   = document.querySelector('meta[name="csrf-token"]').content;
      const unitMap = { gift_voucher_eligible: '주', consecutive_weeks: '주', pass: '회' };
      const unit   = unitMap[stat] || '';

      const displayEl = statEl.querySelector('.stat-display');
      if (!displayEl) return;
      const currentText = displayEl.textContent.replace(unit, '').trim();
      const current = parseInt(currentText, 10) || 0;

      // 이미 편집 중이면 무시
      if (statEl.querySelector('input[data-stat-input]')) return;

      displayEl.style.display = 'none';
      const wrapper = document.createElement('div');
      wrapper.className = 'flex items-center gap-1 mt-1';
      wrapper.innerHTML = `
        <input data-stat-input type="number" value="${current}" min="0" max="99"
               class="input input-xs input-bordered w-16 text-center font-bold text-lg"
               style="height:2rem">
        <span class="text-sm">${unit}</span>
        <button class="btn btn-xs btn-primary" onclick="confirmStatEdit(event,'${url}','${stat}','${csrf}',this)">저장</button>
        <button class="btn btn-xs btn-ghost" onclick="cancelStatEdit(this)">✕</button>
      `;
      statEl.querySelector('.stat-value').appendChild(wrapper);
      wrapper.querySelector('input').focus();
      wrapper.querySelector('input').select();
    };

    window.confirmStatEdit = function(e, url, stat, csrf, btn) {
      e.stopPropagation();
      const wrapper = btn.closest('div');
      const input = wrapper.querySelector('input[data-stat-input]');
      const value = parseInt(input.value, 10);
      if (isNaN(value) || value < 0) { input.focus(); return; }

      btn.disabled = true;
      btn.textContent = '...';

      const isBadgeStat = stat === 'gift_voucher_eligible';
      const headers = { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf };
      if (isBadgeStat) headers['Accept'] = 'text/vnd.turbo-stream.html';

      fetch(url, { method: 'PATCH', headers, body: JSON.stringify({ stat, value }) })
      .then(r => { if (!r.ok) throw new Error('저장 실패'); return isBadgeStat ? r.text() : r.json(); })
      .then(data => {
        if (isBadgeStat) {
          Turbo.renderStreamMessage(data);
        } else {
          const statEl = wrapper.closest('[data-stat]');
          const displayEl = statEl.querySelector('.stat-display');
          const unitMap = { consecutive_weeks: '주', pass: '회' };
          const unit = unitMap[stat] || '';
          displayEl.innerHTML = `${value}<span class="text-sm font-normal">${unit}</span>`;
          displayEl.style.display = '';
          wrapper.remove();
        }
      })
      .catch(() => {
        alert('저장 실패');
        btn.disabled = false;
        btn.textContent = '저장';
      });
    };

    window.cancelStatEdit = function(btn) {
      const wrapper = btn.closest('div');
      const statEl = wrapper.closest('[data-stat]');
      const displayEl = statEl.querySelector('.stat-display');
      displayEl.style.display = '';
      wrapper.remove();
    };
  }
</script>
