<% content_for :title, "결제 상세" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@payment.student.name}", student_path(@payment.student), class: "text-sm text-base-content/70 hover:underline" %>
  <h2 class="text-lg font-bold">결제 상세</h2>
  <% unless @payment.fully_paid? %>
    <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">미완납</span>
  <% end %>
  <% if @payment.refunded? %>
    <span class="bg-base-200 text-base-content/80 text-xs px-2 py-1 rounded">환불완료</span>
  <% end %>
</div>

<!-- 결제 상세 테이블 -->
<div class="bg-base-100 rounded-lg border shadow-sm p-4 mb-6 overflow-x-auto">
  <table class="table table-xs w-full text-sm">
    <thead>
      <tr class="text-xs text-base-content/60">
        <th>수강생</th>
        <th>과목</th>
        <th>유형</th>
        <th>기간</th>
        <th>횟수</th>
        <th>금액</th>
        <th>수단</th>
        <th>예약금</th>
        <th>예약금 납부일</th>
        <th>잔금</th>
        <th>잔금 납부일</th>
        <th>할인</th>
        <th>환불</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= link_to @payment.student.name, student_path(@payment.student), class: "hover:underline" %></td>
        <td><%= @payment.subject %></td>
        <td><%= @payment.payment_type == "deposit" ? "예약금" : "신규" %></td>
        <td><%= @payment.months %>개월</td>
        <td><%= @payment.total_lessons %>회</td>
        <td class="font-medium"><%= format_amount(@payment.amount) %></td>
        <td><%= @payment.payment_method %></td>
        <td><%= @payment.deposit_amount > 0 ? format_amount(@payment.deposit_amount) : "" %></td>
        <td><%= @payment.deposit_paid_at&.strftime("%Y.%m.%d") %></td>
        <td>
          <% if @payment.payment_type == "deposit" && @payment.balance_amount > 0 %>
            <%= format_amount(@payment.balance_amount) %>
          <% end %>
        </td>
        <td>
          <% if @payment.payment_type == "deposit" %>
            <% if @payment.balance_paid_at %>
              <%= @payment.balance_paid_at.strftime("%Y.%m.%d") %>
            <% else %>
              <span class="text-error text-xs">미납</span>
            <% end %>
          <% end %>
        </td>
        <td class="text-purple-600">
          <% @discounts.each do |d| %>
            <div><%= d.memo.presence || d.discount_type %> -<%= format_amount(d.amount) %></div>
          <% end %>
        </td>
        <td>
          <% if @payment.refunded? %>
            <div class="text-error"><%= format_amount(@payment.refund_amount) %></div>
            <div class="text-xs text-base-content/60"><%= @payment.refund_reason %></div>
          <% end %>
        </td>
      </tr>
    </tbody>
  </table>
</div>

<!-- 액션 버튼 -->
<div class="flex gap-2 mb-6">
  <% unless @payment.fully_paid? %>
    <%= button_to "잔금 납부 처리", pay_balance_payment_path(@payment), method: :patch,
          class: "btn btn-sm btn-success",
          form: { onsubmit: "return confirm('잔금 납부 완료 처리하시겠습니까?')" } %>
  <% end %>
  <% unless @payment.refunded? %>
    <%= form_with url: refund_payment_path(@payment), method: :post, class: "flex items-center gap-2" do |f| %>
      <%= f.number_field :refund_amount, value: @payment.refund_amount_calculated, class: "input input-bordered input-sm w-28" %>
      <%= f.text_field :refund_reason, placeholder: "환불 사유", class: "input input-bordered input-sm flex-1" %>
      <%= f.submit "환불 처리", class: "btn btn-sm btn-error btn-outline cursor-pointer",
            data: { onsubmit: "return confirm('환불 처리하시겠습니까?')" } %>
    <% end %>
  <% end %>
</div>

<!-- 수업 날짜 리스트 -->
<div class="bg-base-100 rounded-lg border shadow-sm p-4">
  <h3 class="font-semibold text-sm mb-3">수업 날짜 리스트</h3>
  <table class="w-full text-sm">
    <thead class="text-xs text-base-content/60 border-b">
      <tr>
        <th class="pb-1 text-left">회차</th>
        <th class="pb-1 text-left">날짜</th>
        <th class="pb-1 text-left">상태</th>
        <th class="pb-1 text-left">보강</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @schedules.each do |s| %>
        <tr>
          <td class="py-1.5 text-base-content/60"><%= s.sequence %>회</td>
          <td><%= s.lesson_date.strftime("%Y.%m.%d (%a)") %></td>
          <td><%= schedule_status_badge(s.status) %></td>
          <td class="text-xs text-indigo-500">
            <% if s.makeup_date %>
              <%= s.makeup_date.strftime("%m/%d") %> <%= s.makeup_teacher&.name %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
