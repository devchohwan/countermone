<%# locals: student, existing_referrers %>
<div class="bg-base-100 rounded-lg border shadow-sm p-4 space-y-3" id="referrer-section">
  <h3 class="font-semibold text-sm">추천인 <span class="text-xs text-base-content/50 font-normal">(최대 7명)</span></h3>

  <%# 기존 추천인 태그 %>
  <div id="referrer-tags" class="flex flex-wrap gap-2 min-h-6">
    <% (existing_referrers || []).each do |r| %>
      <span class="badge badge-outline gap-1" data-referrer-id="<%= r.id %>">
        <%= r.name %>
        <button type="button" onclick="removeReferrer(<%= r.id %>)" class="text-error hover:text-error/70">✕</button>
        <input type="hidden" name="referrer_ids[]" value="<%= r.id %>">
      </span>
    <% end %>
  </div>

  <%# 검색 입력 %>
  <div class="relative">
    <input type="text" id="referrer-search" placeholder="이름 검색..." autocomplete="off"
           class="input input-bordered input-sm w-full text-sm"
           oninput="searchReferrers(this.value)">
    <div id="referrer-results" class="absolute z-30 w-full bg-base-100 border border-base-300 rounded-lg shadow-lg mt-1 hidden max-h-48 overflow-y-auto"></div>
  </div>
</div>

<script>
(function() {
  const MAX_REFERRERS = 7;
  let searchTimer = null;

  window.searchReferrers = function(q) {
    clearTimeout(searchTimer);
    const resultsEl = document.getElementById('referrer-results');
    if (q.length < 1) { resultsEl.classList.add('hidden'); return; }
    searchTimer = setTimeout(() => {
      fetch('/students/search?q=' + encodeURIComponent(q))
        .then(r => r.json())
        .then(data => {
          const tags = document.querySelectorAll('#referrer-tags [data-referrer-id]');
          const selectedIds = Array.from(tags).map(t => t.dataset.referrerId);
          const filtered = data.filter(s => !selectedIds.includes(String(s.id)));
          if (filtered.length === 0) {
            resultsEl.innerHTML = '<p class="text-xs text-base-content/50 px-3 py-2">검색 결과 없음</p>';
          } else {
            resultsEl.innerHTML = filtered.map(s =>
              `<div class="px-3 py-2 hover:bg-base-200 cursor-pointer text-sm" onclick="addReferrer(${s.id}, '${s.name.replace(/'/g, "\\'")}')">${s.name}</div>`
            ).join('');
          }
          resultsEl.classList.remove('hidden');
        });
    }, 200);
  };

  window.addReferrer = function(id, name) {
    const tagsEl = document.getElementById('referrer-tags');
    const tags = tagsEl.querySelectorAll('[data-referrer-id]');
    if (tags.length >= MAX_REFERRERS) {
      alert('추천인은 최대 7명까지 입력 가능합니다.');
      return;
    }
    const span = document.createElement('span');
    span.className = 'badge badge-outline gap-1';
    span.dataset.referrerId = id;
    span.innerHTML = `${name} <button type="button" onclick="removeReferrer(${id})" class="text-error hover:text-error/70">✕</button><input type="hidden" name="referrer_ids[]" value="${id}">`;
    tagsEl.appendChild(span);
    document.getElementById('referrer-search').value = '';
    document.getElementById('referrer-results').classList.add('hidden');
  };

  window.removeReferrer = function(id) {
    const tag = document.querySelector(`#referrer-tags [data-referrer-id="${id}"]`);
    if (tag) tag.remove();
  };

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#referrer-section')) {
      document.getElementById('referrer-results')?.classList.add('hidden');
    }
  });
})();
</script>
