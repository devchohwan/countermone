<%
  regular_by_hour  = (schedules || []).reject { |s| s.status.in?(%w[makeup_scheduled makeup_done]) }.group_by { |s| s.lesson_time.in_time_zone('Seoul').hour }
  makeup_by_hour   = (makeups || []).group_by { |s| s.makeup_time&.in_time_zone('Seoul')&.hour }.compact
  deducted_by_hour = (deducted_schedules || []).group_by { |s| s.lesson_time.in_time_zone('Seoul').hour }
  all_hours = (regular_by_hour.keys + makeup_by_hour.keys + deducted_by_hour.keys).uniq.sort

  # 첫수업 판단
  seq1_schedules = (schedules || []).select { |s| s.sequence == 1 }
  first_payment_ids = if seq1_schedules.any?
    enroll_ids = seq1_schedules.map(&:enrollment_id).uniq
    Payment.where(enrollment_id: enroll_ids).group(:enrollment_id).minimum(:id).values.to_set
  else
    Set.new
  end
  first_lesson_ids = seq1_schedules.select { |s| first_payment_ids.include?(s.payment_id) }.map(&:id).to_set

  # 선생님 정렬 순서 (teachers 페이지 카드 순서)
  teacher_order = Teacher.by_position.pluck(:name).each_with_index.to_h

  # 시간대별 선생님 그룹 빌드: teacher_name => { regulars: [], makeups: [] }
  hour_groups = all_hours.index_with do |hour|
    combined = {}
    (regular_by_hour[hour] || []).each do |s|
      key = s.teacher.name
      combined[key] ||= { regulars: [], makeups: [], deducted: [] }
      combined[key][:regulars] << s
    end
    (makeup_by_hour[hour] || []).each do |s|
      key = s.makeup_teacher.name
      combined[key] ||= { regulars: [], makeups: [], deducted: [] }
      combined[key][:makeups] << s
    end
    (deducted_by_hour[hour] || []).each do |s|
      key = s.teacher.name
      combined[key] ||= { regulars: [], makeups: [], deducted: [] }
      combined[key][:deducted] << s
    end
    combined.sort_by { |name, _| teacher_order.fetch(name, 999) }.to_h
  end
%>
<div class="card bg-base-100 shadow-sm">
  <div class="card-body p-4">
    <div class="flex items-center justify-between mb-2">
      <h3 class="card-title text-sm">시간대별 수업</h3>
      <% unless all_hours.empty? %>
        <%
          copy_lines = []
          all_hours.each do |hour|
            copy_lines << "#{hour}시"
            hour_groups[hour].each do |teacher_name, group|
              copy_lines << "[#{teacher_name}]"
              group[:regulars].each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                tag = first_lesson_ids.include?(s.id) ? "(첫)" : ""
                if s.status.in?(%w[attended late])
                  copy_lines << "#{s.student.name}#{tag} #{remaining + 1}-#{remaining}"
                else
                  copy_lines << "#{s.student.name}#{tag} #{remaining}"
                end
              end
              group[:makeups].each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                attended  = s.status == "makeup_done"
                if attended
                  copy_lines << "#{s.student.name}(보/#{s.teacher.name}) #{remaining + 1}-#{remaining}"
                else
                  copy_lines << "#{s.student.name}(보/#{s.teacher.name}) #{remaining}"
                end
              end
              group[:deducted].each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                copy_lines << "#{s.student.name} #{remaining}>당취"
              end
            end
            copy_lines << ""
          end
          copy_text = copy_lines.join("\n").strip
        %>
        <button
          class="btn btn-xs btn-ghost"
          data-copy-text="<%= copy_text %>"
          onclick="
            navigator.clipboard.writeText(this.dataset.copyText)
              .then(() => { this.textContent = '✓ 복사됨'; setTimeout(() => this.textContent = '복사', 1500); })
              .catch(() => {});
          ">복사</button>
      <% end %>
    </div>

    <% if all_hours.empty? %>
      <p class="text-sm text-base-content/40">수업이 없습니다.</p>
    <% else %>
      <div class="flex flex-col gap-3 font-mono text-sm leading-snug overflow-y-auto max-h-72">
        <% all_hours.each do |hour| %>
          <div>
            <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
            <% first_group = true %>
            <% hour_groups[hour].each do |teacher_name, group| %>
              <% unless first_group %><div class="h-2"></div><% end %>
              <% first_group = false %>
              <p class="text-xs text-base-content/40">[<%= teacher_name %>]</p>

              <% group[:regulars].each do |s| %>
                <%
                  attended  = s.status.in?(%w[attended late])
                  remaining = enrollment_remaining[s.enrollment_id] || 0
                  is_first  = first_lesson_ids.include?(s.id)
                %>
                <p>
                  <%= link_to s.student.name, student_path(s.student, tab: s.enrollment_id), class: "hover:underline", data: { turbo_frame: "_top" } %><% if s.trial? %><span class="text-accent">(체험)</span><% elsif is_first %><span class="text-success">(첫)</span><% end %>
                  <% if attended %>
                    <span class="text-base-content/40"><%= remaining + 1 %>-<%= remaining %></span>
                  <% else %>
                    <span class="text-base-content/40"><%= remaining %></span>
                  <% end %>
                </p>
              <% end %>

              <% group[:makeups].each do |s| %>
                <%
                  remaining = enrollment_remaining[s.enrollment_id] || 0
                  attended  = s.status == "makeup_done"
                %>
                <p>
                  <%= link_to s.student.name, student_path(s.student, tab: s.enrollment_id), class: "hover:underline", data: { turbo_frame: "_top" } %><span class="text-purple-500">(보/<%= s.teacher.name %>)</span>
                  <% if attended %>
                    <span class="text-base-content/40"><%= remaining + 1 %>-<%= remaining %></span>
                  <% else %>
                    <span class="text-base-content/40"><%= remaining %></span>
                  <% end %>
                </p>
              <% end %>

              <% group[:deducted].each do |s| %>
                <% remaining = enrollment_remaining[s.enrollment_id] || 0 %>
                <p>
                  <%= link_to s.student.name, student_path(s.student, tab: s.enrollment_id), class: "hover:underline", data: { turbo_frame: "_top" } %>
                  <span class="text-base-content/40"><%= remaining %></span><span class="text-base-content/40">></span><span class="text-error text-xs">당취</span>
                </p>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
