<%# 오늘 결제 예정 체크리스트 — 체크해도 사라지지 않음 (localStorage 저장) %>
<% if @payment_due_today.empty? %>
  <p class="text-sm text-base-content/40">결제 예정 없음</p>
<% else %>
  <%
    teacher_order = Teacher.by_position.to_a
    grouped = {}
    teacher_order.each do |t|
      items = @payment_due_today.select { |i| i[:enrollment]&.teacher_id == t.id }
      grouped[t] = items if items.any?
    end
    ungrouped = @payment_due_today.reject { |i| grouped.values.flatten.include?(i) }
  %>

  <div class="space-y-3 text-sm">
    <% grouped.each do |teacher, items| %>
      <div>
        <div class="text-xs text-base-content/40 mb-0.5">[<%= teacher.name %>]</div>
        <% items.each do |item| %>
          <label class="payment-item flex items-center gap-2 py-0.5 cursor-pointer select-none"
                 data-key="<%= item[:student].id %>_<%= item[:enrollment]&.id %>">
            <input type="checkbox" class="checkbox checkbox-xs payment-check flex-none" />
            <span class="payment-label">
              <%= item[:student].name %>
              <% if item[:type] == :deposit_first_lesson %>
                <span class="text-xs text-error/70">(첫)(예약금)</span>
              <% elsif item[:type] == :balance_due %>
                <span class="text-xs text-warning/70">(예약금)</span>
              <% end %>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>
    <% if ungrouped.any? %>
      <div>
        <div class="text-xs text-base-content/40 mb-0.5">[기타]</div>
        <% ungrouped.each do |item| %>
          <label class="payment-item flex items-center gap-2 py-0.5 cursor-pointer select-none"
                 data-key="<%= item[:student].id %>_<%= item[:enrollment]&.id %>">
            <input type="checkbox" class="checkbox checkbox-xs payment-check flex-none" />
            <span class="payment-label"><%= item[:student].name %></span>
          </label>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<script>
(function() {
  const KEY  = 'payment_checks_<%= Date.today %>';
  const saved = JSON.parse(localStorage.getItem(KEY) || '{}');

  document.querySelectorAll('.payment-item').forEach(row => {
    const cb = row.querySelector('.payment-check');
    const k  = row.dataset.key;
    cb.checked = !!saved[k];
    applyStyle(row, cb.checked);
    cb.addEventListener('change', () => {
      saved[k] = cb.checked;
      localStorage.setItem(KEY, JSON.stringify(saved));
      applyStyle(row, cb.checked);
    });
  });

  function applyStyle(row, checked) {
    row.style.opacity = checked ? '0.4' : '';
    row.querySelector('.payment-label').style.textDecoration = checked ? 'line-through' : '';
  }
})();
</script>
