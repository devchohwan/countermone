<% content_for :title, "#{@enrollment.subject} — #{@enrollment.student.name}" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@enrollment.student.name}", student_path(@enrollment.student), class: "text-sm text-gray-500 hover:underline" %>
  <h2 class="text-lg font-bold"><%= @enrollment.subject %></h2>
  <span class="text-gray-400">/ <%= @enrollment.teacher.name %></span>
  <%= status_badge(@enrollment.status) %>
  <div class="ml-auto flex gap-2">
    <% if @enrollment.status == "active" %>
      <%= button_to "휴원", leave_enrollment_path(@enrollment), method: :patch, class: "text-sm bg-yellow-100 text-yellow-800 px-3 py-1 rounded" %>
    <% elsif @enrollment.status == "leave" %>
      <%= button_to "복귀", return_enrollment_path(@enrollment), method: :patch, class: "text-sm bg-green-100 text-green-700 px-3 py-1 rounded" %>
    <% end %>
    <%= link_to "결제 등록", new_payment_path(enrollment_id: @enrollment.id), class: "text-sm bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700" %>
  </div>
</div>

<div class="grid grid-cols-2 gap-6">

  <!-- 결제 이력 -->
  <div class="bg-white rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">결제 이력</h3>
    <% if @payments.empty? %>
      <p class="text-sm text-gray-400">결제 이력이 없습니다.</p>
    <% else %>
      <div class="space-y-3">
        <% @payments.each do |p| %>
          <div class="border rounded p-3 text-sm">
            <div class="flex items-center justify-between">
              <span class="font-medium"><%= p.starts_at.strftime("%Y.%m.%d") %> ~</span>
              <span class="text-gray-500"><%= format_amount(p.amount) %></span>
            </div>
            <div class="text-xs text-gray-400 mt-1">
              <%= p.months %>개월 / <%= p.total_lessons %>회 /
              <%= p.payment_method == "card" ? "카드" : p.payment_method == "transfer" ? "이체" : "현금" %>
              <% unless p.fully_paid? %>
                <span class="text-red-500 font-medium ml-1">미완납</span>
              <% end %>
            </div>
            <% if p.discounts.any? %>
              <div class="text-xs text-purple-600 mt-1">
                할인: <%= p.discounts.map { |d| "#{d.memo || d.discount_type} #{format_amount(d.amount)}" }.join(", ") %>
              </div>
            <% end %>
            <div class="mt-2">
              <%= link_to "상세", payment_path(p), class: "text-xs text-blue-600 hover:underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 수업 날짜 전체 -->
  <div class="bg-white rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">
      수업 날짜 리스트
      <span class="text-gray-400 font-normal ml-2">잔여 <%= @enrollment.student.remaining_lessons_for(@enrollment) %>회</span>
    </h3>
    <div class="overflow-y-auto max-h-96">
      <table class="w-full text-xs">
        <thead class="text-gray-400 border-b">
          <tr>
            <th class="pb-1 text-left">회차</th>
            <th class="pb-1 text-left">날짜</th>
            <th class="pb-1 text-left">상태</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% @schedules.each do |s| %>
            <tr class="py-1">
              <td class="py-1 text-gray-400"><%= s.sequence %>회</td>
              <td class="py-1">
                <%= s.lesson_date.strftime("%m/%d (%a)") %>
                <% if s.makeup_date %>
                  <span class="text-indigo-500">→ 보강 <%= s.makeup_date.strftime("%m/%d") %></span>
                <% end %>
              </td>
              <td class="py-1"><%= schedule_status_badge(s.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
