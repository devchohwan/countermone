<div role="tabpanel" class="tab-content pt-3" id="attendance-events-panel">
  <% if attendance_events.empty? %>
    <p class="text-sm text-base-content/40">개근 달성자 없음</p>
  <% else %>
    <p class="text-xs text-base-content/50 mb-2">다음 결제 등록 시 수업 횟수 1회 추가 입력 필요</p>
    <ul class="space-y-2">
      <% attendance_events.each do |e| %>
        <li class="flex items-center gap-2 text-sm">
          <span class="font-medium"><%= e.student.name %></span>
          <span class="text-base-content/50"><%= e.subject %></span>
          <span class="badge badge-xs badge-success">12주 개근</span>
          <%= button_to "개근처리", dismiss_attendance_event_enrollment_path(e),
                method: :patch,
                class: "btn btn-xs btn-success ml-auto",
                data: { turbo_confirm: "#{e.student.name} 개근 1회 추가 처리하시겠습니까?" } %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
