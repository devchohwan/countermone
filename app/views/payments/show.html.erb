<% content_for :title, "결제 상세" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@student.name}", student_path(@student), class: "text-sm text-base-content/70 hover:underline" %>
  <h2 class="text-lg font-bold">결제 내역</h2>
  <%= link_to "전체 수정", edit_payment_path(@payment), class: "btn btn-xs btn-outline ml-auto" %>
</div>

<p class="text-xs text-base-content/40 mb-2">셀을 클릭하면 수정할 수 있습니다. Enter로 저장, Esc로 취소.</p>

<!-- 결제 상세 테이블 -->
<div class="bg-base-100 rounded-lg border shadow-sm p-4 mb-6 overflow-x-auto">
  <table class="table table-xs w-full text-sm">
    <thead>
      <tr class="text-xs text-base-content/60">
        <th>유형</th>
        <th>과목</th>
        <th>기간</th>
        <th>횟수</th>
        <th>할인</th>
        <th>할인일</th>
        <th>금액</th>
        <th>수단</th>
        <th>결제일</th>
        <th>예약금</th>
        <th>예약금 납부일</th>
        <th>잔금</th>
        <th>잔금 납부일</th>
        <th>상태</th>
        <th>환불</th>
      </tr>
    </thead>
    <tbody>
      <% @payments.each do |payment| %>
        <tr>
          <td><%= payment.payment_type == "deposit" ? "예약금" : "신규" %></td>
          <td><%= payment.subject %></td>

          <%# 기간 — 수정 가능 %>
          <td class="editable-cell" data-payment-id="<%= payment.id %>" data-field="months"
              data-raw="<%= payment.months %>" data-input-type="number">
            <%= payment.months %>개월
          </td>

          <%# 횟수 — 수정 가능 %>
          <td class="editable-cell" data-payment-id="<%= payment.id %>" data-field="total_lessons"
              data-raw="<%= payment.total_lessons %>" data-input-type="number">
            <%= payment.total_lessons %>회
          </td>

          <td class="text-purple-600">
            <% payment.discounts.each do |d| %>
              <div><%= d.memo.presence || d.discount_type %> -<%= format_amount(d.amount) %></div>
            <% end %>
          </td>
          <td class="text-xs text-base-content/60">
            <% payment.discounts.each do |d| %>
              <div><%= d.created_at.strftime("%Y.%m.%d") %></div>
            <% end %>
          </td>

          <%# 금액 — 수정 가능 %>
          <td class="editable-cell font-medium" data-payment-id="<%= payment.id %>" data-field="amount"
              data-raw="<%= payment.amount %>" data-input-type="number">
            <%= format_amount(payment.amount) %>
          </td>

          <%# 수단 — 수정 가능 (select) %>
          <td class="editable-cell" data-payment-id="<%= payment.id %>" data-field="payment_method"
              data-raw="<%= payment.payment_method %>"
              data-options='[["카드","card"],["계좌이체","transfer"],["현금","cash"]]'>
            <%= ({ "card" => "카드", "transfer" => "계좌이체", "cash" => "현금" }[payment.payment_method] || payment.payment_method) %>
          </td>

          <%# 결제일 (new 타입) — 수정 가능 %>
          <td<% unless payment.payment_type == "deposit" %> class="editable-cell"
              data-payment-id="<%= payment.id %>" data-field="deposit_paid_at"
              data-raw="<%= payment.deposit_paid_at&.to_date %>" data-input-type="date"<% end %>>
            <% unless payment.payment_type == "deposit" %>
              <%= payment.deposit_paid_at&.strftime("%Y.%m.%d") %>
            <% end %>
          </td>

          <%# 예약금 — 수정 가능 %>
          <td<% if payment.payment_type == "deposit" && payment.deposit_amount > 0 %> class="editable-cell"
              data-payment-id="<%= payment.id %>" data-field="deposit_amount"
              data-raw="<%= payment.deposit_amount %>" data-input-type="number"<% end %>>
            <%= payment.payment_type == "deposit" && payment.deposit_amount > 0 ? format_amount(payment.deposit_amount) : "" %>
          </td>

          <%# 예약금 납부일 — 수정 가능 %>
          <td<% if payment.payment_type == "deposit" %> class="editable-cell"
              data-payment-id="<%= payment.id %>" data-field="deposit_paid_at"
              data-raw="<%= payment.deposit_paid_at&.to_date %>" data-input-type="date"<% end %>>
            <% if payment.payment_type == "deposit" %>
              <%= payment.deposit_paid_at&.strftime("%Y.%m.%d") %>
            <% end %>
          </td>

          <%# 잔금 — 수정 가능 %>
          <td<% if payment.payment_type == "deposit" && payment.balance_amount > 0 %> class="editable-cell"
              data-payment-id="<%= payment.id %>" data-field="balance_amount"
              data-raw="<%= payment.balance_amount %>" data-input-type="number"<% end %>>
            <% if payment.payment_type == "deposit" && payment.balance_amount > 0 %>
              <%= format_amount(payment.balance_amount) %>
            <% end %>
          </td>

          <%# 잔금 납부일 — 수정 가능 %>
          <td<% if payment.payment_type == "deposit" %> class="editable-cell"
              data-payment-id="<%= payment.id %>" data-field="balance_paid_at"
              data-raw="<%= payment.balance_paid_at&.to_date %>" data-input-type="date"<% end %>>
            <% if payment.payment_type == "deposit" %>
              <% if payment.balance_paid_at %>
                <%= payment.balance_paid_at.strftime("%Y.%m.%d") %>
              <% else %>
                <span class="text-error text-xs">미납</span>
              <% end %>
            <% end %>
          </td>

          <td>
            <% if payment.refunded? %>
              <span class="badge badge-xs badge-ghost">환불완료</span>
            <% elsif payment.fully_paid? %>
              <span class="badge badge-xs badge-success">완납</span>
            <% else %>
              <span class="badge badge-xs badge-warning">미완납</span>
            <% end %>
          </td>
          <td>
            <% if payment.refunded? %>
              <div class="text-error"><%= format_amount(payment.refund_amount) %></div>
              <div class="text-xs text-base-content/60"><%= payment.refund_reason %></div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr class="border-t-2 border-base-300 font-semibold text-sm">
        <td colspan="14" class="pt-2 text-right pr-3 text-base-content/50">실수령 합계</td>
        <td class="pt-2 text-right"><%= format_amount(@payments.reject(&:refunded?).sum(&:amount)) %></td>
      </tr>
    </tfoot>
  </table>
</div>

<!-- 과목별 수업 날짜 리스트 -->
<% @schedule_groups.each do |g| %>
  <div class="bg-base-100 rounded-lg border shadow-sm p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-sm"><%= g[:enrollment].subject %> 수업 날짜</h3>
      <span class="text-xs text-base-content/50">총 <%= g[:total] %>회</span>
    </div>
    <table class="w-full text-sm">
      <thead class="text-xs text-base-content/60 border-b">
        <tr>
          <th class="pb-1 text-left">회차</th>
          <th class="pb-1 text-left">날짜</th>
          <th class="pb-1 text-left">사유</th>
          <th class="pb-1 text-left">상태</th>
          <th class="pb-1 text-left">보강</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <%
          ev_list = g[:schedules].map { |s| { type: :schedule, date: s.lesson_date, obj: s } }
          enr = g[:enrollment]
          ev_list << { type: :leave,  date: enr.leave_at }  if enr.leave_at.present?
          ev_list << { type: :return, date: enr.return_at } if enr.return_at.present?
          ev_list.sort_by! { |ev| ev[:date] }
        %>
        <% ev_list.each do |ev| %>
          <% if ev[:type] == :schedule %>
            <% s = ev[:obj] %>
            <tr>
              <td class="py-1.5 text-base-content/60"><%= s.sequence %>회</td>
              <td><%= s.lesson_date.strftime("%Y.%m.%d (%a)") %></td>
              <td></td>
              <td><%= schedule_status_badge(s.status) %></td>
              <td class="text-xs text-indigo-500">
                <% if s.makeup_date %>
                  <%= s.makeup_date.strftime("%m/%d") %> <%= s.makeup_teacher&.name %>
                <% end %>
              </td>
            </tr>
          <% elsif ev[:type] == :leave %>
            <tr class="bg-warning/10">
              <td class="py-1.5 text-xs font-semibold text-warning">휴원</td>
              <td class="text-xs text-warning"><%= ev[:date].strftime("%Y.%m.%d (%a)") %></td>
              <td class="text-xs text-base-content/60"><%= enr.leave_reason %></td>
              <td><span class="badge badge-xs badge-warning">휴원</span></td>
              <td></td>
            </tr>
          <% elsif ev[:type] == :return %>
            <tr class="bg-success/10">
              <td class="py-1.5 text-xs font-semibold text-success">복귀</td>
              <td class="text-xs text-success"><%= ev[:date].strftime("%Y.%m.%d (%a)") %></td>
              <td></td>
              <td><span class="badge badge-xs badge-success">복귀</span></td>
              <td></td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
    <% if g[:total_pages] > 1 %>
      <div class="flex items-center gap-2 mt-3 text-xs">
        <% if g[:page] > 1 %>
          <%= link_to "← 이전", request.params.merge("page_#{g[:enrollment].id}" => g[:page] - 1),
                class: "btn btn-xs btn-ghost" %>
        <% end %>
        <span class="text-base-content/50"><%= g[:page] %> / <%= g[:total_pages] %></span>
        <% if g[:page] < g[:total_pages] %>
          <%= link_to "다음 →", request.params.merge("page_#{g[:enrollment].id}" => g[:page] + 1),
                class: "btn btn-xs btn-ghost" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<style>
  .editable-cell {
    cursor: pointer;
    border-bottom: 1px dashed oklch(var(--bc) / 0.3);
    transition: background 0.1s;
  }
  .editable-cell:hover { background: oklch(var(--b2)); }
  .editable-cell input, .editable-cell select {
    min-width: 70px; max-width: 140px;
  }
</style>

<script>
document.querySelectorAll('.editable-cell').forEach(cell => {
  cell.addEventListener('click', function () {
    if (cell.querySelector('input, select')) return;

    const field     = cell.dataset.field;
    const raw       = cell.dataset.raw || '';
    const paymentId = cell.dataset.paymentId;
    const inputType = cell.dataset.inputType || 'text';
    const optionsJson = cell.dataset.options;
    const original  = cell.innerHTML;

    let ctrl;
    if (optionsJson) {
      ctrl = document.createElement('select');
      ctrl.className = 'select select-bordered select-xs';
      JSON.parse(optionsJson).forEach(([label, val]) => {
        const o = document.createElement('option');
        o.value = val; o.textContent = label;
        if (String(val) === String(raw)) o.selected = true;
        ctrl.appendChild(o);
      });
    } else {
      ctrl = document.createElement('input');
      ctrl.type = inputType;
      ctrl.value = raw;
      ctrl.className = 'input input-bordered input-xs';
      ctrl.style.width = inputType === 'date' ? '130px' : '80px';
    }

    cell.innerHTML = '';
    cell.appendChild(ctrl);
    ctrl.focus();
    if (ctrl.tagName === 'INPUT' && ctrl.type !== 'date') ctrl.select();

    const csrf = document.querySelector('meta[name="csrf-token"]').content;

    const save = async () => {
      const val = ctrl.value;
      if (val === raw) { cell.innerHTML = original; return; }
      try {
        const res = await fetch(`/payments/${paymentId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf, 'Accept': 'application/json' },
          body: JSON.stringify({ payment: { [field]: val } })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          alert(data.error || '수정에 실패했습니다.');
          cell.innerHTML = original;
        }
      } catch {
        cell.innerHTML = original;
      }
    };

    ctrl.addEventListener('keydown', e => {
      if (e.key === 'Enter')  { e.preventDefault(); save(); }
      if (e.key === 'Escape') { cell.innerHTML = original; }
    });
    ctrl.addEventListener('change', () => { if (ctrl.tagName === 'SELECT') save(); });
    ctrl.addEventListener('blur', () => setTimeout(() => {
      if (cell.contains(ctrl)) save();
    }, 150));
  });
});
</script>
