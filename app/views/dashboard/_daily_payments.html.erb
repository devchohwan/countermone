<div id="daily_payments">
  <% unless daily_payments.empty? %>
    <div class="card bg-base-100 shadow-sm h-96">
      <div class="card-body p-4 flex flex-col overflow-hidden">
        <h3 class="card-title text-sm mb-2">결제 내역</h3>
        <ul class="space-y-1 overflow-y-auto flex-1 min-h-0">
          <% daily_payments.each do |p| %>
            <li class="text-sm flex items-center gap-2">
              <%= link_to p.student.name, student_path(p.student), class: "hover:underline" %> — <%= p.subject %> (<%= format_amount(p.amount) %>)
              <% if p.payment_type == "deposit" && !p.fully_paid? %>
                <span class="badge badge-warning badge-xs">예약금</span>
              <% else %>
                <span class="badge badge-success badge-xs">완납</span>
              <% end %>
              <%= link_to "수정", edit_payment_path(p), class: "btn btn-xs btn-ghost" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
</div>
