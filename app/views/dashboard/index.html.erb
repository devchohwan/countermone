<% content_for :title, "대시보드 — 모네뮤직" %>

<% if @is_today %>
  <%= turbo_stream_from "dashboard_current" %>
<% end %>

<div class="space-y-4">

  <%# 헤더 + 날짜 네비게이션 %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="join">
        <%= link_to "←", root_path(date: (@date - 1).to_s), class: "join-item btn btn-sm btn-ghost" %>
        <span class="join-item btn btn-sm btn-ghost pointer-events-none font-semibold">
          <%= @date.strftime("%Y.%m.%d (%a)") %>
        </span>
        <%= link_to "→", root_path(date: (@date + 1).to_s),
              class: "join-item btn btn-sm btn-ghost #{@date >= Date.today ? 'btn-disabled opacity-30' : ''}" %>
      </div>
      <% unless @is_today %>
        <%= link_to "오늘", root_path, class: "btn btn-xs btn-primary" %>
      <% end %>
      <% if @is_today %>
        <p class="text-sm text-base-content/60" id="dashboard-time"></p>
      <% end %>
    </div>
    <div class="flex gap-2 items-center">
      <% if @attendance_events&.any? %>
        <div class="badge badge-accent gap-1">🔥 개근달성 <%= @attendance_events.count %>명</div>
      <% end %>
      <% if @is_today %>
        <% if @payment_due_today.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-error badge-xs"><%= @payment_due_today.count %></span><span class="btn btn-ghost btn-sm">💳</span></div>
        <% end %>
        <% if @contact_list.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-warning badge-xs"><%= @contact_list.count %></span><span class="btn btn-ghost btn-sm">📞</span></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @is_today %>
    <%# 3×2 그리드 %>
    <div class="grid grid-cols-3 gap-4">

      <%# Row 1: 시간대별수업 / 시간대별등하원 / 지금이순간 %>
      <%= render "hourly_schedule_text",
            schedules: @today_schedules,
            enrollment_remaining: @enrollment_remaining %>

      <%= render "hourly_arrival_text", schedules: @today_schedules %>

      <div>
        <%= turbo_frame_tag "current_schedules", src: dashboard_current_schedules_path, loading: :lazy do %>
          <%= render "current_schedules" %>
        <% end %>
      </div>

      <%# Row 2: 오늘결제/연락/확인 / 내일결제자 / 오늘마감 %>

      <%# 오늘 결제자·연락·확인 (탭) %>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">
          <div role="tablist" class="tabs tabs-bordered tabs-sm">

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="💳 결제 (<%= @payment_due_today.count %>)" checked />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @payment_due_today.empty? %>
                <p class="text-sm text-base-content/40">오늘 결제 예정 없음</p>
              <% else %>
                <ul class="space-y-2">
                  <% @payment_due_today.each do |item| %>
                    <% color = item[:type] == :deposit_first_lesson ? "border-error" : item[:type] == :balance_due ? "border-warning" : "border-info" %>
                    <li class="flex items-center gap-2 text-sm border-l-2 pl-2 <%= color %>">
                      <span class="font-medium"><%= item[:student].name %></span>
                      <span class="text-base-content/50">— <%= item[:enrollment].subject %></span>
                      <span class="badge badge-xs <%= item[:type] == :deposit_first_lesson ? 'badge-error' : item[:type] == :balance_due ? 'badge-warning' : 'badge-info' %>">
                        <%= case item[:type]
                            when :deposit_first_lesson then "오늘 첫수업, 완납필요"
                            when :balance_due          then "잔금미납"
                            when :next_payment_due     then "다음결제예정"
                            end %>
                      </span>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="📞 연락 (<%= @contact_list.count %>)" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @contact_list.empty? %>
                <p class="text-sm text-base-content/40">오늘 연락할 대상 없음</p>
              <% else %>
                <ul class="space-y-2">
                  <% @contact_list.each do |item| %>
                    <li class="flex items-center gap-2 text-sm">
                      <span class="font-medium"><%= item[:student].name %></span>
                      <span class="badge badge-xs badge-outline">
                        <%= case item[:type]
                            when :contact_due     then "연락기한"
                            when :return_due      then "복귀예정"
                            when :waiting_expired then "자리대기만료"
                            end %>
                      </span>
                      <% if item[:enrollment] %>
                        <span class="text-xs text-base-content/50"><%= item[:enrollment].subject %></span>
                      <% end %>
                      <%= button_to "완료", complete_contact_student_path(item[:student]),
                            method: :patch,
                            class: "btn btn-xs btn-ghost text-success ml-auto" %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab" aria-label="✅ 확인" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @minus_enrollments.any? %>
                <p class="text-xs font-bold text-error mb-1">마이너스 수업</p>
                <% @minus_enrollments.each do |e| %>
                  <p class="text-sm"><%= e.student.name %> — <%= e.subject %> (<%= e.minus_lesson_count %>회)</p>
                <% end %>
              <% end %>
              <% if @pending_consents.any? %>
                <p class="text-xs font-bold text-warning mt-2 mb-1">동의서 미수령</p>
                <% @pending_consents.each do |s| %>
                  <p class="text-sm"><%= s.name %></p>
                <% end %>
              <% end %>
              <% if @minus_enrollments.empty? && @pending_consents.empty? %>
                <p class="text-sm text-base-content/40">없음</p>
              <% end %>
            </div>

          </div>
        </div>
      </div>

      <%# 내일 결제자 %>
      <%= render "tomorrow_payments" %>

      <%# 오늘 마감 %>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">
          <div class="flex items-center justify-between mb-1">
            <h3 class="card-title text-sm">오늘 마감</h3>
            <%= link_to "마감 톡 생성 →", statistics_path(date: @date), class: "btn btn-xs btn-primary" %>
          </div>
          <%= render "daily_summary" %>
        </div>
      </div>

    </div>

  <% else %>
    <%# 과거/미래: 마감 요약만 %>
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body p-4">
        <div class="flex items-center justify-between mb-1">
          <h3 class="card-title text-sm"><%= @date.strftime("%m/%d") %> 마감</h3>
          <%= link_to "마감 톡 생성 →", statistics_path(date: @date), class: "btn btn-xs btn-primary" %>
        </div>
        <%= render "daily_summary" %>
      </div>
    </div>
  <% end %>

  <%# 시간표 — /timetable/4 그대로 임베드 %>
  <%= turbo_frame_tag "timetable_embed", src: teacher_timetable_path(4, date: @date.to_s), loading: :lazy do %>
    <div class="card bg-base-100 shadow-sm p-4 text-sm text-base-content/40">시간표 로딩 중...</div>
  <% end %>

</div>

<% if @is_today %>
<script>
  const DAYS_KO = ['일','월','화','수','목','금','토'];
  function updateTime() {
    const now = new Date();
    const hh  = String(now.getHours()).padStart(2,'0');
    const mm  = String(now.getMinutes()).padStart(2,'0');
    const ss  = String(now.getSeconds()).padStart(2,'0');
    const el  = document.getElementById('dashboard-time');
    if (el) el.textContent = `${hh}:${mm}:${ss} (${DAYS_KO[now.getDay()]}요일) · 현재 시간대: ${now.getHours()}:00`;
  }
  updateTime();
  setInterval(updateTime, 1000);
</script>
<% end %>
