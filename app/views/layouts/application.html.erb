<!DOCTYPE html>
<html lang="ko" data-theme="light" id="html-root" class="h-full">
  <head>
    <title><%= content_for(:title) || "모네뮤직 카운터" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <script>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if authenticated? %>

      <!-- DaisyUI Drawer 레이아웃 -->
      <div class="drawer lg:drawer-open h-full">
        <input id="drawer-toggle" type="checkbox" class="drawer-toggle" />

        <!-- 메인 콘텐츠 영역 -->
        <div class="drawer-content flex flex-col h-full">

          <!-- 상단 Navbar -->
          <div class="navbar bg-base-100 border-b border-base-200 shrink-0 z-10 shadow-sm">
            <div class="flex-none lg:hidden">
              <label for="drawer-toggle" class="btn btn-square btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </label>
            </div>
            <div class="flex-1">
              <span class="text-sm font-semibold text-base-content/70">
                <%= content_for(:title) || "모네뮤직 카운터" %>
              </span>
            </div>
            <div class="flex-none gap-2">
              <!-- 다크모드 토글 -->
              <label class="swap swap-rotate btn btn-ghost btn-circle">
                <input type="checkbox" id="theme-toggle" onchange="toggleTheme(this)" />
                <!-- 해 아이콘 (라이트) -->
                <svg class="swap-off fill-current w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
                </svg>
                <!-- 달 아이콘 (다크) -->
                <svg class="swap-on fill-current w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
                </svg>
              </label>
            </div>
          </div>

          <!-- Flash 메시지 (DaisyUI Toast) -->
          <% if notice.present? %>
            <div id="flash-toast" class="toast toast-top toast-end z-50">
              <div class="alert alert-success shadow-md">
                <span class="text-sm"><%= notice %></span>
                <button onclick="this.closest('#flash-toast').remove()" class="btn btn-xs btn-ghost">✕</button>
              </div>
            </div>
            <script>setTimeout(() => document.getElementById('flash-toast')?.remove(), 4000)</script>
          <% end %>
          <% if alert.present? %>
            <div id="flash-toast-alert" class="toast toast-top toast-end z-50">
              <div class="alert alert-error shadow-md">
                <span class="text-sm"><%= alert %></span>
                <button onclick="this.closest('#flash-toast-alert').remove()" class="btn btn-xs btn-ghost">✕</button>
              </div>
            </div>
            <script>setTimeout(() => document.getElementById('flash-toast-alert')?.remove(), 6000)</script>
          <% end %>

          <!-- 메인 콘텐츠 -->
          <main class="flex-1 overflow-auto p-6 bg-base-200">
            <%= yield %>
          </main>
        </div>

        <!-- 사이드바 -->
        <div class="drawer-side z-20">
          <label for="drawer-toggle" class="drawer-overlay"></label>
          <aside class="bg-base-100 border-r border-base-200 w-48 min-h-full flex flex-col">
            <div class="px-4 py-4 border-b border-base-200">
              <h1 class="text-sm font-bold">🎵 모네뮤직</h1>
            </div>
            <ul class="menu menu-sm flex-1 px-2 py-3 gap-0.5">
              <li><%= link_to "대시보드",  root_path,        class: nav_link_class(root_path) %></li>
              <li><%= link_to "수강생",    students_path,    class: nav_link_class(students_path) %></li>
              <li><%= link_to "결제",      payments_path,    class: nav_link_class(payments_path) %></li>
              <li><%= link_to "출결 관리", schedules_path,   class: nav_link_class(schedules_path) %></li>
              <li><%= link_to "시간표",    timetable_path,   class: nav_link_class(timetable_path) %></li>
              <li><%= link_to "패스 시트", pass_sheet_path, class: nav_link_class(pass_sheet_path) %></li>
              <li><%= link_to "통계/마감", statistics_path,  class: nav_link_class(statistics_path) %></li>
              <li><%= link_to "가격표",    price_plans_path, class: nav_link_class(price_plans_path) %></li>
              <li><%= link_to "선생님",   teachers_path,    class: nav_link_class(teachers_path) %></li>
              <% if Current.user&.admin? %>
                <% pending_count = User.where(approved: false).count %>
                <li>
                  <%= link_to approvals_path, class: nav_link_class(approvals_path) do %>
                    가입승인<% if pending_count > 0 %>&nbsp;<span class="badge badge-error badge-xs"><%= pending_count %></span><% end %>
                  <% end %>
                </li>
              <% end %>
              <li class="divider my-1"></li>
              <li><%= link_to "키패드 ↗",  keypad_path, target: "_blank", class: "text-base-content/60" %></li>
            </ul>
            <div class="px-3 py-3 border-t border-base-200">
              <%= button_to "로그아웃", session_path, method: :delete, class: "btn btn-ghost btn-xs w-full justify-start text-base-content/50" %>
            </div>
          </aside>
        </div>
      </div>

    <% else %>
      <!-- 로그인 화면 -->
      <main class="flex items-center justify-center min-h-screen bg-base-200">
        <%= yield %>
      </main>
    <% end %>

    <script>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        const toggle = document.getElementById('theme-toggle');
        if (toggle) toggle.checked = (theme === 'dark');
      })();
      function toggleTheme(el) {
        const theme = el.checked ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      }
    </script>
  </body>
</html>
