<% content_for :title, "#{@teacher.name} 시간표" %>

<%= turbo_frame_tag "timetable_embed" do %>
<div class="flex items-center justify-between mb-3">
  <h2 class="text-lg font-bold"><%= @teacher.name %> 시간표</h2>
  <div class="flex items-center gap-2 text-sm">
    <%= link_to "← 이전주", teacher_timetable_path(@teacher.id, date: (@week_start - 7.days).to_s), class: "btn btn-xs btn-ghost" %>
    <span class="font-medium"><%= @week_start.strftime("%Y.%m.%d") %> ~ <%= (@week_start + 6.days).strftime("%m.%d") %></span>
    <%= link_to "다음주 →", teacher_timetable_path(@teacher.id, date: (@week_start + 7.days).to_s), class: "btn btn-xs btn-ghost" %>
  </div>
</div>

<%# 선생님 탭 %>
<div class="tabs tabs-box mb-4 overflow-x-auto flex-nowrap">
  <% @teachers.each do |t| %>
    <%= link_to t.name, teacher_timetable_path(t.id, date: @date.to_s),
          class: "tab #{t.id == @teacher.id ? 'tab-active' : ''} shrink-0" %>
  <% end %>
</div>

<%# 시간표 테이블 %>
<style>
  .timetable-table tbody tr { border-bottom: 1px solid rgba(0,0,0,0.2); }
  .timetable-table thead tr { border-bottom: 2px solid rgba(0,0,0,0.4); }
  [data-theme="dark"] .timetable-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.2); }
  [data-theme="dark"] .timetable-table thead tr { border-bottom: 2px solid rgba(255,255,255,0.4); }
</style>
<div class="card bg-base-100 shadow-sm overflow-x-auto">
  <table class="table table-sm w-full timetable-table">
    <thead>
      <tr>
        <th class="w-16">시간</th>
        <% @week_days.each do |d| %>
          <th class="text-center min-w-[130px] <%= d == Date.today ? 'bg-primary/10' : '' %>">
            <%= d.strftime("%m/%d") %>
            (<%= %w[월 화 수 목 금 토 일][(d.wday + 6) % 7] %>)
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% start_hour = @week_days.include?(Date.today) && Date.today.monday? ? 14 : 13 %>
      <% end_hour = @teacher.max_lesson_hour || 21 %>
      <% (start_hour..end_hour).each do |hour| %>
        <% is_break = (hour == 18) %>
        <%# 해당 시간대 전체 선생님 기준 차량 총합 (주차공간 공유) %>
        <% weekly_car_total = @week_days.sum do |wd|
             r = @all_schedule_data[:regular].select { |s| s.lesson_date == wd && s.lesson_time.hour == hour }
             m = @all_schedule_data[:makeups].select  { |s| s.makeup_date == wd && s.makeup_time&.hour == hour }
             (r + m).count { |s| s.student.has_car? }
           end %>
        <tr class="<%= is_break ? 'opacity-40' : 'hover' %>">
          <td class="font-mono text-xs text-base-content/50 text-center py-3">
            <%= sprintf("%02d:00", hour) %>
            <% if is_break %>
              <div class="text-xs">브레이크</div>
            <% elsif weekly_car_total > 0 %>
              <div class="mt-0.5">🚗 <%= weekly_car_total %>대</div>
            <% end %>
          </td>
          <% @week_days.each do |d| %>
            <% is_breaktime_open = @breaktime_openings.include?(d) %>
            <% regular = @schedule_data[:regular].select { |s| s.lesson_date == d && s.lesson_time.hour == hour } %>
            <% makeups = @schedule_data[:makeups].select { |s| s.makeup_date == d && s.makeup_time&.hour == hour } %>
            <% slot_total = regular.count { |s| s.status.in?(%w[scheduled attended late]) } + makeups.count %>
            <% is_full = slot_total >= 3 %>
            <td class="align-top py-3 text-center
              <%= d == Date.today ? 'bg-primary/5' : '' %>
              <%= is_break && !is_breaktime_open ? 'bg-base-200' : '' %>
              <%= is_full && !(is_break && !is_breaktime_open) ? 'bg-success/15' : '' %>">
              <% if is_break && !is_breaktime_open %>
                <span class="text-xs text-base-content/30">-</span>
              <% else %>
                <div class="flex flex-col items-center gap-0.5">
                  <% regular.each do |s| %>
                    <% is_pass = s.status.in?(%w[pass emergency_pass holiday]) %>
                    <% badge_data = {
                         "data-sid"           => s.id,
                         "data-student"       => s.student.name,
                         "data-teacher"       => s.teacher.name,
                         "data-day"           => lesson_day_ko(s.enrollment.lesson_day),
                         "data-time"          => s.lesson_time.strftime("%H:%M"),
                         "data-status"        => s.status,
                         "data-makeup-teacher"=> s.makeup_teacher&.name,
                         "data-makeup-date"   => s.makeup_date&.strftime("%m/%d(%a)")&.gsub("Mon","월")&.gsub("Tue","화")&.gsub("Wed","수")&.gsub("Thu","목")&.gsub("Fri","금")&.gsub("Sat","토")&.gsub("Sun","일"),
                         "data-makeup-time"   => s.makeup_time&.strftime("%H:%M"),
                         "onclick"            => "showTimetablePopup(this)"
                       } %>
                    <% if s.status == "makeup_scheduled" %>
                      <div class="badge badge-sm badge-ghost badge-outline w-full h-auto py-0.5 whitespace-normal justify-center opacity-50 cursor-pointer" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>(→<%= s.makeup_teacher&.name %>)
                      </div>
                    <% elsif is_pass %>
                      <div class="badge badge-sm badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer opacity-50" style="color:#9ca3af;border-color:#9ca3af;" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% else %>
                      <div class="badge badge-sm badge-info badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% end %>
                  <% end %>
                  <% makeups.each do |s| %>
                    <% badge_data = {
                         "data-sid"           => s.id,
                         "data-student"       => s.student.name,
                         "data-teacher"       => s.teacher.name,
                         "data-day"           => lesson_day_ko(s.enrollment.lesson_day),
                         "data-time"          => s.lesson_time.strftime("%H:%M"),
                         "data-status"        => s.status,
                         "data-makeup-teacher"=> s.makeup_teacher&.name,
                         "data-makeup-date"   => s.makeup_date&.strftime("%m/%d(%a)")&.gsub("Mon","월")&.gsub("Tue","화")&.gsub("Wed","수")&.gsub("Thu","목")&.gsub("Fri","금")&.gsub("Sat","토")&.gsub("Sun","일"),
                         "data-makeup-time"   => s.makeup_time&.strftime("%H:%M"),
                         "onclick"            => "showTimetablePopup(this)"
                       } %>
                    <div class="badge badge-sm badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer" style="color:rgb(147,51,234);border-color:rgb(147,51,234);" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                      <%= timetable_makeup_label(s, @teacher) %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# 시간표 메모란 (자리 대기, 일정 변경 대기) %>
<div class="card bg-base-100 shadow-sm p-4 mt-4">
  <div class="flex items-center gap-2 mb-2">
    <h3 class="font-semibold text-sm">메모란</h3>
    <span class="text-xs text-base-content/40">자리 대기 / 일정 변경 대기</span>
  </div>
  <textarea id="timetable-memo-<%= @teacher.id %>"
            class="textarea textarea-bordered w-full text-sm"
            rows="3"
            placeholder="자리 대기, 일정 변경 대기 등 메모..."
            onchange="saveMemo('<%= @teacher.id %>', this.value)"></textarea>
</div>

<%# 범례 %>
<div class="flex flex-wrap gap-2 mt-3 text-xs text-base-content/60">
  <span class="badge badge-sm badge-info badge-outline">정규</span>
  <span class="badge badge-sm badge-success badge-outline">FULL(3명)</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(147,51,234);border-color:rgb(147,51,234);">보강</span>
  <span class="badge badge-sm badge-success/20 border border-success/30">■ 3명 만석</span>
  <span>★ 차량 | (첫) 첫수업 | (복) 복귀 | (패) 패스 | (휴) 휴원 | (보) 보강 | (대기) 등록대기</span>
</div>

<%# 수업 정보 팝업 모달 %>
<dialog id="timetable-popup" class="modal">
  <div class="modal-box max-w-xs p-5">
    <h3 class="font-bold text-base mb-3" id="tt-popup-student"></h3>
    <div class="text-sm space-y-1" id="tt-popup-body"></div>
    <div class="modal-action mt-4">
      <form method="dialog"><button class="btn btn-sm btn-ghost">닫기</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  // 메모 localStorage 저장
  (function() {
    const key = 'timetable-memo-<%= @teacher.id %>';
    const el  = document.getElementById('timetable-memo-<%= @teacher.id %>');
    if (el) el.value = localStorage.getItem(key) || '';
  })();
  window.saveMemo = function(teacherId, val) {
    localStorage.setItem('timetable-memo-' + teacherId, val);
  };

  (function() {
  const STATUS_KO = {
    scheduled: '예정', attended: '출석', late: '지각', deducted: '차감',
    pass: '패스', emergency_pass: '긴급패스', holiday: '공휴일패스',
    makeup_scheduled: '보강예정', makeup_done: '보강완료'
  };

  window.showTimetablePopup = function(el) {
    const student      = el.dataset.student;
    const teacher      = el.dataset.teacher;
    const day          = el.dataset.day;
    const time         = el.dataset.time;
    const status       = el.dataset.status;
    const mkTeacher    = el.dataset.makeupTeacher;
    const mkDate       = el.dataset.makeupDate;
    const mkTime       = el.dataset.makeupTime;

    document.getElementById('tt-popup-student').textContent = student;

    let html = '';
    const statusLabel = STATUS_KO[status] || status;
    html += `<div class="flex items-center gap-2">`;
    html += `<span class="text-base-content/50 w-12 shrink-0">원수업</span>`;
    html += `<span>${teacher} ${day}요일 ${time}</span>`;
    html += `</div>`;

    if (mkTeacher && mkDate) {
      html += `<div class="flex items-center gap-2 mt-1">`;
      html += `<span class="text-base-content/50 w-12 shrink-0">보강</span>`;
      html += `<span class="text-purple-500">${mkTeacher} ${mkDate} ${mkTime || ''}</span>`;
      html += `</div>`;
    }

    html += `<div class="flex items-center gap-2 mt-2">`;
    html += `<span class="text-base-content/50 w-12 shrink-0">상태</span>`;
    html += `<span class="badge badge-xs">${statusLabel}</span>`;
    html += `</div>`;

    document.getElementById('tt-popup-body').innerHTML = html;
    document.getElementById('timetable-popup').showModal();
  };
  })();
</script>
<% end %>
