<% content_for :title, "결제 등록" %>

<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <h2 class="text-lg font-bold">결제 등록</h2>
  </div>

  <%= form_with model: @payment, class: "space-y-4", id: "payment-form",
        data: { turbo: params[:popup] == "1" ? "false" : "true" } do |f| %>
    <% if params[:popup] == "1" %>
      <input type="hidden" name="popup" value="1">
    <% end %>
    <% if @payment.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
        <% @payment.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
      </div>
    <% end %>

    <div class="bg-base-100 rounded-lg border shadow-sm p-4 space-y-4">
      <% if @enrollment %>
        <%= f.hidden_field :enrollment_id, value: @enrollment.id %>
        <%= f.hidden_field :student_id, value: @enrollment.student_id %>
        <%= f.hidden_field :subject, value: @enrollment.subject %>
        <div class="text-sm text-base-content/80">
          <span class="font-medium"><%= @enrollment.student.name %></span> — <%= @enrollment.subject %> / <%= @enrollment.teacher.name %>
        </div>
        <% if @enrollment.student.referral_discount_pending > 0 %>
          <div class="text-sm text-success bg-success/10 rounded px-3 py-2">
            친구 추천 할인 5만원이 이 결제에 자동 적용됩니다.
          </div>
        <% end %>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :payment_type, "결제 유형", class: "block text-sm font-medium text-base-content mb-1" %>
          <%= f.select :payment_type, [["일반결제","new"],["예약금","deposit"]], {}, class: "select select-bordered w-full text-sm" %>
        </div>
        <div>
          <%= f.label :payment_method, "결제 수단", class: "block text-sm font-medium text-base-content mb-1" %>
          <%= f.select :payment_method, [["카드","card"],["이체","transfer"],["현금","cash"]], {}, class: "select select-bordered w-full text-sm" %>
        </div>
        <div>
          <%= f.label :months, "개월 수", class: "block text-sm font-medium text-base-content mb-1" %>
          <%= f.select :months, [["1개월",1],["3개월",3],["4개월",4]], { prompt: "선택" }, class: "select select-bordered w-full text-sm", id: "payment_months" %>
        </div>
        <div>
          <%= f.label :total_lessons, "총 수업 횟수", class: "block text-sm font-medium text-base-content mb-1" %>
          <%= f.number_field :total_lessons, class: "input input-bordered w-full text-sm" %>
        </div>
        <div>
          <%= f.label :amount, "결제 금액", class: "block text-sm font-medium text-base-content mb-1" %>
          <div class="relative">
            <%= f.number_field :amount, class: "input input-bordered w-full text-sm", id: "payment_amount" %>
            <span id="price-hint" class="absolute right-2 top-2 text-xs text-blue-500 hidden"></span>
          </div>
        </div>
        <div>
          <%= f.label :starts_at, "수강 시작일", class: "block text-sm font-medium text-base-content mb-1" %>
          <%= f.date_field :starts_at, value: @default_starts_at || Date.today, class: "input input-bordered w-full text-sm" %>
        </div>
      </div>

      <%# 금액 자동 조회용 데이터 %>
      <script>
        (function initPaymentForm() {
          const PRICE_TABLE = {
            <% @price_plans.each do |pp| %>
              "<%= pp.subject %>_<%= pp.months %>": <%= pp.amount %>,
            <% end %>
          };
          const ENROLLMENT_SUBJECT   = "<%= @enrollment&.subject %>";
          const MULTI_CLASS_DISCOUNT = <%= @multi_class_discount.to_i %>;
          const REFERRAL_DISCOUNT    = <%= (@enrollment&.student&.referral_discount_pending || 0) * 50_000 %>;

          const monthsEl        = document.getElementById("payment_months");
          const amountEl        = document.getElementById("payment_amount");
          const lessonsEl       = document.getElementById("payment_total_lessons");
          const hintEl          = document.getElementById("price-hint");
          const multiMonthLine  = document.getElementById("multi-month-line");
          const multiMonthMemo  = document.getElementById("multi-month-memo");
          const multiMonthAmt   = document.getElementById("multi-month-amount");
          const totalDiscountEl = document.getElementById("total-discount-amount");

          function formatWon(n) {
            return "-" + n.toLocaleString("ko-KR") + "원";
          }

          function updateDiscountPreview(months) {
            if (!multiMonthLine) return;
            const subject    = ENROLLMENT_SUBJECT || "";
            const singlePrice = PRICE_TABLE[subject + "_1"];
            const multiPrice  = PRICE_TABLE[subject + "_" + months];
            let multiMonthDiscount = 0;

            if (months > 1 && singlePrice && multiPrice) {
              multiMonthDiscount = (singlePrice * months) - multiPrice;
            }

            if (multiMonthDiscount > 0) {
              multiMonthMemo.textContent  = months + "개월 다개월 할인";
              multiMonthAmt.textContent   = formatWon(multiMonthDiscount);
              multiMonthLine.classList.remove("hidden");
            } else {
              multiMonthLine.classList.add("hidden");
            }

            if (totalDiscountEl) {
              const total = MULTI_CLASS_DISCOUNT + multiMonthDiscount;
              totalDiscountEl.textContent = formatWon(total);
            }
          }

          function lookupPrice() {
            const months  = parseInt(monthsEl?.value) || 0;
            const subject = ENROLLMENT_SUBJECT || "";
            if (!months || !subject) return;

            // 총 수업 횟수 자동 입력 (1개월 = 4회)
            if (lessonsEl) lessonsEl.value = months * 4;

            // 금액 자동 입력 (다중수강 + 추천인 할인 적용)
            const price = PRICE_TABLE[subject + "_" + months];
            if (price) {
              const totalDiscount = MULTI_CLASS_DISCOUNT + REFERRAL_DISCOUNT;
              amountEl.value = Math.max(0, price - totalDiscount);
              hintEl.textContent = totalDiscount > 0 ? "자동 입력 (할인 적용)" : "자동 입력";
              hintEl.classList.remove("hidden");
              setTimeout(() => hintEl.classList.add("hidden"), 2000);
            }

            updateDiscountPreview(months);
          }

          monthsEl?.addEventListener("change", lookupPrice);

          // 예약금 입력 시 잔금 자동 계산
          const depositEl  = document.getElementById("payment_deposit_amount");
          const balanceEl  = document.getElementById("payment_balance_amount");

          function recalcBalance() {
            const total   = parseInt(amountEl?.value)  || 0;
            const deposit = parseInt(depositEl?.value) || 0;
            if (balanceEl && total > 0) balanceEl.value = Math.max(0, total - deposit);
          }

          depositEl?.addEventListener("input", recalcBalance);
          amountEl?.addEventListener("input",  recalcBalance);

          // ── 영수증 미리보기 ──────────────────────────────────
          function formatWonPos(n) { return Number(n).toLocaleString("ko-KR") + "원"; }

          function updateReceipt() {
            const receiptBody = document.getElementById("payment-receipt-body");
            if (!receiptBody) return;
            const months  = parseInt(monthsEl?.value) || 0;
            const amount  = parseInt(amountEl?.value) || 0;
            const subject = ENROLLMENT_SUBJECT || "";
            const typeEl  = document.getElementById("payment_payment_type");
            const payType = typeEl?.value || "new";
            const deposit = parseInt(depositEl?.value) || 0;
            if (!months || !amount || !subject) {
              receiptBody.innerHTML = '<p class="text-xs text-base-content/40">개월 수와 금액을 입력하면 자동으로 표시됩니다.</p>';
              return;
            }
            const singlePrice    = PRICE_TABLE[subject + "_1"] || 0;
            const multiPrice     = PRICE_TABLE[subject + "_" + months] || 0;
            const listPrice      = multiPrice || (singlePrice * months);
            const multiMonthDisc  = (months > 1 && singlePrice && multiPrice) ? (singlePrice * months - multiPrice) : 0;
            const multiClassDisc  = MULTI_CLASS_DISCOUNT || 0;
            const referralDisc    = REFERRAL_DISCOUNT || 0;
            const totalDisc       = multiMonthDisc + multiClassDisc + referralDisc;
            const balance        = payType === "deposit" ? Math.max(0, amount - deposit) : 0;

            let rows = "";
            rows += `<tr><td class="py-1 text-xs text-base-content/60">정가 (${months}개월)</td><td class="py-1 text-xs text-right">${formatWonPos(listPrice)}</td></tr>`;
            if (multiMonthDisc > 0)  rows += `<tr><td class="py-0.5 pl-3 text-xs text-primary">${months}개월 할인</td><td class="py-0.5 text-xs text-primary text-right">-${formatWonPos(multiMonthDisc)}</td></tr>`;
            if (multiClassDisc > 0)  rows += `<tr><td class="py-0.5 pl-3 text-xs text-secondary">다중수강 할인</td><td class="py-0.5 text-xs text-secondary text-right">-${formatWonPos(multiClassDisc)}</td></tr>`;
            if (referralDisc > 0)    rows += `<tr><td class="py-0.5 pl-3 text-xs text-success">친구 추천 할인</td><td class="py-0.5 text-xs text-success text-right">-${formatWonPos(referralDisc)}</td></tr>`;
            if (totalDisc > 0)       rows += `<tr class="border-t border-base-200"><td class="py-1 text-xs font-semibold">결제 금액</td><td class="py-1 text-xs font-semibold text-right">${formatWonPos(amount)}</td></tr>`;
            else                     rows += `<tr class="border-t border-base-200"><td class="py-1 text-xs font-semibold">결제 금액</td><td class="py-1 text-xs font-semibold text-right">${formatWonPos(amount)}</td></tr>`;
            if (payType === "deposit") {
              rows += `<tr><td class="py-0.5 pl-3 text-xs text-base-content/60">예약금</td><td class="py-0.5 text-xs text-right">${formatWonPos(deposit)}</td></tr>`;
              rows += `<tr><td class="py-0.5 pl-3 text-xs text-warning">잔금</td><td class="py-0.5 text-xs text-warning text-right">${formatWonPos(balance)}</td></tr>`;
            }

            receiptBody.innerHTML = `
              <div class="text-xs text-base-content/60 mb-2">${subject} ${months}개월</div>
              <table class="w-full"><tbody>${rows}</tbody></table>`;
          }

          monthsEl?.addEventListener("change", updateReceipt);
          amountEl?.addEventListener("input",  updateReceipt);
          depositEl?.addEventListener("input", updateReceipt);
          document.getElementById("payment_payment_type")?.addEventListener("change", updateReceipt);
          updateReceipt();
        })();
      </script>

      <div class="border-t pt-3 space-y-3">
        <h4 class="text-sm font-medium">예약금 설정 (예약금 결제 시)</h4>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :deposit_amount, "예약금", class: "block text-sm font-medium text-base-content mb-1" %>
            <%= f.number_field :deposit_amount, class: "input input-bordered w-full text-sm" %>
          </div>
          <div>
            <%= f.label :balance_amount, "잔금", class: "block text-sm font-medium text-base-content mb-1" %>
            <%= f.number_field :balance_amount, class: "input input-bordered w-full text-sm" %>
          </div>
        </div>
        <label class="flex items-center gap-2 text-sm">
          <%= f.check_box :fully_paid %> 완납
        </label>
        <label class="flex items-center gap-2 text-sm">
          <%= f.check_box :before_lesson %> 수업 전 결제
        </label>
      </div>
    </div>

    <%# ── 예상 할인 안내 (신규클래스 등록 시에만 표시) ── %>
    <% if @enrollment && !@is_renewal %>
      <div class="bg-base-100 border border-primary/30 rounded-lg p-4 space-y-2" id="discount-preview">
        <h4 class="text-sm font-semibold text-primary">예상 할인 안내</h4>
        <div class="space-y-1 text-sm" id="discount-lines">
          <% if @multi_class_discount.to_i > 0 %>
            <div class="flex justify-between text-primary/80">
              <span><%= @multi_class_memo %></span>
              <span class="font-medium">-<%= number_with_delimiter(@multi_class_discount) %>원</span>
            </div>
          <% end %>
          <div class="flex justify-between text-primary/80 hidden" id="multi-month-line">
            <span id="multi-month-memo">다개월 할인</span>
            <span class="font-medium" id="multi-month-amount"></span>
          </div>
        </div>
        <div class="border-t border-base-300 pt-2 flex justify-between text-sm font-semibold text-base-content">
          <span>합계 할인</span>
          <span id="total-discount-amount">-<%= number_with_delimiter(@multi_class_discount.to_i) %>원</span>
        </div>
        <p class="text-xs text-base-content/50">결제 등록 시 자동 적용됩니다.</p>
      </div>
    <% end %>

    <%# ── 영수증 미리보기 ── %>
    <div class="bg-base-100 border rounded-lg p-4" id="payment-receipt-preview">
      <h4 class="text-sm font-semibold mb-3">영수증 미리보기</h4>
      <div id="payment-receipt-body">
        <p class="text-xs text-base-content/40">개월 수와 금액을 입력하면 자동으로 표시됩니다.</p>
      </div>
    </div>

    <!-- 가격표 참고 -->
    <div class="bg-base-200 rounded-lg border p-3">
      <h4 class="text-xs font-medium text-base-content/70 mb-2">가격표 참고</h4>
      <div class="grid grid-cols-3 gap-2 text-xs text-base-content/80">
        <% @price_plans.each do |pp| %>
          <div><%= pp.subject %> <%= pp.months %>개월: <%= format_amount(pp.amount) %></div>
        <% end %>
      </div>
    </div>

    <div class="flex gap-3">
      <%= f.submit "결제 등록", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "취소", :back, class: "border px-4 py-2 rounded text-sm hover:bg-base-200" %>
    </div>
  <% end %>
</div>

<script>
  document.getElementById("payment-form").addEventListener("submit", function(e) {
    if (!confirm("결제를 등록하시겠습니까?")) {
      e.preventDefault();
      e.stopImmediatePropagation();
    }
  });
</script>
