<% content_for :title, @student.name %>

<%# 헤더 %>
<div class="flex items-center gap-3 mb-4">
  <%= link_to "← 목록", students_path, class: "btn btn-ghost btn-sm" %>
  <h2 class="text-xl font-bold"><%= @student.name %></h2>
  <%= status_badge(@student.status) %>
  <div class="ml-auto flex gap-2">
    <%= link_to "수정", edit_student_path(@student), class: "btn btn-sm btn-ghost" %>
    <button onclick="document.getElementById('delete-confirm-modal').showModal()" class="btn btn-sm btn-ghost text-error">삭제</button>

    <dialog id="delete-confirm-modal" class="modal">
      <div class="modal-box">
        <h3 class="font-bold text-lg text-error">수강생 삭제</h3>
        <p class="py-3 text-sm"><span class="font-semibold"><%= @student.name %></span> 수강생을 삭제합니다.</p>
        <p class="text-sm text-base-content/60">결제 내역, 수업 이력 등 모든 데이터가 함께 삭제되며 복구할 수 없습니다.</p>
        <div class="modal-action">
          <form method="dialog"><button class="btn btn-sm btn-ghost">취소</button></form>
          <%= button_to "삭제 확인", student_path(@student), method: :delete, class: "btn btn-sm btn-error" %>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>
  </div>
</div>

<%# 기본정보 카드 3열 %>
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">기본 정보</h3>
      <table class="table table-xs">
        <tbody>
          <tr><td class="text-base-content/50 w-24">전화번호</td><td><%= @student.phone %></td></tr>
          <tr><td class="text-base-content/50">나이</td><td><%= @student.age %>세</td></tr>
          <tr><td class="text-base-content/50">출결코드</td><td class="font-mono font-bold"><%= @student.attendance_code %></td></tr>
          <tr><td class="text-base-content/50">랭크</td><td><%= @student.rank == "first" ? "1차전직" : "2차전직" %></td></tr>
          <tr><td class="text-base-content/50">자차</td><td><%= @student.has_car? ? "✓ 있음" : "-" %></td></tr>
          <% if @student.first_enrolled_at %><tr><td class="text-base-content/50">첫 등록</td><td><%= @student.first_enrolled_at.strftime("%Y.%m.%d") %></td></tr><% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">상담 정보</h3>
      <div class="space-y-2 text-sm">
        <% if @student.reason_for_joining.present? %>
          <div><p class="text-xs text-base-content/50">찾아온 이유</p><p class="text-xs"><%= @student.reason_for_joining %></p></div>
        <% end %>
        <% if @student.own_problem.present? %>
          <div><p class="text-xs text-base-content/50">본인의 문제점</p><p class="text-xs"><%= @student.own_problem %></p></div>
        <% end %>
        <% if @student.desired_goal.present? %>
          <div><p class="text-xs text-base-content/50">하고 싶은 것</p><p class="text-xs"><%= @student.desired_goal %></p></div>
        <% end %>
        <% if @student.memo.present? %>
          <div><p class="text-xs text-base-content/50">메모</p><p class="text-xs"><%= @student.memo %></p></div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">할인 / 기타</h3>
      <table class="table table-xs">
        <tbody>
          <tr>
            <td class="text-base-content/50">추천인</td>
            <td>
              <% if @student.referrers.any? %>
                <%= @student.referrers.map { |r| link_to r.name, student_path(r), class: "link link-hover" }.join(', ').html_safe %>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
          <tr>
            <td class="text-base-content/50">내 추천 학생</td>
            <td>
              <% if @student.referred_students.any? %>
                <%= @student.referred_students.map { |s| link_to s.name, student_path(s), class: "link link-hover" }.join(', ').html_safe %>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
          <% referral_discounts = Discount.joins(:payment).where(payments: { student_id: @student.id }, discount_type: 'referral').order(:created_at) %>
          <% pending_count = @student.referral_discount_pending %>
          <tr>
            <td class="text-base-content/50">추천 할인</td>
            <td>
              <% if pending_count == 0 && referral_discounts.none? %>
                <span class="text-base-content/30">-</span>
              <% else %>
                <% if pending_count > 0 %>
                  <span class="text-warning font-medium">대기 <%= pending_count %>건</span>
                  <span class="text-xs text-base-content/50 ml-1">(-<%= number_with_delimiter(pending_count * 50_000) %>원 예정)</span>
                <% end %>
                <% referral_discounts.each do |d| %>
                  <% separator = (pending_count > 0) ? ' · ' : '' %>
                  <%= separator.html_safe %><span class="text-success">사용됨: -<%= number_with_delimiter(d.amount) %>원</span>
                  <span class="text-xs text-base-content/40 ml-1">(<%= d.payment.enrollment.subject %>, <%= d.created_at.strftime('%Y-%m-%d') %>)</span>
                <% end %>
              <% end %>
            </td>
          </tr>
          <tr><td class="text-base-content/50">동의서</td><td><%= @student.consent_form? ? "✓" : %(<span class="badge badge-xs badge-warning">미수령</span>).html_safe %></td></tr>
          <tr><td class="text-base-content/50">2차전직서</td><td><%= @student.second_transfer_form? ? "✓" : "-" %></td></tr>
          <tr><td class="text-base-content/50">후기 할인</td><td><%= @student.review_discount_applied? ? "적용" : "-" %></td></tr>
          <tr><td class="text-base-content/50">인터뷰</td><td><%= @student.interview_completed? ? "완료" : "-" %></td></tr>
          <tr>
            <td class="text-base-content/50">상품권</td>
            <td>
              <% vouchers = @student.gift_vouchers.order(:issued_at) %>
              <% if vouchers.any? %>
                <div class="space-y-0.5">
                  <% vouchers.each do |v| %>
                    <div class="text-xs">
                      <%= v.enrollment.subject %>
                      <% if v.used? %>
                        <span class="text-base-content/40">(사용됨)</span>
                      <% elsif v.expires_at < Date.today %>
                        <span class="text-error">(만료)</span>
                      <% else %>
                        <span class="text-success">(사용가능)</span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%# 클래스 탭 — 3개 이하: 탭, 4개 이상: 탭+드롭다운 %>
<div class="flex items-center justify-between mb-3">
  <h3 class="text-lg font-bold">수강 클래스</h3>
  <%= link_to "+ 신규 클래스 추가", new_student_enrollment_path(@student), class: "btn btn-sm btn-primary" %>
</div>

<% if @enrollments.empty? %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body items-center py-10">
      <p class="text-base-content/40">등록된 클래스가 없습니다.</p>
      <%= link_to "첫 클래스 등록하기", new_student_enrollment_path(@student), class: "btn btn-primary btn-sm mt-2" %>
    </div>
  </div>
<% else %>
  <%# 탭 목록 — 최대 3개까지 직접 표시, 이후 드롭다운 %>
  <% visible = @enrollments.first(3) %>
  <% overflow = @enrollments.drop(3) %>

  <% target_tab = params[:tab]&.to_i %>
  <div role="tablist" class="tabs tabs-bordered mb-0">
    <% visible.each_with_index do |enrollment, idx| %>
      <input type="radio" name="enrollment-tabs" role="tab" class="tab"
             id="tab-<%= enrollment.id %>"
             aria-label="<%= enrollment.subject %> (<%= status_badge_text(enrollment.status) %>)"
             <%= (target_tab ? target_tab == enrollment.id : idx == 0) ? "checked" : "" %> />
      <div role="tabpanel" class="tab-content">
        <%= render "enrollment_tab", enrollment: enrollment, student: @student %>
      </div>
    <% end %>

    <% if overflow.any? %>
      <%# 드롭다운 탭 %>
      <div class="dropdown dropdown-end ml-auto">
        <label tabindex="0" class="tab">더보기 (<%= overflow.count %>)</label>
        <ul tabindex="0" class="dropdown-content z-10 menu shadow bg-base-100 rounded-box w-40 border">
          <% overflow.each do |enrollment| %>
            <li><a href="#enrollment-<%= enrollment.id %>" onclick="showEnrollmentPanel('<%= enrollment.id %>')">
              <%= enrollment.subject %> — <%= enrollment.teacher.name %>
            </a></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <%# 오버플로우 enrollment 패널 (숨김 상태로 렌더링) %>
  <% overflow.each do |enrollment| %>
    <div id="enrollment-panel-<%= enrollment.id %>" class="hidden">
      <%= render "enrollment_tab", enrollment: enrollment, student: @student %>
    </div>
  <% end %>
<% end %>

<%# 지류상품권 목록 %>
<% if @student.gift_vouchers.any? %>
  <div class="card bg-base-100 shadow-sm p-4 mt-4">
    <h3 class="font-semibold text-sm mb-3">지류상품권</h3>
    <div class="space-y-2">
      <% @student.gift_vouchers.order(:issued_at).each do |v| %>
        <div class="flex items-center gap-3 text-sm border rounded p-2 <%= v.used? ? 'opacity-50' : '' %>">
          <div class="flex-1 space-y-0.5">
            <div class="font-medium"><%= v.enrollment.subject %> 과목 발급</div>
            <div class="text-xs text-base-content/60">
              발급일: <%= v.issued_at.strftime("%Y.%m.%d") %> /
              만료일: <%= v.expires_at.strftime("%Y.%m.%d") %>
              <% if v.used? %>
                / <span class="text-success">사용완료 <%= v.used_at&.strftime("%Y.%m.%d") %> (<%= v.used_class %>)</span>
              <% elsif v.expires_at < Date.today %>
                / <span class="text-error">만료</span>
              <% end %>
            </div>
          </div>
          <% if !v.used? && v.expires_at >= Date.today %>
            <% other_subjects = TeacherSubject::SUBJECTS - [v.enrollment.subject] %>
            <% if other_subjects.any? %>
              <form action="<%= use_gift_voucher_path(v) %>" method="post"
                    onsubmit="return confirm('상품권을 사용 처리하시겠습니까?')">
                <input type="hidden" name="_method" value="patch">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                <select name="used_class" class="select select-bordered select-xs mr-1" required>
                  <option value="">과목 선택</option>
                  <% other_subjects.each do |subj| %>
                    <option value="<%= subj %>"><%= subj %></option>
                  <% end %>
                </select>
                <button type="submit" class="btn btn-xs btn-success">사용처리</button>
              </form>
            <% else %>
              <span class="text-xs text-base-content/40">사용 가능 과목 없음</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# 메모 %>
<div class="card bg-base-100 shadow-sm p-4 mt-4">
  <div class="flex items-center justify-between mb-2">
    <h3 class="font-semibold text-sm">메모</h3>
    <button type="button" onclick="toggleMemoEdit()" id="memo-edit-btn" class="btn btn-xs btn-ghost">수정</button>
  </div>

  <div id="memo-view">
    <% if @student.memo.present? %>
      <p class="text-sm whitespace-pre-wrap"><%= @student.memo %></p>
    <% else %>
      <p class="text-sm text-base-content/30">메모 없음</p>
    <% end %>
  </div>

  <%= form_with url: update_memo_student_path(@student), method: :patch, id: "memo-form", class: "hidden" do |f| %>
    <%= f.text_area :memo, value: @student.memo, rows: 5,
          class: "textarea textarea-bordered w-full text-sm",
          placeholder: "메모를 입력하세요..." %>
    <div class="flex gap-2 mt-2">
      <%= f.submit "저장", class: "btn btn-sm btn-primary" %>
      <button type="button" onclick="toggleMemoEdit()" class="btn btn-sm btn-ghost">취소</button>
    </div>
  <% end %>
</div>

<script>
function toggleMemoEdit() {
  const view = document.getElementById('memo-view');
  const form = document.getElementById('memo-form');
  const btn  = document.getElementById('memo-edit-btn');
  const editing = form.classList.toggle('hidden');
  view.classList.toggle('hidden');
  btn.textContent = editing ? '수정' : '';
}
</script>

<%# 오버플로우 탭 전환 스크립트 %>
<script>
function showEnrollmentPanel(id) {
  document.querySelectorAll('[id^="enrollment-panel-"]').forEach(el => el.classList.add('hidden'));
  document.getElementById('enrollment-panel-' + id)?.classList.remove('hidden');
}
</script>

<%# 복귀 처리 스크립트 %>
<script>
async function handleReturn(event, studentId, currentCode) {
  event.preventDefault();
  try {
    const res  = await fetch(`/students/check_attendance_code?code=${encodeURIComponent(currentCode)}&student_id=${studentId}`);
    const data = await res.json();
    if (!data.available) {
      const newCode = prompt('출결코드 중복입니다. 새 코드를 지정해주세요.', currentCode);
      if (!newCode?.trim()) return false;
      const res2  = await fetch(`/students/check_attendance_code?code=${encodeURIComponent(newCode)}&student_id=${studentId}`);
      const data2 = await res2.json();
      if (!data2.available) { alert(`'${newCode}'도 이미 사용 중입니다.`); return false; }
      const input = document.createElement('input');
      input.type = 'hidden'; input.name = 'new_attendance_code'; input.value = newCode;
      event.target.appendChild(input);
    }
    event.target.submit();
  } catch(e) { event.target.submit(); }
}
</script>
