<% readonly = local_assigns.fetch(:readonly, false) %>
<div id="hourly_arrival">
  <div class="card bg-base-100 shadow-sm h-96">
    <div class="card-body p-4 flex flex-col overflow-hidden">
      <h3 class="card-title text-sm mb-2">시간대별 등하원</h3>

      <%
        teacher_order = Teacher.by_position.pluck(:name).each_with_index.to_h
        effective_hour    = ->(s) { s.status.in?(%w[makeup_scheduled makeup_done]) ? s.makeup_time&.hour.to_i : s.lesson_time.in_time_zone('Seoul').hour }
        effective_teacher = ->(s) { s.status.in?(%w[makeup_scheduled makeup_done]) && s.makeup_teacher ? s.makeup_teacher : s.teacher }
        hourly_groups = schedules
          .group_by { |s| effective_hour.call(s) }
          .sort
          .map { |hour, hour_schedules|
            by_teacher = hour_schedules
              .group_by { |s| effective_teacher.call(s) }
              .sort_by { |t, _| teacher_order.fetch(t.name, 999) }
            [hour, by_teacher]
          }
      %>

      <% if hourly_groups.empty? %>
        <p class="text-sm text-base-content/40">수업이 없습니다.</p>
      <% else %>
        <div class="flex flex-col gap-3 overflow-y-auto flex-1 min-h-0">
          <% hourly_groups.each do |hour, by_teacher| %>
            <div>
              <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
              <% by_teacher.each do |teacher, hour_schedules| %>
                <p class="text-xs text-base-content/40 mt-1">[<%= teacher.name %>]</p>
                <div class="flex flex-col gap-1">
                <% hour_schedules.each do |s| %>
                  <div class="flex items-center gap-2 text-xs">
                    <%= link_to student_path(s.student, tab: s.enrollment_id), class: "font-medium w-14 truncate hover:underline", data: { turbo_frame: "_top" } do %><%= s.student.name %><% if s.trial? %><span class="text-accent text-xs">(체험)</span><% end %><% end %>

                    <%# 등원 %>
                    <% if s.attendance&.checked_in_at %>
                      <span class="text-success w-12"><%= s.attendance.checked_in_at.in_time_zone('Seoul').strftime("%H:%M") %> ✓</span>
                    <% elsif s.status.in?(%w[scheduled makeup_scheduled]) && !readonly %>
                      <%= button_to "등원", attend_schedule_path(s),
                            method: :patch,
                            class: "btn btn-xs btn-outline btn-success w-12",
                            form: { data: { turbo_stream: true } } %>
                    <% elsif s.status.in?(%w[attended late makeup_done]) %>
                      <span class="text-success w-12">✓</span>
                    <% else %>
                      <span class="w-12 text-base-content/30">-</span>
                    <% end %>

                    <%# 하원 %>
                    <% if s.attendance&.checked_out_at %>
                      <span class="text-info w-12"><%= s.attendance.checked_out_at.in_time_zone('Seoul').strftime("%H:%M") %> ✓</span>
                    <% elsif s.attendance&.checked_in_at && !readonly %>
                      <%= button_to "하원", checkout_schedule_path(s),
                            method: :patch,
                            class: "btn btn-xs btn-outline btn-info w-12",
                            form: { data: { turbo_stream: true } } %>
                    <% else %>
                      <span class="w-12 text-base-content/20">-</span>
                    <% end %>

                    <%# 지류상품권 — 등원 여부 무관, 해당자 항상 표시 %>
                    <% if !readonly && s.enrollment.review_gift_eligible? && !GiftVoucher.where(enrollment: s.enrollment).exists? %>
                      <%= button_to "🎁 지류상품권", gift_vouchers_path(enrollment_id: s.enrollment.id),
                            method: :post,
                            class: "btn btn-xs btn-warning",
                            data: { turbo_confirm: "#{s.student.name} 지류상품권을 발급하시겠습니까?" },
                            form: { data: { turbo_stream: true } } %>
                    <% end %>

                    <%# 당취 — scheduled/makeup_scheduled 상태면 항상 표시 (체험 수업은 당취 없음) %>
                    <% if s.status.in?(%w[scheduled makeup_scheduled]) && !readonly && !s.trial? %>
                      <button type="button"
                              class="btn btn-xs btn-outline btn-error"
                              onclick="openDangchwiModal(<%= s.id %>, '<%= j s.student.name %>', '<%= j s.subject %>', '<%= s.status %>')">당취</button>
                    <% end %>
                  </div>
                <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
