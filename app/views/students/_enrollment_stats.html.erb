<div id="enrollment-stats-<%= enrollment.id %>" class="stats stats-horizontal shadow-none border border-base-200 rounded-lg mb-4 w-full">
  <div class="stat py-2 px-3">
    <div class="stat-title text-xs">총출석</div>
    <div class="stat-value text-lg"><%= student.total_attended_weeks_for(enrollment) %><span class="text-sm font-normal">회</span></div>
  </div>
  <div class="stat py-2 px-3 cursor-pointer"
       data-stat="gift_voucher_eligible"
       data-enrollment-id="<%= enrollment.id %>"
       data-update-url="<%= update_stat_enrollment_path(enrollment) %>"
       title="더블클릭하여 수정"
       ondblclick="openStatEdit(this)">
    <div class="stat-title text-xs">휴원안한주차</div>
    <div class="stat-value text-lg <%= GiftVoucher.where(enrollment: enrollment).exists? ? 'text-success' : '' %>">
      <span class="stat-display"><%= student.review_weeks_for(enrollment) %><span class="text-sm font-normal">주</span></span>
    </div>
  </div>
  <div class="stat py-2 px-3 cursor-pointer"
       data-stat="consecutive_weeks"
       data-enrollment-id="<%= enrollment.id %>"
       data-update-url="<%= update_stat_enrollment_path(enrollment) %>"
       title="더블클릭하여 수정"
       ondblclick="openStatEdit(this)">
    <div class="stat-title text-xs flex items-center gap-1">
      연속개근
      <% if enrollment.last_attendance_event_at %>
        <span class="badge badge-xs badge-success"><%= enrollment.last_attendance_event_at.strftime("%-m/%-d") %></span>
      <% end %>
    </div>
    <div class="stat-value text-lg">
      <span class="stat-display"><%= student.consecutive_weeks_for(enrollment) %><span class="text-sm font-normal">주</span></span>
    </div>
  </div>
  <div class="stat py-2 px-3">
    <div class="stat-title text-xs">잔여수업</div>
    <div class="stat-value text-lg"><%= student.remaining_lessons_for(enrollment) %><span class="text-sm font-normal">회</span></div>
  </div>
  <div class="stat py-2 px-3 cursor-pointer"
       data-stat="pass"
       data-enrollment-id="<%= enrollment.id %>"
       data-update-url="<%= update_stat_enrollment_path(enrollment) %>"
       title="더블클릭하여 수정"
       ondblclick="openStatEdit(this)">
    <div class="stat-title text-xs">잔여패스</div>
    <div class="stat-value text-lg <%= student.available_passes_for(enrollment) <= 0 ? 'text-error' : '' %>">
      <span class="stat-display"><%= student.available_passes_for(enrollment) %><span class="text-sm font-normal">회</span></span>
    </div>
  </div>
</div>

<%# 마일스톤 배지 %>
<% review_weeks = student.review_weeks_for(enrollment) %>
<% has_gift_voucher = GiftVoucher.where(enrollment: enrollment).exists? %>
<% show_cafe    = review_weeks >= 12 %>
<% show_video   = review_weeks >= 24 %>
<% show_gift    = enrollment.review_gift_eligible? && !has_gift_voucher %>

<% if show_cafe || show_video || show_gift %>
  <div class="flex flex-wrap gap-2 mb-3">
    <% if show_cafe %>
      <span class="badge badge-warning gap-1">☕ 카페후기 할인 가능</span>
    <% end %>
    <% if show_video %>
      <span class="badge badge-info gap-1">🎬 영상후기 할인 가능</span>
    <% end %>
    <% if show_gift %>
      <span class="badge badge-success gap-1">🎁 지류가능</span>
    <% end %>
  </div>
<% end %>
