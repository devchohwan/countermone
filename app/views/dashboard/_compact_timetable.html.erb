<%# 시간별 → 선생님별 compact 시간표 %>
<% by_hour   = @today_schedules.group_by { |s| s.lesson_time.hour } %>
<% makeup_by = @today_makeups.group_by   { |s| (s.makeup_time || s.lesson_time).hour } %>
<% all_hours = (by_hour.keys + makeup_by.keys).uniq.sort %>

<% if all_hours.empty? %>
  <p class="text-sm text-base-content/40">수업 없음</p>
<% else %>
  <div class="space-y-4 text-sm">
    <% all_hours.each do |hour| %>
      <%
        h_sched  = by_hour[hour]   || []
        h_makeup = makeup_by[hour] || []
        tid_set  = (h_sched.map(&:teacher_id) + h_makeup.map(&:makeup_teacher_id)).compact.uniq
        teachers = @teachers_today.select { |t| tid_set.include?(t.id) }
        extra    = tid_set - teachers.map(&:id)
        teachers = teachers + Teacher.where(id: extra).to_a if extra.any?
      %>
      <div class="<%= hour == @current_hour ? 'bg-primary/5 rounded-lg px-2 py-1 -mx-2' : '' %>">
        <div class="font-bold text-base-content/70 border-b border-base-200 pb-0.5 mb-1">
          <%= hour > 12 ? hour - 12 : hour %>
        </div>
        <% teachers.each do |t| %>
          <% ts = h_sched.select  { |s| s.teacher_id == t.id } %>
          <% tm = h_makeup.select { |s| s.makeup_teacher_id == t.id } %>
          <% next if ts.empty? && tm.empty? %>
          <div class="mb-1">
            <div class="text-xs text-base-content/40">[<%= t.name %>]</div>
            <% ts.each do |s| %>
              <div class="flex justify-between items-baseline pl-1">
                <span><%= timetable_label(s) %></span>
                <span class="text-xs text-base-content/30 ml-2 tabular-nums"><%= @remaining_by_enrollment[s.enrollment_id].to_i %></span>
              </div>
            <% end %>
            <% tm.each do |s| %>
              <div class="flex justify-between items-baseline pl-1 text-secondary/70">
                <span><%= timetable_makeup_label(s, t) %></span>
                <span class="text-xs text-secondary/40 ml-2 tabular-nums"><%= @remaining_by_enrollment[s.enrollment_id].to_i %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
