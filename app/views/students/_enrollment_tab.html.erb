<%# enrollment 탭 내용 partial %>
<div class="card bg-base-100 shadow-sm mt-0 rounded-tl-none" id="enrollment-<%= enrollment.id %>">
  <div class="card-body p-4">

    <%# 클래스 헤더 %>
    <div class="flex items-center gap-3 mb-3 pb-3 border-b border-base-200">
      <span class="font-semibold"><%= enrollment.subject %></span>
      <span class="text-base-content/50 text-sm"><%= enrollment.teacher.name %></span>
      <span class="text-base-content/50 text-sm"><%= lesson_day_ko(enrollment.lesson_day) %>요일 <%= enrollment.lesson_time.strftime("%H:%M") %></span>
      <%= status_badge(enrollment.status) %>
      <% if enrollment.minus_lesson_count > 0 %>
        <span class="badge badge-sm badge-error">마이너스 <%= enrollment.minus_lesson_count %>회</span>
      <% end %>
      <div class="ml-auto flex gap-2">
        <%= link_to "상세", enrollment_path(enrollment), class: "btn btn-xs btn-ghost" %>
        <% if enrollment.status == "active" %>
          <%= button_to "휴원", leave_enrollment_path(enrollment), method: :patch, class: "btn btn-xs btn-warning btn-outline" %>
        <% elsif enrollment.status == "leave" %>
          <%= button_to "복귀", return_enrollment_path(enrollment), method: :patch, class: "btn btn-xs btn-success btn-outline" %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6">

      <%# 왼쪽: 현황 + 결제 내역 %>
      <div>
        <%# 현황 통계 %>
        <div class="stats stats-horizontal shadow-none border border-base-200 rounded-lg mb-4 w-full">
          <div class="stat py-2 px-3">
            <div class="stat-title text-xs">잔여</div>
            <div class="stat-value text-lg"><%= student.remaining_lessons_for(enrollment) %><span class="text-sm font-normal">회</span></div>
          </div>
          <div class="stat py-2 px-3">
            <div class="stat-title text-xs">연속개근</div>
            <div class="stat-value text-lg"><%= student.consecutive_weeks_for(enrollment) %><span class="text-sm font-normal">주</span></div>
          </div>
          <div class="stat py-2 px-3">
            <div class="stat-title text-xs">총출석</div>
            <div class="stat-value text-lg"><%= student.total_attended_weeks_for(enrollment) %><span class="text-sm font-normal">회</span></div>
          </div>
          <div class="stat py-2 px-3">
            <div class="stat-title text-xs">잔여패스</div>
            <div class="stat-value text-lg <%= student.available_passes_for(enrollment) <= 0 ? 'text-error' : '' %>">
              <%= student.available_passes_for(enrollment) %><span class="text-sm font-normal">회</span>
            </div>
          </div>
        </div>

        <%# 결제 내역 (최근 1건 기본, 접기/펼치기) %>
        <h4 class="text-sm font-semibold mb-2">결제 내역</h4>
        <% payments = enrollment.payments.order(created_at: :desc) %>
        <% if payments.any? %>
          <% payments.each_with_index do |payment, idx| %>
            <div class="<%= idx > 0 ? 'payment-extra-' + enrollment.id.to_s + ' hidden' : '' %>">
              <div class="text-sm bg-base-200 rounded-lg p-3 mb-2">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium"><%= payment.months %>개월 / <%= payment.total_lessons %>회</span>
                  <span class="font-bold"><%= format_amount(payment.amount) %></span>
                  <span class="badge badge-xs <%= payment.fully_paid? ? 'badge-success' : 'badge-warning' %>">
                    <%= payment.fully_paid? ? "완납" : "예약금" %>
                  </span>
                  <div class="ml-auto flex items-center gap-1">
                    <%= link_to "상세", payment_path(payment), class: "btn btn-xs btn-ghost" %>
                    <div class="dropdown dropdown-end">
                      <label tabindex="0" class="btn btn-xs btn-ghost">⋯</label>
                      <ul tabindex="0" class="dropdown-content z-20 menu shadow bg-base-100 rounded-box text-xs border w-32">
                        <% unless payment.refunded? %>
                          <li>
                            <%= button_to "환불 처리", refund_payment_path(payment), method: :post,
                                  class: "text-error text-left w-full px-3 py-1.5 hover:bg-base-200",
                                  data: { turbo_confirm: "환불 금액: #{format_amount(payment.refund_amount_calculated)}. 환불 처리하시겠습니까?" } %>
                          </li>
                        <% end %>
                        <% unless payment.fully_paid? %>
                          <li>
                            <%= button_to "잔금 납부", pay_balance_payment_path(payment), method: :patch,
                                  class: "text-success text-left w-full px-3 py-1.5 hover:bg-base-200",
                                  data: { turbo_confirm: "잔금 납부 완료 처리하시겠습니까?" } %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  </div>
                </div>
                <div class="text-xs text-base-content/50">
                  <%= payment.starts_at&.strftime("%Y.%m.%d") %>
                  <% if payment.ends_at %> ~ <%= payment.ends_at.strftime("%Y.%m.%d") %><% end %>
                </div>
                <% if payment.discounts.any? %>
                  <div class="text-xs text-secondary mt-1">
                    <%= payment.discounts.map { |d| "#{d.memo}" }.join(" / ") %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if payments.count > 1 %>
            <button onclick="togglePayments('<%= enrollment.id %>')" id="payment-toggle-<%= enrollment.id %>"
                    class="btn btn-xs btn-ghost text-base-content/50 w-full">
              전체보기 (<%= payments.count %>건) ∨
            </button>
          <% end %>
          <% if enrollment.status == "active" %>
            <%= link_to "+ 연장 결제", new_payment_path(enrollment_id: enrollment.id), class: "btn btn-xs btn-outline btn-primary mt-1" %>
          <% end %>
        <% else %>
          <p class="text-sm text-base-content/40">결제 내역 없음</p>
          <%= link_to "+ 결제 등록", new_payment_path(enrollment_id: enrollment.id), class: "btn btn-xs btn-primary mt-1" %>
        <% end %>
      </div>

      <%# 오른쪽: 수업 이력 (필터) %>
      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-sm font-semibold">수업 이력</h4>
          <%# 필터 버튼 %>
          <div class="flex gap-1" id="filter-btns-<%= enrollment.id %>">
            <% [["전체", "all"], ["예정", "scheduled"], ["출석", "attended"], ["보강", "makeup"], ["패스", "pass"]].each do |label, key| %>
              <button onclick="filterSchedules('<%= enrollment.id %>', '<%= key %>')"
                      class="btn btn-xs <%= key == 'all' ? 'btn-neutral' : 'btn-ghost' %>"
                      data-filter="<%= key %>"
                      id="filter-<%= enrollment.id %>-<%= key %>">
                <%= label %>
              </button>
            <% end %>
          </div>
        </div>

        <%# 결제분 단위 청킹 %>
        <% enrollment.payments.order(:starts_at).each do |payment| %>
          <% schedules = payment.schedules.order(:lesson_date) %>
          <% next if schedules.empty? %>
          <div class="payment-chunk-<%= enrollment.id %> mb-3">
            <p class="text-xs text-base-content/40 mb-1">
              <%= payment.starts_at&.strftime("%Y.%m") %> — <%= payment.months %>개월 (<%= schedules.count %>회)
            </p>
            <div class="flex flex-wrap gap-1">
              <% schedules.each do |s| %>
                <%# 필터용 data 속성 %>
                <% filter_key = case s.status
                   when "attended", "late" then "attended"
                   when "makeup_scheduled", "makeup_done" then "makeup"
                   when "pass", "emergency_pass" then "pass"
                   when "scheduled" then "scheduled"
                   else "other"
                   end %>
                <div class="schedule-item-<%= enrollment.id %> badge badge-sm badge-outline cursor-pointer hover:badge-primary"
                     data-filter="<%= filter_key %>"
                     title="<%= s.lesson_date.strftime('%Y.%m.%d') %> <%= schedule_status_ko(s.status) %>"
                     onclick="openScheduleAction('<%= s.id %>', '<%= s.lesson_date.strftime('%m/%d') %>', '<%= s.status %>')">
                  <%= s.lesson_date.strftime("%-m/%-d") %>
                  <span class="<%= case s.status
                    when 'attended', 'makeup_done' then 'text-success'
                    when 'scheduled' then 'text-info'
                    when 'deducted' then 'text-error'
                    when 'pass', 'emergency_pass' then 'text-secondary'
                    else 'text-base-content/40'
                    end %>">●</span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>

<%# 수업 처리 모달 (DaisyUI modal) %>
<dialog id="schedule-modal-<%= enrollment.id %>" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg" id="modal-title-<%= enrollment.id %>">출결 처리</h3>
    <p class="text-sm text-base-content/60 mb-4" id="modal-date-<%= enrollment.id %>"></p>
    <div id="modal-actions-<%= enrollment.id %>" class="space-y-2">
      <%# JS로 채워짐 %>
    </div>
    <div class="modal-action">
      <form method="dialog"><button class="btn btn-sm">닫기</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
(function() {
  // 결제 접기/펼치기
  window.togglePayments = window.togglePayments || function(enrollmentId) {
    const extras = document.querySelectorAll('.payment-extra-' + enrollmentId);
    const btn    = document.getElementById('payment-toggle-' + enrollmentId);
    const hidden = extras[0]?.classList.contains('hidden');
    extras.forEach(el => el.classList.toggle('hidden', !hidden));
    if (btn) btn.textContent = hidden ? '접기 ∧' : `전체보기 (${extras.length + 1}건) ∨`;
  };

  // 수업이력 필터
  window.filterSchedules = window.filterSchedules || function(enrollmentId, filterKey) {
    const items = document.querySelectorAll('.schedule-item-' + enrollmentId);
    items.forEach(el => {
      const match = filterKey === 'all' || el.dataset.filter === filterKey;
      el.style.display = match ? '' : 'none';
    });
    document.querySelectorAll('#filter-btns-' + enrollmentId + ' button').forEach(btn => {
      btn.classList.toggle('btn-neutral', btn.dataset.filter === filterKey);
      btn.classList.toggle('btn-ghost',   btn.dataset.filter !== filterKey);
    });
  };

  // 수업 처리 모달
  window.openScheduleAction = function(scheduleId, dateLabel, status) {
    const el = document.querySelector(`[onclick*="openScheduleAction('${scheduleId}'"]`);
    if (!el) return;
    const classMatch = el.className.match(/schedule-item-(\d+)/);
    if (!classMatch) return;
    const enrollmentId = classMatch[1];
    const modal      = document.getElementById('schedule-modal-' + enrollmentId);
    if (!modal) return;
    const titleEl    = document.getElementById('modal-title-'   + enrollmentId);
    const dateEl     = document.getElementById('modal-date-'    + enrollmentId);
    const actionsEl  = document.getElementById('modal-actions-' + enrollmentId);
    const csrf       = document.querySelector('meta[name="csrf-token"]').content;

    dateEl.textContent = dateLabel;

    function patchForm(url, extra) {
      const f = document.createElement('form');
      f.method = 'POST'; f.action = url;
      f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                     <input type="hidden" name="_method" value="patch">` + (extra || '');
      document.body.appendChild(f);
      f.submit();
    }

    window.showMain    = showMain;
    window.showMakeup  = showMakeup;
    window.showPass    = showPass;
    window.loadTeachers   = loadTeachers;
    window.submitMakeup   = submitMakeup;
    window.submitPass     = submitPass;

    function showMain() {
      titleEl.textContent = '출결 처리';
      let html = '';
      if (status === 'scheduled') {
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/attend','${csrf}')" class="btn btn-sm btn-success w-full">출석</button>`;
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/late','${csrf}')"   class="btn btn-sm btn-warning w-full">지각</button>`;
        html += `<button onclick="showMakeup()" class="btn btn-sm btn-info btn-outline w-full">보강</button>`;
        html += `<button onclick="showPass()"   class="btn btn-sm btn-secondary btn-outline w-full">패스</button>`;
        html += `<button onclick="if(confirm('결석 차감 처리하시겠습니까?')) submitPatch('/schedules/${scheduleId}/deduct','${csrf}')"
                         class="btn btn-sm btn-error btn-outline w-full">결석 차감</button>`;
      } else if (status === 'deducted') {
        html += `<p class="text-xs text-error mb-1">결석 차감 처리됨</p>`;
        html += `<button onclick="submitPatch('/schedules/${scheduleId}/undo_deduct','${csrf}')" class="btn btn-sm btn-warning btn-outline w-full">차감 취소</button>`;
        html += `<a href="/schedules/${scheduleId}" class="btn btn-sm btn-ghost w-full mt-1">수업 상세 보기</a>`;
      } else if (['makeup_scheduled','pass','emergency_pass'].includes(status)) {
        html += `<a href="/schedules/${scheduleId}" class="btn btn-sm btn-primary w-full">수업 상세 / 전환</a>`;
      }
      actionsEl.innerHTML = html;
    }

    function showMakeup() {
      titleEl.textContent = '보강 등록';
      actionsEl.innerHTML = `<p class="text-xs text-base-content/50 py-2">불러오는 중…</p>`;

      fetch(`/schedules/${scheduleId}/makeup_slots`)
        .then(r => r.json())
        .then(data => {
          if (!data.range_min) {
            actionsEl.innerHTML = `
              <p class="text-sm text-error py-2">보강 가능 기간이 없습니다.</p>
              <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>`;
            return;
          }
          actionsEl.innerHTML = `
            <div class="space-y-3">
              <div>
                <label class="text-xs text-base-content/60">보강 날짜
                  <span class="ml-1">(${data.range_min} ~ ${data.range_max})</span>
                </label>
                <input type="date" id="mkdate-${scheduleId}"
                       min="${data.range_min}" max="${data.range_max}"
                       class="input input-bordered input-sm w-full mt-1"
                       onchange="loadTeachers(this.value, '${data.lesson_time}')">
              </div>
              <div id="mkteacher-${scheduleId}" class="hidden space-y-2">
                <label class="text-xs text-base-content/60">선생님</label>
                <select id="mksel-${scheduleId}" class="select select-bordered select-sm w-full"></select>
                <button onclick="submitMakeup('${data.lesson_time}')"
                        class="btn btn-sm btn-primary w-full">보강 등록</button>
              </div>
              <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>
            </div>`;
        });
    }

    function loadTeachers(date, defaultTime) {
      fetch(`/schedules/${scheduleId}/makeup_slots?date=${date}`)
        .then(r => r.json())
        .then(data => {
          const sel = document.getElementById(`mksel-${scheduleId}`);
          sel.innerHTML = data.teachers.map(t => {
            const label = t.available ? `${t.name}  (${t.slots}/3)` : `${t.name} — 마감`;
            return `<option value="${t.id}" ${!t.available ? 'disabled' : ''}>${label}</option>`;
          }).join('');
          document.getElementById(`mkteacher-${scheduleId}`).classList.remove('hidden');
        });
    }

    function submitMakeup(defaultTime) {
      const date     = document.getElementById(`mkdate-${scheduleId}`)?.value;
      const teacherId = document.getElementById(`mksel-${scheduleId}`)?.value;
      if (!date || !teacherId) return;
      patchForm(`/schedules/${scheduleId}/makeup`,
        `<input type="hidden" name="makeup_date" value="${date}">
         <input type="hidden" name="makeup_time" value="${defaultTime}">
         <input type="hidden" name="makeup_teacher_id" value="${teacherId}">`);
    }

    function showPass() {
      titleEl.textContent = '패스 처리';
      actionsEl.innerHTML = `
        <div class="space-y-3">
          <div class="bg-orange-50 border border-orange-200 rounded p-2 text-xs text-orange-700">
            ⚠️ 패스 처리 시 개근 카운트가 리셋됩니다.
          </div>
          <div>
            <label class="text-xs text-base-content/60">패스 사유</label>
            <input type="text" id="passreason-${scheduleId}" placeholder="사유 입력 (선택)"
                   class="input input-bordered input-sm w-full mt-1">
          </div>
          <button onclick="submitPass()" class="btn btn-sm btn-secondary w-full">패스 처리</button>
          <button onclick="showMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>
        </div>`;
    }

    function submitPass() {
      const reason = document.getElementById(`passreason-${scheduleId}`)?.value || '';
      patchForm(`/schedules/${scheduleId}/pass`,
        `<input type="hidden" name="pass_reason" value="${reason}">`);
    }

    showMain();
    modal.showModal();
  };

  window.submitPatch = function(url, csrf) {
    const form = document.createElement('form');
    form.method = 'POST'; form.action = url;
    form.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf}">
                      <input type="hidden" name="_method" value="patch">`;
    document.body.appendChild(form);
    form.submit();
  };
})();
</script>
