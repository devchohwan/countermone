<%
  # 정규 수업: {hour => {teacher_id => [schedule, ...]}}
  regular_by_hour = (schedules || []).group_by { |s| s.lesson_time.in_time_zone('Seoul').hour }

  # 보강 수업: {hour => {makeup_teacher_id => [schedule, ...]}}
  makeup_by_hour  = (makeups || []).group_by { |s| s.makeup_time&.in_time_zone('Seoul')&.hour }.compact

  all_hours = (regular_by_hour.keys + makeup_by_hour.keys).uniq.sort

  # 첫수업 판단: sequence==1인 수업 중 해당 enrollment의 첫 결제인 경우
  seq1_schedules = (schedules || []).select { |s| s.sequence == 1 }
  first_payment_ids = if seq1_schedules.any?
    enroll_ids = seq1_schedules.map(&:enrollment_id).uniq
    Payment.where(enrollment_id: enroll_ids)
           .group(:enrollment_id).minimum(:id)
           .values.to_set
  else
    Set.new
  end
  first_lesson_ids = seq1_schedules.select { |s| first_payment_ids.include?(s.payment_id) }.map(&:id).to_set
%>
<div class="card bg-base-100 shadow-sm">
  <div class="card-body p-4">
    <div class="flex items-center justify-between mb-2">
      <h3 class="card-title text-sm">시간대별 수업</h3>
      <% unless all_hours.empty? %>
        <%
          copy_lines = []
          all_hours.each do |hour|
            copy_lines << "#{hour}시"
            # 정규
            (regular_by_hour[hour] || []).group_by(&:teacher_id).each_value do |ts|
              copy_lines << "[#{ts.first.teacher.name}]"
              ts.each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                tag = first_lesson_ids.include?(s.id) ? "(첫)" : ""
                if s.status.in?(%w[attended late])
                  copy_lines << "#{s.student.name}#{tag} #{remaining + 1}-#{remaining}"
                else
                  copy_lines << "#{s.student.name}#{tag} #{remaining}"
                end
              end
            end
            # 보강
            (makeup_by_hour[hour] || []).group_by(&:makeup_teacher_id).each_value do |ms|
              copy_lines << "[#{ms.first.makeup_teacher.name}]"
              ms.each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                copy_lines << "#{s.student.name}(보/#{s.makeup_teacher.name}) #{remaining}"
              end
            end
            copy_lines << ""
          end
          copy_text = copy_lines.join("\n").strip
        %>
        <button
          class="btn btn-xs btn-ghost"
          data-copy-text="<%= copy_text %>"
          onclick="
            navigator.clipboard.writeText(this.dataset.copyText)
              .then(() => { this.textContent = '✓ 복사됨'; setTimeout(() => this.textContent = '복사', 1500); })
              .catch(() => {});
          ">복사</button>
      <% end %>
    </div>

    <% if all_hours.empty? %>
      <p class="text-sm text-base-content/40">수업이 없습니다.</p>
    <% else %>
      <div class="flex flex-col gap-3 font-mono text-sm leading-snug overflow-y-auto max-h-72">
        <% all_hours.each do |hour| %>
          <div>
            <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
            <%
              reg_groups    = (regular_by_hour[hour] || []).group_by(&:teacher_id)
              makeup_groups = (makeup_by_hour[hour]  || []).group_by(&:makeup_teacher_id)
              first_group   = true
            %>

            <% reg_groups.each_value do |ts| %>
              <% unless first_group %><div class="h-2"></div><% end %>
              <% first_group = false %>
              <p class="text-xs text-base-content/40">[<%= ts.first.teacher.name %>]</p>
              <% ts.each do |s| %>
                <%
                  attended = s.status.in?(%w[attended late])
                  remaining_scheduled = enrollment_remaining[s.enrollment_id] || 0
                  before_count = attended ? remaining_scheduled + 1 : remaining_scheduled
                  after_count  = remaining_scheduled
                  is_first = first_lesson_ids.include?(s.id)
                %>
                <p>
                  <%= s.student.name %><% if is_first %><span class="text-success">(첫)</span><% end %>
                  <% if attended %>
                    <span class="text-base-content/40"><%= before_count %>-<%= after_count %></span>
                  <% else %>
                    <span class="text-base-content/40"><%= before_count %></span>
                  <% end %>
                </p>
              <% end %>
            <% end %>

            <% makeup_groups.each_value do |ms| %>
              <% unless first_group %><div class="h-2"></div><% end %>
              <% first_group = false %>
              <p class="text-xs text-base-content/40">[<%= ms.first.makeup_teacher.name %>]</p>
              <% ms.each do |s| %>
                <%
                  remaining_scheduled = enrollment_remaining[s.enrollment_id] || 0
                  attended = s.status == "makeup_done"
                %>
                <p>
                  <%= s.student.name %><span class="text-purple-500">(보/<%= s.makeup_teacher.name %>)</span>
                  <% if attended %>
                    <span class="text-base-content/40"><%= remaining_scheduled + 1 %>-<%= remaining_scheduled %></span>
                  <% else %>
                    <span class="text-base-content/40"><%= remaining_scheduled %></span>
                  <% end %>
                </p>
              <% end %>
            <% end %>

          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
