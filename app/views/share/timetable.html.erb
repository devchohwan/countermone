<% content_for :title, "#{@teacher.name} 시간표" %>

<%= turbo_stream_from "teacher_timetable_#{@teacher.id}" %>

<style>
  .timetable-table tbody tr { border-bottom: 1px solid rgba(0,0,0,0.15); }
  .timetable-table thead tr { border-bottom: 2px solid rgba(0,0,0,0.3); }
  [data-theme="dark"] .timetable-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.15); }
  [data-theme="dark"] .timetable-table thead tr { border-bottom: 2px solid rgba(255,255,255,0.3); }
</style>

<%# 헤더 %>
<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-bold">🎵 <%= @teacher.name %> 시간표</h1>
  <label class="swap swap-rotate btn btn-ghost btn-sm btn-circle">
    <input type="checkbox" id="theme-toggle" onchange="toggleTheme(this)" />
    <svg class="swap-off fill-current w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
    </svg>
    <svg class="swap-on fill-current w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
    </svg>
  </label>
</div>

<%# 주간 네비게이션 %>
<div class="flex items-center gap-2 mb-3">
  <%= link_to "← 이전주", share_timetable_path(@teacher.id, date: (@week_start - 7.days).to_s),
        class: "btn btn-xs btn-ghost" %>
  <span class="font-medium text-sm">
    <%= @week_start.strftime("%Y.%m.%d") %> ~ <%= (@week_start + 6.days).strftime("%m.%d") %>
  </span>
  <%= link_to "다음주 →", share_timetable_path(@teacher.id, date: (@week_start + 7.days).to_s),
        class: "btn btn-xs btn-ghost" %>
  <% if @date != Date.today %>
    <%= link_to "오늘", share_timetable_path(@teacher.id), class: "btn btn-xs btn-primary" %>
  <% end %>
</div>

<%# 시간표 %>
<div class="card bg-base-100 shadow-sm overflow-x-auto">
  <table class="table table-sm w-full timetable-table">
    <thead>
      <tr>
        <th class="w-14 text-center">시간</th>
        <% @week_days.each do |d| %>
          <th class="text-center min-w-[110px] <%= d == Date.today ? 'bg-primary/10' : '' %>">
            <%= d.strftime("%m/%d") %>
            (<%= %w[월 화 수 목 금 토 일][(d.wday + 6) % 7] %>)
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% start_hour = 13 %>
      <% end_hour = @teacher.max_lesson_hour || 21 %>
      <% monday_max = @teacher.monday_max_lesson_hour || 17 %>
      <% (start_hour..end_hour).each do |hour| %>
        <% is_break = (hour == 18) %>
        <tr class="<%= is_break ? 'opacity-40' : 'hover' %>">
          <td class="font-mono text-xs text-base-content/50 text-center py-3">
            <%= sprintf("%02d:00", hour) %>
            <% if is_break %>
              <div class="text-[10px]">브레이크</div>
            <% end %>
          </td>
          <% @week_days.each do |d| %>
            <% is_monday_restricted = d.wday == 1 && hour > monday_max %>
            <% regular = @schedule_data[:regular].select { |s| s.lesson_date == d && s.lesson_time.hour == hour } %>
            <% makeups = @schedule_data[:makeups].select { |s| s.makeup_date == d && s.makeup_time&.hour == hour } %>
            <td class="align-top py-2 text-center
              <%= d == Date.today ? 'bg-primary/5' : '' %>
              <%= is_break || is_monday_restricted ? 'bg-base-200' : '' %>">
              <% if is_break || is_monday_restricted %>
                <span class="text-xs text-base-content/30">-</span>
              <% else %>
                <div class="flex flex-col items-center gap-0.5">
                  <% regular.each do |s| %>
                    <% is_pass = s.status.in?(%w[pass emergency_pass holiday]) %>
                    <% subj_style = subject_badge_style(s.subject) %>
                    <% badge_data = {
                         "data-sid"           => s.id,
                         "data-student"       => s.student.name,
                         "data-teacher"       => s.teacher.name,
                         "data-day"           => lesson_day_ko(s.enrollment.lesson_day),
                         "data-time"          => s.lesson_time.strftime("%H:%M"),
                         "data-status"        => s.status,
                         "data-makeup-teacher"=> s.makeup_teacher&.name,
                         "data-makeup-date"   => s.makeup_date&.strftime("%m/%d(%a)")&.gsub("Mon","월")&.gsub("Tue","화")&.gsub("Wed","수")&.gsub("Thu","목")&.gsub("Fri","금")&.gsub("Sat","토")&.gsub("Sun","일"),
                         "data-makeup-time"   => s.makeup_time&.strftime("%H:%M"),
                         "onclick"            => "showPopup(this)"
                       } %>
                    <% if s.status == "makeup_scheduled" %>
                      <div class="badge badge-sm badge-ghost badge-outline w-full h-auto py-0.5 whitespace-normal justify-center opacity-50 cursor-pointer" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% elsif is_pass %>
                      <div class="badge badge-sm badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer opacity-50" style="color:#9ca3af;border-color:#9ca3af;" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% elsif subj_style %>
                      <div class="badge badge-sm badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer" style="<%= subj_style %>" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% else %>
                      <div class="badge badge-sm badge-info badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                        <%= timetable_label(s) %>
                      </div>
                    <% end %>
                  <% end %>
                  <% makeups.each do |s| %>
                    <% badge_data = {
                         "data-sid"           => s.id,
                         "data-student"       => s.student.name,
                         "data-teacher"       => s.teacher.name,
                         "data-day"           => lesson_day_ko(s.enrollment.lesson_day),
                         "data-time"          => s.lesson_time.strftime("%H:%M"),
                         "data-status"        => s.status,
                         "data-makeup-teacher"=> s.makeup_teacher&.name,
                         "data-makeup-date"   => s.makeup_date&.strftime("%m/%d(%a)")&.gsub("Mon","월")&.gsub("Tue","화")&.gsub("Wed","수")&.gsub("Thu","목")&.gsub("Fri","금")&.gsub("Sat","토")&.gsub("Sun","일"),
                         "data-makeup-time"   => s.makeup_time&.strftime("%H:%M"),
                         "onclick"            => "showPopup(this)"
                       } %>
                    <div class="badge badge-sm badge-outline w-full h-auto py-0.5 whitespace-normal justify-center cursor-pointer" style="color:rgb(147,51,234);border-color:rgb(147,51,234);" <%= badge_data.map { |k,v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>
                      <%= timetable_makeup_label(s, @teacher) %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# 범례 %>
<div class="flex flex-wrap gap-2 mt-3 text-xs text-base-content/50">
  <span class="badge badge-sm badge-info badge-outline">정규</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(147,51,234);border-color:rgb(147,51,234);">보강</span>
  <span>(첫) 첫수업 · (복) 복귀 · (패) 패스 · (휴) 휴원 · (보) 보강</span>
</div>

<% if @teacher.name == "오또" %>
<div class="flex flex-wrap items-center gap-2 mt-2 text-xs text-base-content/50">
  <span class="font-medium text-base-content/70">과목:</span>
  <span class="badge badge-sm badge-info badge-outline">클린보컬</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(249,115,22);border-color:rgb(249,115,22);">믹싱1차</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(239,68,68);border-color:rgb(239,68,68);">믹싱2차</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(22,163,74);border-color:rgb(22,163,74);">기타</span>
  <span class="badge badge-sm badge-outline" style="color:rgb(59,130,246);border-color:rgb(59,130,246);">작곡</span>
</div>
<% end %>

<%# 팝업 모달 %>
<dialog id="share-popup" class="modal">
  <div class="modal-box max-w-xs p-5">
    <h3 class="font-bold text-base mb-3" id="sp-student"></h3>
    <div class="text-sm space-y-1" id="sp-body"></div>
    <div class="modal-action mt-4">
      <form method="dialog"><button class="btn btn-sm btn-ghost">닫기</button></form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
(function() {
  const STATUS_KO = {
    scheduled: '예정', attended: '출석', late: '지각', deducted: '차감',
    pass: '패스', emergency_pass: '긴급패스', holiday: '공휴일패스',
    makeup_scheduled: '보강예정', makeup_done: '보강완료'
  };

  window.showPopup = function(el) {
    const d = el.dataset;
    document.getElementById('sp-student').textContent = d.student;
    let html = '';
    html += `<div class="flex gap-2"><span class="text-base-content/40 w-12 shrink-0">원수업</span><span>${d.teacher} ${d.day}요일 ${d.time}</span></div>`;
    if (d.makeupTeacher && d.makeupDate) {
      html += `<div class="flex gap-2 mt-1"><span class="text-base-content/40 w-12 shrink-0">보강</span><span class="text-purple-500">${d.makeupTeacher} ${d.makeupDate} ${d.makeupTime || ''}</span></div>`;
    }
    html += `<div class="flex gap-2 mt-2"><span class="text-base-content/40 w-12 shrink-0">상태</span><span class="badge badge-xs">${STATUS_KO[d.status] || d.status}</span></div>`;
    document.getElementById('sp-body').innerHTML = html;
    document.getElementById('share-popup').showModal();
  };

  const theme = localStorage.getItem('theme') || 'light';
  const toggle = document.getElementById('theme-toggle');
  if (toggle) toggle.checked = (theme === 'dark');
})();
</script>
