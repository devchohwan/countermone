<% content_for :title, "수강생 목록" %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-bold">수강생</h2>
  <%= link_to "+ 등록", new_student_path, class: "btn btn-sm btn-primary" %>
</div>

<%# 필터 + 검색 %>
<div class="flex flex-wrap gap-2 mb-4">
  <div class="join">
    <%= link_to "전체", students_path(q: params[:q]),                              class: "join-item btn btn-sm #{params[:status].blank? ? 'btn-neutral' : 'btn-ghost'}" %>
    <%= link_to "재원", students_path(status: "active",  q: params[:q]),          class: "join-item btn btn-sm #{params[:status] == 'active'  ? 'btn-neutral' : 'btn-ghost'}" %>
    <%= link_to "휴원", students_path(status: "leave",   q: params[:q]),          class: "join-item btn btn-sm #{params[:status] == 'leave'   ? 'btn-neutral' : 'btn-ghost'}" %>
    <%= link_to "퇴원", students_path(status: "dropout", q: params[:q]),          class: "join-item btn btn-sm #{params[:status] == 'dropout' ? 'btn-neutral' : 'btn-ghost'}" %>
    <%= link_to "대기", students_path(status: "pending", q: params[:q]),          class: "join-item btn btn-sm #{params[:status] == 'pending' ? 'btn-neutral' : 'btn-ghost'}" %>
  </div>

  <%= form_with url: students_path, method: :get, class: "ml-auto flex gap-2" do |f| %>
    <%= f.hidden_field :status, value: params[:status] %>
    <%= f.text_field :q, value: params[:q], placeholder: "이름/코드 검색", class: "input input-sm input-bordered w-40" %>
    <%= f.submit "검색", class: "btn btn-sm btn-ghost" %>
  <% end %>
</div>

<div class="card bg-base-100 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="table table-sm">
      <thead>
        <tr>
          <th>이름</th>
          <th>상태</th>
          <th>과목/선생님</th>
          <th>출결코드</th>
          <th>전화번호</th>
          <th>등록일</th>
        </tr>
      </thead>
      <tbody>
        <% @students.each do |student| %>
          <tr class="hover">
            <td>
              <%= link_to student.name, student_path(student), class: "font-medium link link-hover" %>
              <% if student.rank == "second" %><span class="badge badge-xs badge-secondary ml-1">2차</span><% end %>
            </td>
            <td><%= status_badge(student.status) %></td>
            <td>
              <% student.enrollments.where(status: "active").each do |e| %>
                <div class="text-xs"><%= e.subject %> / <%= e.teacher.name %></div>
              <% end %>
            </td>
            <td class="font-mono text-xs"><%= student.attendance_code %></td>
            <td class="text-base-content/60 text-sm"><%= student.phone %></td>
            <td class="text-base-content/40 text-xs"><%= student.first_enrolled_at&.strftime("%Y.%m.%d") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @students.empty? %>
      <p class="text-center text-base-content/40 py-8 text-sm">수강생이 없습니다.</p>
    <% end %>
  </div>
</div>

<%# 페이지네이션 %>
<div class="flex items-center justify-between mt-4">
  <p class="text-xs text-base-content/50">
    전체 <%= @total_count %>명 중 <%= [(@page - 1) * 50 + 1, @total_count].min %>–<%= [@page * 50, @total_count].min %>명
  </p>
  <% if @total_pages > 1 %>
    <div class="join">
      <% if @page > 1 %>
        <%= link_to "«", students_path(page: 1,         status: params[:status], q: params[:q]), class: "join-item btn btn-sm btn-ghost" %>
        <%= link_to "‹", students_path(page: @page - 1, status: params[:status], q: params[:q]), class: "join-item btn btn-sm btn-ghost" %>
      <% end %>
      <% ([@page - 2, 1].max..[@page + 2, @total_pages].min).each do |p| %>
        <%= link_to p, students_path(page: p, status: params[:status], q: params[:q]),
              class: "join-item btn btn-sm #{p == @page ? 'btn-neutral' : 'btn-ghost'}" %>
      <% end %>
      <% if @page < @total_pages %>
        <%= link_to "›", students_path(page: @page + 1, status: params[:status], q: params[:q]), class: "join-item btn btn-sm btn-ghost" %>
        <%= link_to "»", students_path(page: @total_pages, status: params[:status], q: params[:q]), class: "join-item btn btn-sm btn-ghost" %>
      <% end %>
    </div>
  <% end %>
</div>
