<% content_for :title, "수업 상세" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← 출결 관리", schedules_path, class: "text-sm text-base-content/70 hover:underline" %>
  <h2 class="text-lg font-bold"><%= @schedule.student.name %> — <%= @schedule.subject %></h2>
  <%= schedule_status_badge(@schedule.status) %>
</div>

<div class="grid grid-cols-2 gap-6">

  <%# ── 수업 정보 + 상태별 1차 액션 ── %>
  <div class="bg-base-100 rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">수업 정보</h3>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-2"><dt class="text-base-content/60 w-24">날짜</dt><dd><%= @schedule.lesson_date.strftime("%Y.%m.%d (%a)") %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-24">시간</dt><dd><%= @schedule.lesson_time.strftime("%H:%M") %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-24">선생님</dt><dd><%= @schedule.teacher.name %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-24">회차</dt><dd><%= @schedule.sequence %>회</dd></div>
      <% if @schedule.from_pass? %>
        <div class="flex gap-2"><dt class="text-base-content/60 w-24">메모</dt><dd class="text-purple-600 text-xs">패스로 자동 생성된 수업</dd></div>
      <% end %>
      <% if @schedule.status.in?(%w[makeup_scheduled makeup_done]) && @schedule.makeup_date %>
        <div class="flex gap-2"><dt class="text-base-content/60 w-24">보강일</dt><dd><%= @schedule.makeup_date.strftime("%Y.%m.%d") %></dd></div>
        <div class="flex gap-2"><dt class="text-base-content/60 w-24">보강시간</dt><dd><%= @schedule.makeup_time&.strftime("%H:%M") %></dd></div>
      <% end %>
      <% if @schedule.status.in?(%w[pass emergency_pass holiday]) && @schedule.pass_reason.present? %>
        <div class="flex gap-2"><dt class="text-base-content/60 w-24">패스사유</dt><dd><%= @schedule.pass_reason %></dd></div>
      <% end %>
    </dl>

    <div class="mt-4 flex flex-wrap gap-2">
      <%# scheduled: 출석/결석 %>
      <% if @schedule.status == "scheduled" %>
        <%= button_to "출석", attend_schedule_path(@schedule), method: :patch,
              class: "text-sm bg-green-100 text-green-700 px-3 py-1.5 rounded hover:bg-green-200" %>
        <%= button_to "결석 차감", deduct_schedule_path(@schedule), method: :patch,
              class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200" %>
      <% end %>

      <%# deducted: 차감 취소 %>
      <% if @schedule.status == "deducted" %>
        <div class="w-full">
          <p class="text-xs text-red-500 mb-2">결석 차감 처리됨</p>
          <%= button_to "차감 취소", undo_deduct_schedule_path(@schedule), method: :patch,
                class: "text-sm bg-yellow-100 text-yellow-700 px-3 py-1.5 rounded hover:bg-yellow-200",
                data: { turbo_confirm: "차감 취소 후 예정 상태로 전환됩니다. 진행하시겠습니까?" } %>
        </div>
      <% end %>

      <%# pass / emergency_pass / holiday: 보강 전환 or 차감 전환 %>
      <% if @schedule.status.in?(%w[pass emergency_pass holiday]) %>
        <div class="w-full">
          <p class="text-xs <%= @schedule.status == "holiday" ? "text-green-700" : "text-purple-600" %> mb-2">
            <%= { "emergency_pass" => "긴급패스", "holiday" => "공휴일" }.fetch(@schedule.status, "패스") %> 처리됨 —
            보강 또는 차감으로 전환할 수 있습니다.
          </p>
          <%= button_to "차감으로 전환", deduct_schedule_path(@schedule), method: :patch,
                class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200",
                data: { turbo_confirm: "패스를 취소하고 결석 차감으로 처리합니다. (추가 생성된 Schedule이 삭제됩니다.) 진행하시겠습니까?" } %>
        </div>
      <% end %>

      <%# makeup_scheduled: 차감 전환 %>
      <% if @schedule.status == "makeup_scheduled" %>
        <div class="w-full">
          <p class="text-xs text-blue-600 mb-2">보강 예정 — 패스 또는 차감으로 전환할 수 있습니다.</p>
          <%= button_to "차감으로 전환", deduct_schedule_path(@schedule), method: :patch,
                class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200",
                data: { turbo_confirm: "보강을 취소하고 결석 차감으로 처리합니다. 진행하시겠습니까?" } %>
        </div>
      <% end %>

      <%# makeup_done: 경고 후 전환 허용 %>
      <% if @schedule.status == "makeup_done" %>
        <div class="w-full">
          <div class="bg-yellow-50 border border-yellow-200 rounded p-2 text-xs text-yellow-700 mb-2">
            ⚠️ 보강 완료됨. 전환 시 상담원 확인이 필요합니다.
          </div>
          <%= button_to "차감으로 전환", deduct_schedule_path(@schedule), method: :patch,
                class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200",
                data: { turbo_confirm: "보강 완료 상태에서 차감으로 전환합니다. 상담원 확인 후 진행하세요. 계속하시겠습니까?" } %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── 보강 등록 (scheduled / makeup_scheduled / pass / emergency_pass / holiday) ── %>
  <% show_makeup = @schedule.status.in?(%w[scheduled makeup_scheduled pass emergency_pass holiday]) %>
  <% if show_makeup %>
    <div class="bg-base-100 rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-3">보강 등록</h3>
      <% range = @schedule.makeup_available_range %>
      <% if range %>
        <p class="text-xs text-base-content/70 mb-3">보강 가능 기간: <%= range.first.strftime("%m/%d") %> ~ <%= range.last.strftime("%m/%d") %></p>
        <% if @schedule.lesson_date == Date.today %>
          <div class="bg-yellow-50 border border-yellow-200 rounded p-2 mb-3 text-xs text-yellow-700">
            ⚠️ 당일 취소 보강입니다. 상담원 확인 후 진행하세요.
          </div>
        <% end %>
        <% if @schedule.status.in?(%w[pass emergency_pass holiday]) %>
          <div class="bg-purple-50 border border-purple-200 rounded p-2 mb-3 text-xs text-purple-700">
            패스/공휴일 → 보강 전환 시 추가 생성된 Schedule이 삭제됩니다.
          </div>
        <% end %>
        <%= form_with url: makeup_schedule_path(@schedule), method: :patch, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-base-content mb-1">보강 날짜</label>
            <%= f.date_field :makeup_date, min: range.first, max: range.last, class: "input input-bordered w-full text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-base-content mb-1">보강 시간</label>
            <%= f.time_field :makeup_time, class: "input input-bordered w-full text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-base-content mb-1">선생님</label>
            <%= f.select :makeup_teacher_id,
                Teacher.joins(:teacher_subjects).where(teacher_subjects: { subject: @schedule.subject }).map { |t| [t.name, t.id] },
                { prompt: "선생님 선택" },
                class: "select select-bordered w-full text-sm" %>
          </div>
          <% if @schedule.subject == "믹싱" && @schedule.enrollment.student.rank == "first" %>
            <div class="bg-blue-50 border border-blue-200 rounded p-2 text-xs text-blue-700">
              믹싱 1차전직 보강 순서:<br>
              1️⃣ 같은 주차 미라쿠도 반 슬롯<br>
              2️⃣ 미라쿠도 빈 시간<br>
              3️⃣ 오또 빈 시간 (드라이브 기입 필요)
            </div>
          <% end %>
          <%= f.submit "보강 등록", class: "w-full bg-indigo-600 text-white py-2 rounded text-sm hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      <% else %>
        <p class="text-sm text-base-content/60">보강 가능 기간이 없습니다.</p>
      <% end %>
    </div>
  <% end %>

  <%# ── 패스 처리 (scheduled / makeup_scheduled) ── %>
  <% show_pass = @schedule.status.in?(%w[scheduled makeup_scheduled]) %>
  <% if show_pass %>
    <div class="bg-base-100 rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-3">패스 처리</h3>
      <% if @schedule.lesson_date == Date.today %>
        <div class="bg-orange-50 border border-orange-200 rounded p-3 text-xs text-orange-700">
          <p class="font-medium mb-1">⚠️ 당일 패스 불가</p>
          <p>1단계: 보강 등록을 먼저 시도하세요.</p>
          <p>2단계: 보강도 불가하면 결석 차감으로 처리하세요.</p>
        </div>
      <% elsif @schedule.subject == "믹싱" %>
        <div class="bg-orange-50 border border-orange-200 rounded p-3 text-xs text-orange-700">
          <p class="font-medium mb-1">⚠️ 믹싱 패스 불가</p>
          <p>1단계: 보강 등록을 시도하세요.</p>
          <p>2단계: 보강도 불가하면 결석 차감으로 처리하세요.</p>
        </div>
      <% else %>
        <% if @schedule.status == "makeup_scheduled" %>
          <div class="bg-blue-50 border border-blue-200 rounded p-2 mb-3 text-xs text-blue-700">
            보강 → 패스 전환: 보강 예약이 취소되고 패스로 처리됩니다.
          </div>
        <% end %>
        <%= form_with url: pass_schedule_path(@schedule), method: :patch, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-base-content mb-1">패스 사유</label>
            <%= f.text_field :pass_reason, class: "input input-bordered w-full text-sm" %>
          </div>
          <p class="text-xs text-orange-600">⚠️ 패스 처리 시 개근 카운트가 리셋됩니다.</p>
          <%= f.submit "패스 처리", class: "w-full bg-purple-100 text-purple-700 py-2 rounded text-sm hover:bg-purple-200 cursor-pointer" %>
        <% end %>
        <% if @schedule.status == "scheduled" %>
          <div class="mt-3 pt-3 border-t">
            <%= form_with url: emergency_pass_schedule_path(@schedule), method: :patch, class: "flex gap-2" do |f| %>
              <%= f.text_field :pass_reason, placeholder: "긴급패스 사유", class: "input input-bordered flex-1 text-sm" %>
              <%= f.submit "긴급패스", class: "bg-pink-100 text-pink-700 px-3 py-1.5 rounded text-sm hover:bg-pink-200 cursor-pointer" %>
            <% end %>
          </div>
          <div class="mt-3 pt-3 border-t">
            <%= form_with url: holiday_schedule_path(@schedule), method: :patch, class: "flex gap-2" do |f| %>
              <%= f.text_field :pass_reason, placeholder: "공휴일명 (예: 삼일절)", class: "input input-bordered flex-1 text-sm" %>
              <%= f.submit "공휴일", class: "bg-green-100 text-green-700 px-3 py-1.5 rounded text-sm hover:bg-green-200 cursor-pointer" %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>
