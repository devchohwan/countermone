<% content_for :title, "수업 상세" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← 출결 관리", schedules_path, class: "text-sm text-gray-500 hover:underline" %>
  <h2 class="text-lg font-bold"><%= @schedule.student.name %> — <%= @schedule.subject %></h2>
  <%= schedule_status_badge(@schedule.status) %>
</div>

<div class="grid grid-cols-2 gap-6">

  <div class="bg-white rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">수업 정보</h3>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-2"><dt class="text-gray-400 w-24">날짜</dt><dd><%= @schedule.lesson_date.strftime("%Y.%m.%d (%a)") %></dd></div>
      <div class="flex gap-2"><dt class="text-gray-400 w-24">시간</dt><dd><%= @schedule.lesson_time.strftime("%H:%M") %></dd></div>
      <div class="flex gap-2"><dt class="text-gray-400 w-24">선생님</dt><dd><%= @schedule.teacher.name %></dd></div>
      <div class="flex gap-2"><dt class="text-gray-400 w-24">회차</dt><dd><%= @schedule.sequence %>회</dd></div>
    </dl>

    <div class="mt-4 flex flex-wrap gap-2">
      <% if @schedule.status == "scheduled" %>
        <%= button_to "출석", attend_schedule_path(@schedule),  method: :patch, class: "text-sm bg-green-100 text-green-700 px-3 py-1.5 rounded hover:bg-green-200" %>
        <%= button_to "결강", absent_schedule_path(@schedule),  method: :patch, class: "text-sm bg-orange-100 text-orange-700 px-3 py-1.5 rounded hover:bg-orange-200" %>
        <%= button_to "결석", deduct_schedule_path(@schedule),  method: :patch, class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200" %>
      <% end %>
    </div>
  </div>

  <!-- 보강 등록 -->
  <% if @schedule.status.in?(%w[absent scheduled]) %>
    <div class="bg-white rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-3">보강 등록</h3>
      <% range = @schedule.makeup_available_range %>
      <% if range %>
        <p class="text-xs text-gray-500 mb-3">보강 가능 기간: <%= range.first.strftime("%m/%d") %> ~ <%= range.last.strftime("%m/%d") %></p>
        <%= form_with url: makeup_schedule_path(@schedule), method: :patch, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">보강 날짜</label>
            <%= f.date_field :makeup_date, min: range.first, max: range.last, class: "w-full border rounded px-2 py-1.5 text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">보강 시간</label>
            <%= f.time_field :makeup_time, class: "w-full border rounded px-2 py-1.5 text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">선생님</label>
            <%= f.select :makeup_teacher_id,
                Teacher.joins(:teacher_subjects).where(teacher_subjects: { subject: @schedule.subject }).map { |t| [t.name, t.id] },
                { prompt: "선생님 선택" },
                class: "w-full border rounded px-2 py-1.5 text-sm" %>
          </div>
          <%= f.submit "보강 등록", class: "w-full bg-indigo-600 text-white py-2 rounded text-sm hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-400">보강 가능 기간이 없습니다.</p>
      <% end %>
    </div>
  <% end %>

  <!-- 패스 처리 -->
  <% if @schedule.status == "scheduled" %>
    <div class="bg-white rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-3">패스 처리</h3>
      <%= form_with url: pass_schedule_path(@schedule), method: :patch, class: "space-y-3" do |f| %>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">패스 사유</label>
          <%= f.text_field :pass_reason, class: "w-full border rounded px-2 py-1.5 text-sm" %>
        </div>
        <p class="text-xs text-orange-600">⚠️ 패스 처리 시 개근 카운트가 리셋됩니다.</p>
        <%= f.submit "패스 처리", class: "w-full bg-purple-100 text-purple-700 py-2 rounded text-sm hover:bg-purple-200 cursor-pointer" %>
      <% end %>
      <div class="mt-3 pt-3 border-t">
        <%= form_with url: emergency_pass_schedule_path(@schedule), method: :patch, class: "flex gap-2" do |f| %>
          <%= f.text_field :pass_reason, placeholder: "긴급패스 사유", class: "flex-1 border rounded px-2 py-1.5 text-sm" %>
          <%= f.submit "긴급패스", class: "bg-pink-100 text-pink-700 px-3 py-1.5 rounded text-sm hover:bg-pink-200 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
