<% content_for :title, "대시보드 — 모네뮤직" %>

<% if @is_today %>
  <%= turbo_stream_from "dashboard_current" %>
<% end %>

<div class="space-y-4">

  <%# 헤더 + 날짜 네비게이션 %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="join">
        <%= link_to "←", root_path(date: (@date - 1).to_s), class: "join-item btn btn-sm btn-ghost" %>
        <span class="join-item btn btn-sm btn-ghost pointer-events-none font-semibold">
          <%= @date.strftime("%Y.%m.%d (%a)") %>
        </span>
        <%= link_to "→", root_path(date: (@date + 1).to_s),
              class: "join-item btn btn-sm btn-ghost #{@date >= @effective_today ? 'btn-disabled opacity-30' : ''}" %>
      </div>
      <% if @dual_date_mode %>
        <%= link_to "#{Date.today.strftime('%-m/%-d')} 오늘", root_path(date: Date.today.to_s),
              class: "btn btn-xs #{@date == Date.today ? 'btn-primary' : 'btn-outline'}" %>
        <%= link_to "#{Date.tomorrow.strftime('%-m/%-d')} 내일", root_path(date: Date.tomorrow.to_s),
              class: "btn btn-xs #{@date == Date.tomorrow ? 'btn-primary' : 'btn-outline'}" %>
      <% elsif !@is_today %>
        <%= link_to "오늘", root_path, class: "btn btn-xs btn-primary" %>
      <% end %>
      <% if @is_today %>
        <p class="text-sm text-base-content/60" id="dashboard-time"></p>
      <% end %>
    </div>
    <div class="flex gap-2 items-center">
      <span id="keungeun-alert-badge"><% if @attendance_events&.any? %><div class="badge badge-accent gap-1">🔥 개근달성 <%= @attendance_events.count %>명</div><% end %></span>
      <% if @is_today %>
        <% if @payment_due_today.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-error badge-xs"><%= @payment_due_today.count %></span><span class="btn btn-ghost btn-sm">💳</span></div>
        <% end %>
        <% if @contact_list.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-warning badge-xs"><%= @contact_list.count %></span><span class="btn btn-ghost btn-sm">📞</span></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Row 1: 시간대별수업 / 시간대별등하원 / 지금이순간(오늘만) %>
  <div class="grid <%= @is_today ? 'grid-cols-3' : 'grid-cols-2' %> gap-4">

    <%= render "hourly_schedule_text",
          schedules: @today_schedules,
          makeups: @today_makeups,
          enrollment_remaining: @enrollment_remaining %>

    <%= render "hourly_arrival_text", schedules: @today_schedules, readonly: !@is_today %>

    <% if @is_today %>
      <div>
        <%= turbo_frame_tag "current_schedules", src: dashboard_current_schedules_path(date: @date), loading: :lazy do %>
          <%= render "current_schedules" %>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# Row 2: 결제 / 내일결제자(오늘만) / 마감 %>
  <div class="grid <%= @is_today ? 'grid-cols-3' : 'grid-cols-2' %> gap-4">

    <% if @is_today %>
      <%# 오늘: 결제/연락/확인/개근 탭 %>
      <%
        sched_by_enroll  = @today_schedules.index_by(&:enrollment_id)
        makeup_by_enroll = (@today_makeups || []).index_by(&:enrollment_id)
        with_sched    = @payment_due_today.select { |i| sched_by_enroll[i[:enrollment].id] || makeup_by_enroll[i[:enrollment].id] }
        without_sched = @payment_due_today.reject { |i| sched_by_enroll[i[:enrollment].id] || makeup_by_enroll[i[:enrollment].id] }
        effective_hour = ->(i) {
          s = sched_by_enroll[i[:enrollment].id]
          if s
            s.status.in?(%w[makeup_scheduled makeup_done]) ?
              s.makeup_time&.in_time_zone('Seoul')&.hour :
              s.lesson_time.in_time_zone('Seoul').hour
          else
            makeup_by_enroll[i[:enrollment].id].makeup_time&.in_time_zone('Seoul')&.hour
          end
        }
        effective_teacher = ->(i) {
          s = sched_by_enroll[i[:enrollment].id]
          if s
            s.status.in?(%w[makeup_scheduled makeup_done]) ?
              s.makeup_teacher || s.teacher :
              s.teacher
          else
            makeup_by_enroll[i[:enrollment].id]&.makeup_teacher
          end
        }
        grouped = with_sched
          .group_by { |i| effective_hour.(i) }
          .sort
          .map { |hour, items|
            [hour, items.group_by { |i| effective_teacher.(i) }]
          }
        pay_item_name = ->(item) {
          s = sched_by_enroll[item[:enrollment].id]
          is_makeup = (s && s.status.in?(%w[makeup_scheduled makeup_done])) ||
                      (!s && makeup_by_enroll[item[:enrollment].id])
          is_makeup ? "#{item[:student].name}-보강(#{item[:enrollment].subject})" : item[:student].name
        }
        pay_copy_lines = []
        grouped.each do |hour, by_teacher|
          pay_copy_lines << "#{hour}시"
          by_teacher.each do |teacher, items|
            pay_copy_lines << "[#{teacher.name}]"
            items.each do |item|
              lbl = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정"
              pay_copy_lines << "#{pay_item_name.(item)} #{lbl}"
            end
          end
          pay_copy_lines << ""
        end
        unless without_sched.empty?
          pay_copy_lines << "오늘 수업 없음"
          without_sched.each do |item|
            lbl = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정"
            pay_copy_lines << "#{item[:student].name} #{item[:enrollment].subject} #{lbl}"
          end
        end

        contact_copy_lines = @contact_list.map do |item|
          type_label = case item[:type]
          when :contact_due     then "연락기한"
          when :return_due      then "복귀예정"
          when :waiting_expired then "자리대기만료"
          end
          subj = item[:enrollment] ? " #{item[:enrollment].subject}" : ""
          "#{item[:student].name}#{subj} #{type_label}"
        end

        confirm_copy_lines = []
        @minus_enrollments.each { |e| confirm_copy_lines << "#{e.student.name} — #{e.subject} (#{e.minus_lesson_count}회) 마이너스" }
        @pending_consents.each  { |s| confirm_copy_lines << "#{s.name} 동의서미수령" }

        keungeun_copy_lines = @attendance_events.map { |e| "#{e.student.name} #{e.subject} 개근달성" }
      %>
      <script>
        window._todoCopy = {
          pay:      <%= pay_copy_lines.join("\n").strip.to_json.html_safe %>,
          contact:  <%= contact_copy_lines.join("\n").to_json.html_safe %>,
          confirm:  <%= confirm_copy_lines.join("\n").to_json.html_safe %>,
          keungeun: <%= keungeun_copy_lines.join("\n").to_json.html_safe %>
        };
        function switchTodoCopy(type) {
          const btn = document.getElementById('todo-copy-btn');
          if (btn) { btn.dataset.copyText = window._todoCopy[type] || ''; btn.textContent = '복사'; }
        }
      </script>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">

          <div class="flex justify-end mb-1">
            <button id="todo-copy-btn"
                    class="btn btn-xs btn-ghost"
                    data-copy-text=""
                    onclick="navigator.clipboard.writeText(this.dataset.copyText).then(()=>{this.textContent='✓ 복사됨';setTimeout(()=>this.textContent='복사',1500)}).catch(()=>{})">복사</button>
          </div>
          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const btn = document.getElementById('todo-copy-btn');
              if (btn && window._todoCopy) {
                const tab = '<%= params[:todo_tab].presence || 'pay' %>';
                btn.dataset.copyText = window._todoCopy[tab] || window._todoCopy.pay || '';
              }
            });
          </script>

          <div role="tablist" class="tabs tabs-bordered tabs-sm">

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="💳 결제 (<%= @payment_due_today.count %>)"
                   <%= params[:todo_tab].blank? || params[:todo_tab] == 'pay' ? 'checked' : '' %>
                   onchange="switchTodoCopy('pay')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @payment_due_today.empty? %>
                <p class="text-sm text-base-content/40">오늘 결제 예정 없음</p>
              <% else %>
                <div class="flex flex-col gap-3 font-mono text-sm leading-snug overflow-y-auto max-h-60">
                  <% grouped.each do |hour, by_teacher| %>
                    <div>
                      <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
                      <% by_teacher.each do |teacher, items| %>
                        <p class="text-xs text-base-content/40">[<%= teacher.name %>]</p>
                        <% items.each do |item| %>
                          <% badge_color = item[:type] == :deposit_first_lesson ? "badge-error" : "badge-info" %>
                          <% label = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정" %>
                          <p class="flex items-center gap-1">
                            <%= pay_item_name.(item) %>
                            <span class="badge badge-xs <%= badge_color %>"><%= label %></span>
                            <% if item[:type] == :deposit_first_lesson %>
                              <button type="button" onclick="document.getElementById('cpd-<%= item[:payment].id %>').showModal()" class="btn btn-xs btn-error btn-outline">완납</button>
                            <% elsif item[:type] == :next_payment_due %>
                              <button id="pay-btn-<%= item[:enrollment].id %>" type="button"
                                onclick="window.open('<%= new_payment_path(enrollment_id: item[:enrollment].id, popup: 1) %>','_blank','width=900,height=700')"
                                class="btn btn-xs btn-primary btn-outline">결제</button>
                            <% end %>
                          </p>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                  <% if without_sched.any? %>
                    <div>
                      <p class="text-xs font-bold text-base-content/50 mb-1">오늘 수업 없음</p>
                      <% without_sched.each do |item| %>
                        <% badge_color = item[:type] == :deposit_first_lesson ? "badge-error" : "badge-info" %>
                        <% label = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정" %>
                        <p class="flex items-center gap-1">
                          <%= item[:student].name %> — <%= item[:enrollment].subject %>
                          <span class="badge badge-xs <%= badge_color %>"><%= label %></span>
                          <% if item[:type] == :deposit_first_lesson %>
                            <button type="button" onclick="document.getElementById('cpd-<%= item[:payment].id %>').showModal()" class="btn btn-xs btn-error btn-outline">완납</button>
                          <% elsif item[:type] == :next_payment_due %>
                            <button id="pay-btn-<%= item[:enrollment].id %>" type="button"
                              onclick="window.open('<%= new_payment_path(enrollment_id: item[:enrollment].id, popup: 1) %>','_blank','width=900,height=700')"
                              class="btn btn-xs btn-primary btn-outline">결제</button>
                          <% end %>
                        </p>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <%# 완납처리 다이얼로그 %>
              <% (@payment_due_today || []).select { |i| i[:type] == :deposit_first_lesson }.each do |item| %>
                <dialog id="cpd-<%= item[:payment].id %>" class="modal">
                  <div class="modal-box">
                    <h3 class="font-bold text-base mb-4"><%= item[:student].name %> — <%= item[:enrollment].subject %> 완납처리</h3>
                    <% balance_default = [item[:payment].amount.to_i - item[:payment].deposit_amount.to_i, 0].max %>
                    <%= form_with url: complete_deposit_payment_path(item[:payment]), method: :patch do |f| %>
                      <div class="form-control mb-3">
                        <label class="label"><span class="label-text text-sm">잔금액 (예약금: <%= number_with_delimiter(item[:payment].deposit_amount.to_i) %>원 / 총액: <%= number_with_delimiter(item[:payment].amount.to_i) %>원)</span></label>
                        <%= f.number_field :balance_amount, value: balance_default,
                              class: "input input-bordered w-full", min: 0, step: 1000 %>
                      </div>
                      <div class="form-control mb-5">
                        <label class="label"><span class="label-text text-sm">결제수단</span></label>
                        <%= f.select :payment_method,
                              [["카드", "card"], ["계좌이체", "transfer"], ["현금", "cash"]],
                              { selected: item[:payment].payment_method },
                              class: "select select-bordered w-full" %>
                      </div>
                      <div class="flex justify-end gap-2">
                        <button type="button" onclick="document.getElementById('cpd-<%= item[:payment].id %>').close()" class="btn btn-ghost btn-sm">취소</button>
                        <%= f.submit "완납처리", class: "btn btn-error btn-sm" %>
                      </div>
                    <% end %>
                  </div>
                  <form method="dialog" class="modal-backdrop"><button>닫기</button></form>
                </dialog>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="📞 연락 (<%= @contact_list.count %>)"
                   onchange="switchTodoCopy('contact')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @contact_list.empty? %>
                <p class="text-sm text-base-content/40">오늘 연락할 대상 없음</p>
              <% else %>
                <ul class="space-y-2">
                  <% @contact_list.each do |item| %>
                    <li class="flex items-center gap-2 text-sm">
                      <span class="font-medium"><%= item[:student].name %></span>
                      <span class="badge badge-xs badge-outline">
                        <%= case item[:type]
                            when :contact_due     then "연락기한"
                            when :return_due      then "복귀예정"
                            when :waiting_expired then "자리대기만료"
                            end %>
                      </span>
                      <% if item[:enrollment] %>
                        <span class="text-xs text-base-content/50"><%= item[:enrollment].subject %></span>
                      <% end %>
                      <%= button_to "완료", complete_contact_student_path(item[:student]),
                            method: :patch,
                            class: "btn btn-xs btn-ghost text-success ml-auto" %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab" aria-label="✅ 확인"
                   onchange="switchTodoCopy('confirm')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @minus_enrollments.any? %>
                <p class="text-xs font-bold text-error mb-1">마이너스 수업</p>
                <% @minus_enrollments.each do |e| %>
                  <p class="text-sm"><%= e.student.name %> — <%= e.subject %> (<%= e.minus_lesson_count %>회)</p>
                <% end %>
              <% end %>
              <% if @pending_consents.any? %>
                <p class="text-xs font-bold text-warning mt-2 mb-1">동의서 미수령</p>
                <% @pending_consents.each do |s| %>
                  <p class="text-sm"><%= s.name %></p>
                <% end %>
              <% end %>
              <% if @minus_enrollments.empty? && @pending_consents.empty? %>
                <p class="text-sm text-base-content/40">없음</p>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   id="keungeun-tab-radio"
                   aria-label="🎯 개근 (<%= @attendance_events.count %>)"
                   <%= params[:todo_tab] == 'keungeun' ? 'checked' : '' %>
                   onchange="switchTodoCopy('keungeun')" />
            <%= render "dashboard/attendance_events_panel", attendance_events: @attendance_events %>

          </div>
        </div>
      </div>

    <% else %>
      <%# 과거: 그날 완납 결제 내역 %>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">
          <h3 class="card-title text-sm mb-2">결제 완료</h3>
          <% if @daily_payments.empty? %>
            <p class="text-sm text-base-content/40">결제 완료 없음</p>
          <% else %>
            <ul class="space-y-1">
              <% @daily_payments.each do |p| %>
                <li class="text-sm"><%= p.student.name %> — <%= p.subject %> (<%= format_amount(p.amount) %>)</li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @is_today %>
      <%= render "tomorrow_payments" %>
    <% end %>

    <%# 마감 %>
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body p-4">
        <div class="flex items-center justify-between mb-1">
          <h3 class="card-title text-sm"><%= @is_today ? "오늘 마감" : @date.strftime("%m/%d 마감") %></h3>
          <%= link_to "마감 톡 생성 →", statistics_path(date: @date), class: "btn btn-xs btn-primary" %>
        </div>
        <%= render "daily_summary" %>
      </div>
    </div>

  </div>

  <%# 시간표 — /timetable/4 그대로 임베드 %>
  <%= turbo_frame_tag "timetable_embed", src: teacher_timetable_path(4, date: @date.to_s), loading: :lazy do %>
    <div class="card bg-base-100 shadow-sm p-4 text-sm text-base-content/40">시간표 로딩 중...</div>
  <% end %>

</div>

<%# 당취 모달 — hourly_arrival turbo frame 밖에 위치 %>
<dialog id="dangchwi-modal" class="modal">
  <div class="modal-box max-w-2xl p-5">
    <h3 class="font-bold text-base mb-1" id="dangchwi-title"></h3>
    <p class="text-xs text-base-content/50 mb-4" id="dangchwi-subject"></p>
    <div id="dangchwi-body"></div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
(function() {
  let _scheduleId = null;

  function csrf() {
    return document.querySelector('meta[name="csrf-token"]')?.content || '';
  }

  function body() { return document.getElementById('dangchwi-body'); }

  // form.requestSubmit() → Turbo가 가로채어 turbo_stream 응답 처리
  function patchForm(url, extra) {
    const f = document.createElement('form');
    f.method = 'POST';
    f.action = url;
    f.innerHTML = `<input type="hidden" name="authenticity_token" value="${csrf()}">
                   <input type="hidden" name="_method" value="patch">` + (extra || '');
    document.body.appendChild(f);
    document.getElementById('dangchwi-modal').close();
    f.requestSubmit();
  }

  // ── 날짜 유틸 ──────────────────────────────────────────────
  function parseDate(str) {
    const [y, m, d] = str.split('-').map(Number);
    return new Date(y, m - 1, d);
  }
  function toDateStr(d) {
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }
  function getMonday(date) {
    const d = new Date(date); const day = d.getDay();
    const diff = day === 0 ? -6 : 1 - day;
    return new Date(d.getFullYear(), d.getMonth(), d.getDate() + diff);
  }

  // ── 메인 화면 ───────────────────────────────────────────────
  function showMain() {
    document.getElementById('dangchwi-title').textContent =
      document.getElementById('dangchwi-title').textContent.replace(' — 보강 등록', '');
    body().innerHTML = `
      <div class="space-y-2">
        <button onclick="dangchwiShowMakeup()" class="btn btn-sm btn-info btn-outline w-full">보강</button>
        <button onclick="dangchwiShowPass()" class="btn btn-sm btn-secondary btn-outline w-full">패스</button>
        <button onclick="dangchwiDeduct()" class="btn btn-sm btn-error btn-outline w-full">결석 차감</button>
      </div>`;
  }

  window.openDangchwiModal = function(scheduleId, studentName, subject, status) {
    _scheduleId = scheduleId;
    document.getElementById('dangchwi-title').textContent = studentName;
    document.getElementById('dangchwi-subject').textContent = subject;
    showMain();
    document.getElementById('dangchwi-modal').showModal();
  };

  window.dangchwiShowPass = function() {
    body().innerHTML = `
      <div class="space-y-3">
        <div class="border rounded-lg p-3 space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold text-purple-700">일반 패스</span>
            <span class="badge badge-xs badge-warning">횟수 1회 소진</span>
          </div>
          <div class="flex gap-2">
            <input type="text" id="dc-pass-reason" placeholder="사유 (선택)" class="input input-bordered input-sm flex-1 text-sm">
            <button onclick="dangchwiSubmitPass('pass')" class="btn btn-sm bg-purple-100 text-purple-700 hover:bg-purple-200 border-0">패스</button>
          </div>
        </div>
        <div class="border rounded-lg p-3 space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold text-pink-700">긴급 패스</span>
            <span class="badge badge-xs badge-ghost">횟수 소진 없음</span>
          </div>
          <div class="flex gap-2">
            <input type="text" id="dc-emergency-reason" placeholder="사유 (선택)" class="input input-bordered input-sm flex-1 text-sm">
            <button onclick="dangchwiSubmitPass('emergency_pass')" class="btn btn-sm bg-pink-100 text-pink-700 hover:bg-pink-200 border-0">긴급패스</button>
          </div>
        </div>
        <div class="border rounded-lg p-3 space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold text-green-700">공휴일 패스</span>
            <span class="badge badge-xs badge-ghost">횟수 소진 없음</span>
          </div>
          <div class="flex gap-2">
            <input type="text" id="dc-holiday-reason" placeholder="공휴일명 (예: 삼일절)" class="input input-bordered input-sm flex-1 text-sm">
            <button onclick="dangchwiSubmitPass('holiday')" class="btn btn-sm bg-green-100 text-green-700 hover:bg-green-200 border-0">공휴일</button>
          </div>
        </div>
        <button onclick="dangchwiShowMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>
      </div>`;
  };

  window.dangchwiShowMain = showMain;

  window.dangchwiSubmitPass = function(type) {
    const keyMap = { pass: 'pass', emergency_pass: 'emergency', holiday: 'holiday' };
    const reason = document.getElementById('dc-' + keyMap[type] + '-reason')?.value || '';
    patchForm(`/schedules/${_scheduleId}/${type}`,
      `<input type="hidden" name="pass_reason" value="${reason.replace(/"/g, '&quot;')}">`);
  };

  window.dangchwiDeduct = function() {
    if (!confirm('결석 차감 처리하시겠습니까?')) return;
    patchForm(`/schedules/${_scheduleId}/deduct`, '');
  };

  // ── 보강 시간표 그리드 ────────────────────────────────────
  window.dangchwiShowMakeup = function() {
    document.getElementById('dangchwi-title').textContent = '보강 등록';
    body().innerHTML = '<p class="text-xs text-base-content/50 py-4 text-center">슬롯 불러오는 중…</p>';
    fetch(`/schedules/${_scheduleId}/makeup_slots`)
      .then(r => r.json())
      .then(data => {
        if (!data.range_min) {
          body().innerHTML = `
            <p class="text-sm text-error py-2">보강 가능 기간이 없습니다.</p>
            <button onclick="dangchwiShowMain()" class="btn btn-sm btn-ghost w-full">← 돌아가기</button>`;
          return;
        }
        window._dcData      = data;
        window._dcWeekStart = getMonday(new Date());
        window._dcTeacherId = data.teachers[0]?.id ?? null;
        window._dcSid       = _scheduleId;
        window._dcRender();
      });
  };

  window._dcRender = function() {
    const data     = window._dcData;
    const ws       = window._dcWeekStart;
    const rangeMin = parseDate(data.range_min);
    const rangeMax = data.range_max ? parseDate(data.range_max) : null;
    const inRange  = d => d >= rangeMin && (rangeMax === null || d <= rangeMax);
    const DAY_KO   = ['일','월','화','수','목','금','토'];

    const days = Array.from({length: 7}, (_, i) =>
      new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + i));

    const prevWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() - 7);
    const nextWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + 7);
    const prevDays = Array.from({length:7}, (_, i) => new Date(prevWs.getFullYear(), prevWs.getMonth(), prevWs.getDate() + i));
    const nextDays = Array.from({length:7}, (_, i) => new Date(nextWs.getFullYear(), nextWs.getMonth(), nextWs.getDate() + i));
    const prevOk   = prevDays.some(d => inRange(d));
    const nextOk   = rangeMax === null || nextDays.some(d => inRange(d));

    const weekEnd   = days[6];
    const weekLabel = `${ws.getMonth()+1}/${ws.getDate()} ~ ${weekEnd.getMonth()+1}/${weekEnd.getDate()}`;

    const teacherTabs = data.teachers.map(t => {
      const active = window._dcTeacherId === t.id;
      return `<button onclick="window._dcTeacherId=${t.id};window._dcRender();"
                      class="btn btn-xs ${active ? 'btn-primary' : 'btn-ghost'}">${t.name}</button>`;
    }).join('');

    const tid      = String(window._dcTeacherId);
    const tGrid    = (data.grid || {})[tid] || {};
    const tConflict = ((data.conflict_grid || {})[tid]) || {};
    const teacher  = data.teachers.find(t => t.id === window._dcTeacherId);
    const tName    = teacher?.name || '';

    const times = [];
    for (let m = 13 * 60; m <= 22 * 60; m += 60) {
      times.push(`${String(Math.floor(m/60)).padStart(2,'0')}:${String(m%60).padStart(2,'0')}`);
    }

    const thCells = days.map(d => {
      const ok = inRange(d);
      return `<th class="text-xs font-normal text-center px-1 py-1 ${ok ? '' : 'opacity-25'}">
        ${d.getMonth()+1}/${d.getDate()}<br>
        <span class="text-base-content/60">${DAY_KO[d.getDay()]}</span>
      </th>`;
    }).join('');

    const rows = times.map(time => {
      const tds = days.map(d => {
        const ok = inRange(d);
        const ds = toDateStr(d);
        if (!ok) return `<td class="text-center opacity-20 text-xs select-none px-1 py-1">—</td>`;
        const slots    = ((tGrid[ds] || {})[time]) || 0;
        const conflict = ((tConflict[ds] || {})[time]) === 'conflict';
        if (conflict) return `<td class="text-center text-xs select-none px-1 py-1 rounded"
          style="background:rgba(251,146,60,0.12);color:rgba(251,146,60,0.5);" title="다른 과목 수업 있음">✕</td>`;
        if (slots >= 3) return `<td class="text-center text-xs select-none px-1 py-1 rounded"
          style="background:rgba(239,68,68,0.12);color:rgba(239,68,68,0.5);" title="마감 (3/3)">✕</td>`;
        const colorCls = slots === 0 ? 'text-success' : 'text-warning';
        return `<td class="text-center cursor-pointer rounded px-1 py-1"
          style="background:rgba(34,197,94,0.12);"
          onmouseover="this.style.background='rgba(34,197,94,0.25)'"
          onmouseout="this.style.background='rgba(34,197,94,0.12)'"
          onclick="window._dcConfirm('${ds}',${window._dcTeacherId},'${time}','${tName}')"
          title="${tName} — ${slots}/3명">
          <span class="font-mono text-xs ${colorCls}">${'●'.repeat(slots)}</span><span class="font-mono text-xs opacity-30">${'○'.repeat(3-slots)}</span>
        </td>`;
      }).join('');
      return `<tr>
        <td class="text-xs text-base-content/50 text-right pr-2 py-1 whitespace-nowrap font-mono w-12">${time}</td>
        ${tds}
      </tr>`;
    }).join('');

    body().innerHTML = `
      <div class="text-xs text-base-content/50 mb-2">보강 가능: ${data.range_min} ~ ${data.range_max || '상한 없음'}</div>
      <div class="flex flex-wrap gap-1 mb-3">${teacherTabs}</div>
      <div class="flex items-center justify-between mb-2">
        <button onclick="window._dcNav(-1)" class="btn btn-xs btn-ghost" ${!prevOk ? 'disabled' : ''}>←</button>
        <span class="text-sm font-medium">${weekLabel}</span>
        <button onclick="window._dcNav(1)"  class="btn btn-xs btn-ghost" ${!nextOk ? 'disabled' : ''}>→</button>
      </div>
      <div class="overflow-x-auto">
        <table class="table table-xs w-full">
          <thead><tr><th class="w-12"></th>${thCells}</tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
      <button onclick="dangchwiShowMain()" class="btn btn-sm btn-ghost w-full mt-3">← 돌아가기</button>`;
  };

  window._dcNav = function(dir) {
    const ws = window._dcWeekStart;
    window._dcWeekStart = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + dir * 7);
    window._dcRender();
  };

  window._dcConfirm = function(date, teacherId, time, teacherName) {
    const sid  = window._dcSid;
    const tok  = csrf();
    body().innerHTML = `
      <div class="border rounded-lg p-4 space-y-3">
        <div class="text-sm font-semibold">${date} · ${teacherName} 선생님</div>
        <div class="flex items-center gap-2">
          <label class="text-sm text-base-content/60 w-16 shrink-0">보강 시간</label>
          <input type="time" id="dc-confirm-time" value="${time}" class="input input-bordered input-sm flex-1">
        </div>
        <div class="flex gap-2 pt-1">
          <button onclick="
            const t = document.getElementById('dc-confirm-time').value;
            const f = document.createElement('form');
            f.method = 'POST'; f.action = '/schedules/${sid}/makeup';
            f.innerHTML = '<input type=\\'hidden\\' name=\\'authenticity_token\\' value=\\'${tok}\\'>' +
                          '<input type=\\'hidden\\' name=\\'_method\\' value=\\'patch\\'>' +
                          '<input type=\\'hidden\\' name=\\'makeup_date\\' value=\\'${date}\\'>' +
                          '<input type=\\'hidden\\' name=\\'makeup_time\\' value=\\'' + t + '\\'>' +
                          '<input type=\\'hidden\\' name=\\'makeup_teacher_id\\' value=\\'${teacherId}\\'>';
            document.body.appendChild(f);
            document.getElementById('dangchwi-modal').close();
            f.requestSubmit();
          " class="btn btn-sm btn-primary flex-1">보강 등록</button>
          <button onclick="window._dcRender()" class="btn btn-sm btn-ghost flex-1">← 취소</button>
        </div>
      </div>`;
  };
})();
</script>

<% if @is_today %>
<script>
  const DAYS_KO = ['일','월','화','수','목','금','토'];
  function updateTime() {
    const now = new Date();
    const hh  = String(now.getHours()).padStart(2,'0');
    const mm  = String(now.getMinutes()).padStart(2,'0');
    const ss  = String(now.getSeconds()).padStart(2,'0');
    const el  = document.getElementById('dashboard-time');
    if (el) el.textContent = `${hh}:${mm}:${ss} (${DAYS_KO[now.getDay()]}요일) · 현재 시간대: ${now.getHours()}:00`;
  }
  updateTime();
  setInterval(updateTime, 1000);

  window.paymentDone = function(enrollmentId) {
    const btn = document.getElementById('pay-btn-' + enrollmentId);
    if (btn) {
      btn.textContent = '✓ 결제완료';
      btn.disabled = true;
      btn.classList.remove('btn-primary', 'btn-outline');
      btn.classList.add('btn-success');
    }
  };
</script>
<% end %>
