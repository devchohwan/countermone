<% content_for :title, "결제 상세" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@payment.student.name}", student_path(@payment.student), class: "text-sm text-base-content/70 hover:underline" %>
  <h2 class="text-lg font-bold">결제 상세</h2>
  <% unless @payment.fully_paid? %>
    <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">미완납</span>
  <% end %>
  <% if @payment.refunded? %>
    <span class="bg-base-200 text-base-content/80 text-xs px-2 py-1 rounded">환불완료</span>
  <% end %>
</div>

<div class="grid grid-cols-2 gap-6">
  <div class="bg-base-100 rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">결제 정보</h3>
    <dl class="space-y-2 text-sm">
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">수강생</dt><dd><%= link_to @payment.student.name, student_path(@payment.student), class: "hover:underline" %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">과목</dt><dd><%= @payment.subject %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">기간</dt><dd><%= @payment.months %>개월 (<%= @payment.total_lessons %>회)</dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">결제 금액</dt><dd class="font-medium"><%= format_amount(@payment.amount) %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">결제 수단</dt><dd><%= @payment.payment_method %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">시작일</dt><dd><%= @payment.starts_at.strftime("%Y.%m.%d") %></dd></div>
      <div class="flex gap-2"><dt class="text-base-content/60 w-28">종료일</dt><dd><%= @payment.ends_at&.strftime("%Y.%m.%d") || "-" %></dd></div>
      <% if @payment.payment_type == "deposit" %>
        <div class="flex gap-2 border-t pt-2"><dt class="text-base-content/60 w-28">예약금</dt><dd><%= format_amount(@payment.deposit_amount) %></dd></div>
        <div class="flex gap-2"><dt class="text-base-content/60 w-28">잔금</dt><dd><%= format_amount(@payment.balance_amount) %></dd></div>
      <% end %>
    </dl>

    <% unless @payment.fully_paid? %>
      <div class="mt-4 border-t pt-3">
        <%= button_to "잔금 납부 처리", pay_balance_payment_path(@payment), method: :patch, class: "text-sm bg-green-600 text-white px-3 py-1.5 rounded hover:bg-green-700" %>
      </div>
    <% end %>

    <% unless @payment.refunded? %>
      <div class="mt-3">
        <%= form_with url: refund_payment_path(@payment), method: :post, class: "flex items-center gap-2" do |f| %>
          <%= f.number_field :refund_amount, value: @payment.refund_amount_calculated, class: "input input-bordered input-sm text-sm w-28" %>
          <%= f.text_field :refund_reason, placeholder: "환불 사유", class: "input input-bordered input-sm text-sm flex-1" %>
          <%= f.submit "환불 처리", class: "text-sm bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200 cursor-pointer", data: { turbo_confirm: "환불 처리하시겠습니까?" } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <!-- 할인 내역 -->
    <div class="bg-base-100 rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-3">할인 내역</h3>
      <% if @discounts.any? %>
        <ul class="space-y-1 text-sm">
          <% @discounts.each do |d| %>
            <li class="flex justify-between">
              <span class="text-base-content/80"><%= d.memo || d.discount_type %></span>
              <span class="text-purple-600">-<%= format_amount(d.amount) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-base-content/60">없음</p>
      <% end %>
    </div>

    <!-- 수업 횟수 요약 -->
    <div class="bg-base-100 rounded-lg border shadow-sm p-4">
      <h3 class="font-semibold text-sm mb-2">수업 현황</h3>
      <div class="text-sm space-y-1">
        <div class="flex justify-between"><span class="text-base-content/70">총 횟수</span><span><%= @payment.total_lessons %>회</span></div>
        <div class="flex justify-between"><span class="text-base-content/70">출석</span><span><%= @schedules.where(status: %w[attended late makeup_done]).count %>회</span></div>
        <div class="flex justify-between"><span class="text-base-content/70">잔여</span><span class="font-medium text-blue-600"><%= @schedules.where(status: "scheduled").count %>회</span></div>
      </div>
    </div>
  </div>
</div>

<!-- 수업 날짜 리스트 -->
<div class="mt-6 bg-base-100 rounded-lg border shadow-sm p-4">
  <h3 class="font-semibold text-sm mb-3">수업 날짜 리스트</h3>
  <table class="w-full text-sm">
    <thead class="text-xs text-base-content/60 border-b">
      <tr>
        <th class="pb-1 text-left">회차</th>
        <th class="pb-1 text-left">날짜</th>
        <th class="pb-1 text-left">상태</th>
        <th class="pb-1 text-left">보강</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @schedules.each do |s| %>
        <tr>
          <td class="py-1.5 text-base-content/60"><%= s.sequence %>회</td>
          <td><%= s.lesson_date.strftime("%Y.%m.%d (%a)") %></td>
          <td><%= schedule_status_badge(s.status) %></td>
          <td class="text-xs text-indigo-500">
            <% if s.makeup_date %>
              <%= s.makeup_date.strftime("%m/%d") %> <%= s.makeup_teacher&.name %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
