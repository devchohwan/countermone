<% content_for :title, "통계/마감" %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-bold">통계 / 마감</h2>
  <%= form_with url: statistics_daily_path, method: :get, class: "flex gap-2" do |f| %>
    <%= f.date_field :date, value: @date, class: "border rounded px-2 py-1 text-sm" %>
    <%= f.submit "조회", class: "bg-gray-100 px-3 py-1 rounded text-sm hover:bg-gray-200 cursor-pointer" %>
  <% end %>
</div>

<div class="grid grid-cols-2 gap-6">

  <!-- 결제 집계 -->
  <div class="bg-white rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3"><%= @date.strftime("%m월 %d일") %> 결제 현황</h3>
    <dl class="space-y-2 text-sm">
      <div class="flex justify-between border-b pb-2">
        <dt class="text-gray-500">총 결제 건수</dt>
        <dd class="font-bold"><%= @daily_payments.count %>건</dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">합산 금액</dt>
        <dd class="font-bold"><%= format_amount(@daily_payments.sum(&:amount)) %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">첫 결제</dt>
        <dd><%= @first_payments.count %>건</dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">추가 결제</dt>
        <dd><%= @extra_payments.count %>건</dd>
      </div>
    </dl>
    <% if @daily_payments.any? %>
      <div class="mt-3 pt-3 border-t">
        <% @daily_payments.each do |p| %>
          <div class="text-xs text-gray-600 flex justify-between">
            <span><%= p.student.name %> — <%= p.subject %></span>
            <span><%= format_amount(p.amount) %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 출석 통계 -->
  <div class="bg-white rounded-lg border shadow-sm p-4">
    <h3 class="font-semibold text-sm mb-3">출석/휴퇴원</h3>
    <dl class="space-y-2 text-sm">
      <div class="flex justify-between">
        <dt class="text-gray-500">당일 휴원</dt>
        <dd><%= @daily_leaves.count %>명</dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">당일 퇴원</dt>
        <dd><%= @daily_dropouts.count %>명</dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">당일 복귀</dt>
        <dd><%= @daily_returns.count %>명</dd>
      </div>
      <div class="flex justify-between border-t pt-2">
        <dt class="text-gray-500">연락할 완료</dt>
        <dd><%= @contact_completed.count %>명</dd>
      </div>
      <% if @otto_students_clean %>
        <div class="flex justify-between border-t pt-2">
          <dt class="text-gray-500">오또 재원 (클린)</dt>
          <dd><%= @otto_students_clean %>명</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">오또 재원 (비클린)</dt>
          <dd><%= @otto_students_nonclean %>명</dd>
        </div>
      <% end %>
    </dl>
  </div>

</div>

<!-- 마감 톡 자동 생성 -->
<div class="mt-6 bg-white rounded-lg border shadow-sm p-4">
  <div class="flex items-center justify-between mb-3">
    <h3 class="font-semibold text-sm">마감 톡</h3>
    <button onclick="copyClosingMessage()" class="text-xs bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded">복사</button>
  </div>
  <textarea id="closing-message" class="w-full border rounded p-3 text-sm font-mono" rows="12" readonly><%= generate_closing_message(assigns) %></textarea>
</div>

<script>
function copyClosingMessage() {
  const el = document.getElementById("closing-message");
  navigator.clipboard.writeText(el.value).then(() => alert("복사되었습니다!"));
}
</script>
