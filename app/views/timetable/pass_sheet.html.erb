<% content_for :title, "패스 사용 시트" %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-bold">선생님별 패스 사용 시트</h2>
  <%= form_with url: pass_sheet_path, method: :get, class: "flex gap-2" do |f| %>
    <%= f.month_field :month, value: @month.strftime("%Y-%m"), class: "input input-sm input-bordered" %>
    <%= f.submit "조회", class: "btn btn-sm btn-neutral" %>
  <% end %>
</div>

<% if @pass_data.empty? %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body items-center py-8">
      <p class="text-base-content/40"><%= @month.strftime("%Y년 %m월") %> 패스 사용 없음</p>
    </div>
  </div>
<% else %>
  <% @pass_data.each do |data| %>
    <div class="card bg-base-100 shadow-sm mb-4">
      <div class="card-body p-4">
        <h3 class="card-title text-sm">
          <%= data[:teacher].name %>
          <span class="badge badge-sm badge-secondary"><%= data[:passes].count %>건</span>
        </h3>
        <div class="overflow-x-auto">
          <table class="table table-xs">
            <thead>
              <tr><th>날짜</th><th>수강생</th><th>과목</th><th>종류</th><th>사유</th></tr>
            </thead>
            <tbody>
              <% data[:passes].each do |s| %>
                <tr>
                  <td class="font-mono text-xs"><%= s.lesson_date.strftime("%m/%d (%a)") %></td>
                  <td><%= s.student.name %></td>
                  <td><%= s.subject %></td>
                  <td>
                    <span class="badge badge-xs <%= s.status == 'emergency_pass' ? 'badge-error' : 'badge-secondary' %>">
                      <%= s.status == 'emergency_pass' ? '긴급패스' : '패스' %>
                    </span>
                  </td>
                  <td class="text-base-content/60 text-xs"><%= s.pass_reason.presence || "-" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
