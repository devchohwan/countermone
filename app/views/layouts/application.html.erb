<!DOCTYPE html>
<html lang="ko" class="h-full">
  <head>
    <title><%= content_for(:title) || "모네뮤직 카운터" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-50 text-gray-900">
    <% if authenticated? %>
      <!-- 사이드바 레이아웃 -->
      <div class="flex h-full">
        <!-- 사이드바 -->
        <nav class="w-48 bg-gray-900 text-white flex flex-col shrink-0">
          <div class="px-4 py-5 border-b border-gray-700">
            <h1 class="text-sm font-bold text-white">모네뮤직 카운터</h1>
          </div>
          <ul class="flex-1 px-2 py-4 space-y-1 text-sm">
            <li><%= link_to "대시보드",    root_path,        class: nav_link_class(root_path) %></li>
            <li><%= link_to "수강생",      students_path,    class: nav_link_class(students_path) %></li>
            <li><%= link_to "결제",        payments_path,    class: nav_link_class(payments_path) %></li>
            <li><%= link_to "출결 관리",   schedules_path,   class: nav_link_class(schedules_path) %></li>
            <li><%= link_to "시간표",      timetable_path,   class: nav_link_class(timetable_path) %></li>
            <li><%= link_to "통계/마감",   statistics_path,  class: nav_link_class(statistics_path) %></li>
            <li><%= link_to "가격표",      price_plans_path, class: nav_link_class(price_plans_path) %></li>
            <li class="border-t border-gray-700 pt-2 mt-2">
              <%= link_to "키패드", keypad_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700 hover:text-white" %>
            </li>
          </ul>
          <div class="px-4 py-3 border-t border-gray-700">
            <%= button_to "로그아웃", session_path, method: :delete, class: "text-xs text-gray-400 hover:text-white" %>
          </div>
        </nav>

        <!-- 메인 콘텐츠 -->
        <main class="flex-1 overflow-auto">
          <!-- 알림 -->
          <% if notice.present? %>
            <div class="bg-green-100 border border-green-300 text-green-800 px-4 py-2 text-sm">
              <%= notice %>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="bg-red-100 border border-red-300 text-red-800 px-4 py-2 text-sm">
              <%= alert %>
            </div>
          <% end %>

          <div class="p-6">
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <!-- 로그인 화면 -->
      <main class="flex items-center justify-center h-full">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
