<% content_for :title, "대시보드 — 모네뮤직" %>

<% if @is_today %>
  <%= turbo_stream_from "dashboard_current" %>
<% end %>

<div class="space-y-4">

  <%# 헤더 + 날짜 네비게이션 %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="join">
        <%= link_to "←", root_path(date: (@date - 1).to_s), class: "join-item btn btn-sm btn-ghost" %>
        <span class="join-item btn btn-sm btn-ghost pointer-events-none font-semibold">
          <%= @date.strftime("%Y.%m.%d (%a)") %>
        </span>
        <%= link_to "→", root_path(date: (@date + 1).to_s),
              class: "join-item btn btn-sm btn-ghost #{@date >= Date.today ? 'btn-disabled opacity-30' : ''}" %>
      </div>
      <% unless @is_today %>
        <%= link_to "오늘", root_path, class: "btn btn-xs btn-primary" %>
      <% end %>
      <% if @is_today %>
        <p class="text-sm text-base-content/60" id="dashboard-time"></p>
      <% end %>
    </div>
    <div class="flex gap-2 items-center">
      <% if @attendance_events&.any? %>
        <div class="badge badge-accent gap-1">🔥 개근달성 <%= @attendance_events.count %>명</div>
      <% end %>
      <% if @is_today %>
        <% if @payment_due_today.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-error badge-xs"><%= @payment_due_today.count %></span><span class="btn btn-ghost btn-sm">💳</span></div>
        <% end %>
        <% if @contact_list.count > 0 %>
          <div class="indicator"><span class="indicator-item badge badge-warning badge-xs"><%= @contact_list.count %></span><span class="btn btn-ghost btn-sm">📞</span></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @is_today %>
    <%# 3×2 그리드 %>
    <div class="grid grid-cols-3 gap-4">

      <%# Row 1: 시간대별수업 / 시간대별등하원 / 지금이순간 %>
      <%= render "hourly_schedule_text",
            schedules: @today_schedules,
            enrollment_remaining: @enrollment_remaining %>

      <%= render "hourly_arrival_text", schedules: @today_schedules %>

      <div>
        <%= turbo_frame_tag "current_schedules", src: dashboard_current_schedules_path, loading: :lazy do %>
          <%= render "current_schedules" %>
        <% end %>
      </div>

      <%# Row 2: 오늘결제/연락/확인 / 내일결제자 / 오늘마감 %>

      <%# 오늘 결제자·연락·확인·개근 (탭) %>
      <%
        # 복사 텍스트 사전 계산
        sched_by_enroll = @today_schedules.index_by(&:enrollment_id)
        with_sched    = @payment_due_today.select { |i| sched_by_enroll[i[:enrollment].id] }
        without_sched = @payment_due_today.reject { |i| sched_by_enroll[i[:enrollment].id] }
        grouped = with_sched
          .group_by { |i| sched_by_enroll[i[:enrollment].id].lesson_time.in_time_zone('Seoul').hour }
          .sort
          .map { |hour, items| [hour, items.group_by { |i| sched_by_enroll[i[:enrollment].id].teacher }] }
        pay_copy_lines = []
        grouped.each do |hour, by_teacher|
          pay_copy_lines << "#{hour}시"
          by_teacher.each do |teacher, items|
            pay_copy_lines << "[#{teacher.name}]"
            items.each do |item|
              lbl = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정"
              pay_copy_lines << "#{item[:student].name} #{lbl}"
            end
          end
          pay_copy_lines << ""
        end
        unless without_sched.empty?
          pay_copy_lines << "오늘 수업 없음"
          without_sched.each do |item|
            lbl = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정"
            pay_copy_lines << "#{item[:student].name} #{item[:enrollment].subject} #{lbl}"
          end
        end

        contact_copy_lines = @contact_list.map do |item|
          type_label = case item[:type]
          when :contact_due     then "연락기한"
          when :return_due      then "복귀예정"
          when :waiting_expired then "자리대기만료"
          end
          subj = item[:enrollment] ? " #{item[:enrollment].subject}" : ""
          "#{item[:student].name}#{subj} #{type_label}"
        end

        confirm_copy_lines = []
        @minus_enrollments.each { |e| confirm_copy_lines << "#{e.student.name} — #{e.subject} (#{e.minus_lesson_count}회) 마이너스" }
        @pending_consents.each  { |s| confirm_copy_lines << "#{s.name} 동의서미수령" }

        keungeun_copy_lines = @attendance_events.map { |e| "#{e.student.name} #{e.subject} 개근달성" }
      %>
      <script>
        window._todoCopy = {
          pay:      <%= pay_copy_lines.join("\n").strip.to_json.html_safe %>,
          contact:  <%= contact_copy_lines.join("\n").to_json.html_safe %>,
          confirm:  <%= confirm_copy_lines.join("\n").to_json.html_safe %>,
          keungeun: <%= keungeun_copy_lines.join("\n").to_json.html_safe %>
        };
        function switchTodoCopy(type) {
          const btn = document.getElementById('todo-copy-btn');
          if (btn) { btn.dataset.copyText = window._todoCopy[type] || ''; btn.textContent = '복사'; }
        }
      </script>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">

          <%# 복사버튼 — 탭 우측상단 %>
          <div class="flex justify-end mb-1">
            <button id="todo-copy-btn"
                    class="btn btn-xs btn-ghost"
                    data-copy-text=""
                    onclick="navigator.clipboard.writeText(this.dataset.copyText).then(()=>{this.textContent='✓ 복사됨';setTimeout(()=>this.textContent='복사',1500)}).catch(()=>{})">복사</button>
          </div>
          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const btn = document.getElementById('todo-copy-btn');
              if (btn && window._todoCopy) btn.dataset.copyText = window._todoCopy.pay || '';
            });
          </script>

          <div role="tablist" class="tabs tabs-bordered tabs-sm">

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="💳 결제 (<%= @payment_due_today.count %>)" checked
                   onchange="switchTodoCopy('pay')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @payment_due_today.empty? %>
                <p class="text-sm text-base-content/40">오늘 결제 예정 없음</p>
              <% else %>
                <div class="flex flex-col gap-3 font-mono text-sm leading-snug overflow-y-auto max-h-60">
                  <% grouped.each do |hour, by_teacher| %>
                    <div>
                      <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
                      <% by_teacher.each do |teacher, items| %>
                        <p class="text-xs text-base-content/40">[<%= teacher.name %>]</p>
                        <% items.each do |item| %>
                          <% badge_color = item[:type] == :deposit_first_lesson ? "badge-error" : "badge-info" %>
                          <% label = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정" %>
                          <p><%= item[:student].name %> <span class="badge badge-xs <%= badge_color %>"><%= label %></span></p>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                  <% if without_sched.any? %>
                    <div>
                      <p class="text-xs font-bold text-base-content/50 mb-1">오늘 수업 없음</p>
                      <% without_sched.each do |item| %>
                        <% badge_color = item[:type] == :deposit_first_lesson ? "badge-error" : "badge-info" %>
                        <% label = item[:type] == :deposit_first_lesson ? "완납필요" : "결제예정" %>
                        <p><%= item[:student].name %> — <%= item[:enrollment].subject %> <span class="badge badge-xs <%= badge_color %>"><%= label %></span></p>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="📞 연락 (<%= @contact_list.count %>)"
                   onchange="switchTodoCopy('contact')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @contact_list.empty? %>
                <p class="text-sm text-base-content/40">오늘 연락할 대상 없음</p>
              <% else %>
                <ul class="space-y-2">
                  <% @contact_list.each do |item| %>
                    <li class="flex items-center gap-2 text-sm">
                      <span class="font-medium"><%= item[:student].name %></span>
                      <span class="badge badge-xs badge-outline">
                        <%= case item[:type]
                            when :contact_due     then "연락기한"
                            when :return_due      then "복귀예정"
                            when :waiting_expired then "자리대기만료"
                            end %>
                      </span>
                      <% if item[:enrollment] %>
                        <span class="text-xs text-base-content/50"><%= item[:enrollment].subject %></span>
                      <% end %>
                      <%= button_to "완료", complete_contact_student_path(item[:student]),
                            method: :patch,
                            class: "btn btn-xs btn-ghost text-success ml-auto" %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab" aria-label="✅ 확인"
                   onchange="switchTodoCopy('confirm')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @minus_enrollments.any? %>
                <p class="text-xs font-bold text-error mb-1">마이너스 수업</p>
                <% @minus_enrollments.each do |e| %>
                  <p class="text-sm"><%= e.student.name %> — <%= e.subject %> (<%= e.minus_lesson_count %>회)</p>
                <% end %>
              <% end %>
              <% if @pending_consents.any? %>
                <p class="text-xs font-bold text-warning mt-2 mb-1">동의서 미수령</p>
                <% @pending_consents.each do |s| %>
                  <p class="text-sm"><%= s.name %></p>
                <% end %>
              <% end %>
              <% if @minus_enrollments.empty? && @pending_consents.empty? %>
                <p class="text-sm text-base-content/40">없음</p>
              <% end %>
            </div>

            <input type="radio" name="todo-tabs" role="tab" class="tab"
                   aria-label="🎯 개근 (<%= @attendance_events.count %>)"
                   onchange="switchTodoCopy('keungeun')" />
            <div role="tabpanel" class="tab-content pt-3">
              <% if @attendance_events.empty? %>
                <p class="text-sm text-base-content/40">개근 달성자 없음</p>
              <% else %>
                <p class="text-xs text-base-content/50 mb-2">다음 결제 등록 시 수업 횟수 1회 추가 입력 필요</p>
                <ul class="space-y-2">
                  <% @attendance_events.each do |e| %>
                    <li class="flex items-center gap-2 text-sm">
                      <span class="font-medium"><%= e.student.name %></span>
                      <span class="text-base-content/50"><%= e.subject %></span>
                      <span class="badge badge-xs badge-success">12주 개근</span>
                      <%= button_to "개근처리", dismiss_attendance_event_enrollment_path(e),
                            method: :patch,
                            class: "btn btn-xs btn-success ml-auto",
                            data: { turbo_confirm: "#{e.student.name} 개근 1회 추가 처리하시겠습니까?" } %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

          </div>
        </div>
      </div>

      <%# 내일 결제자 %>
      <%= render "tomorrow_payments" %>

      <%# 오늘 마감 %>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4">
          <div class="flex items-center justify-between mb-1">
            <h3 class="card-title text-sm">오늘 마감</h3>
            <%= link_to "마감 톡 생성 →", statistics_path(date: @date), class: "btn btn-xs btn-primary" %>
          </div>
          <%= render "daily_summary" %>
        </div>
      </div>

    </div>

  <% else %>
    <%# 과거/미래: 마감 요약만 %>
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body p-4">
        <div class="flex items-center justify-between mb-1">
          <h3 class="card-title text-sm"><%= @date.strftime("%m/%d") %> 마감</h3>
          <%= link_to "마감 톡 생성 →", statistics_path(date: @date), class: "btn btn-xs btn-primary" %>
        </div>
        <%= render "daily_summary" %>
      </div>
    </div>
  <% end %>

  <%# 시간표 — /timetable/4 그대로 임베드 %>
  <%= turbo_frame_tag "timetable_embed", src: teacher_timetable_path(4, date: @date.to_s), loading: :lazy do %>
    <div class="card bg-base-100 shadow-sm p-4 text-sm text-base-content/40">시간표 로딩 중...</div>
  <% end %>

</div>

<% if @is_today %>
<script>
  const DAYS_KO = ['일','월','화','수','목','금','토'];
  function updateTime() {
    const now = new Date();
    const hh  = String(now.getHours()).padStart(2,'0');
    const mm  = String(now.getMinutes()).padStart(2,'0');
    const ss  = String(now.getSeconds()).padStart(2,'0');
    const el  = document.getElementById('dashboard-time');
    if (el) el.textContent = `${hh}:${mm}:${ss} (${DAYS_KO[now.getDay()]}요일) · 현재 시간대: ${now.getHours()}:00`;
  }
  updateTime();
  setInterval(updateTime, 1000);
</script>
<% end %>
