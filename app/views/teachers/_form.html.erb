<%# teacher 등록/수정 폼 partial %>
<%= form_with model: teacher, class: "space-y-4" do |f| %>
  <% if teacher.errors.any? %>
    <div class="alert alert-error text-sm">
      <ul class="list-disc list-inside">
        <% teacher.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :name, "이름", class: "label label-text font-medium" %>
    <%= f.text_field :name, class: "input input-bordered w-full", placeholder: "선생님 이름" %>
  </div>

  <div class="form-control">
    <label class="label label-text font-medium">담당 과목</label>
    <div class="flex flex-wrap gap-3">
      <% Teacher::SUBJECTS.each do |subj| %>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="subjects[]" value="<%= subj %>"
                 class="checkbox checkbox-sm"
                 <%= teacher.teacher_subjects.map(&:subject).include?(subj) ? "checked" : "" %> />
          <span class="text-sm"><%= subj %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit teacher.new_record? ? "등록" : "수정", class: "btn btn-primary btn-sm" %>
    <%= link_to "취소", teachers_path, class: "btn btn-ghost btn-sm" %>
  </div>
<% end %>
