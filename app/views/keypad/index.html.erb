<% content_for :title, "출석 키패드" %>

<style>
  body.is-fullscreen .navbar,
  body.is-fullscreen .drawer-side {
    display: none !important;
  }
  body.is-fullscreen .drawer-content {
    margin-left: 0 !important;
  }
  body.is-fullscreen #keypad-wrapper {
    min-height: 100dvh;
    background: oklch(var(--b2) / 1);
  }
  body.is-fullscreen #keypad-container {
    max-width: 540px;
  }
  body.is-fullscreen #keypad-body {
    padding: 2.5rem;
    gap: 1.5rem;
  }
  body.is-fullscreen #keypad-title   { font-size: 2rem; }
  body.is-fullscreen #keypad-subtitle { font-size: 1.1rem; }
  body.is-fullscreen #keypad-display-wrap {
    font-size: 3.5rem;
    min-height: 5.5rem;
    padding: 1rem 1.5rem;
  }
  body.is-fullscreen #result-message  { font-size: 1.2rem; padding: 1rem; }
  body.is-fullscreen .keypad-btn      { font-size: 2.8rem !important; height: 6rem !important; }
  body.is-fullscreen #clear-btn,
  body.is-fullscreen #submit-btn      { font-size: 2rem !important; height: 6rem !important; }
  body.is-fullscreen .class-select-btn { font-size: 1.2rem; height: 3.5rem; }
</style>

<%# 전체화면 토글 버튼 %>
<button id="fs-btn" class="fixed top-3 right-3 z-50 btn btn-sm btn-ghost opacity-30 hover:opacity-80" title="전체화면">
  <svg id="fs-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="15 3 21 3 21 9"/>
    <polyline points="9 21 3 21 3 15"/>
    <line x1="21" y1="3" x2="14" y2="10"/>
    <line x1="3" y1="21" x2="10" y2="14"/>
  </svg>
</button>

<div class="min-h-screen bg-base-200 flex items-center justify-center p-4" id="keypad-wrapper">
  <div class="card bg-base-100 shadow-2xl w-full max-w-sm" id="keypad-container">
    <div class="card-body items-center text-center gap-4 p-8" id="keypad-body">

      <div>
        <h1 class="card-title text-xl justify-center" id="keypad-title">모네뮤직</h1>
        <p class="text-base-content/50 text-sm" id="keypad-subtitle">출결 코드를 입력하세요</p>
      </div>

      <%# 입력 표시 %>
      <div class="bg-base-200 rounded-xl px-4 py-3 w-full text-2xl font-mono tracking-widest min-h-12 flex items-center justify-center" id="keypad-display-wrap">
        <span id="code-display">_</span>
      </div>

      <%# 결과 메시지 %>
      <div id="result-message" class="hidden w-full"></div>

      <%# 클래스 선택 (N개 클래스 수강 시) %>
      <div id="class-select" class="hidden w-full space-y-2"></div>

      <%# 키패드 %>
      <div class="grid grid-cols-3 gap-2 w-full">
        <% [1,2,3,4,5,6,7,8,9].each do |n| %>
          <button class="keypad-btn btn btn-neutral text-xl" data-value="<%= n %>"><%= n %></button>
        <% end %>
        <button class="btn btn-error" id="clear-btn">C</button>
        <button class="keypad-btn btn btn-neutral text-xl" data-value="0">0</button>
        <button class="btn btn-success" id="submit-btn">확인</button>
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  let code = "";
  const display   = document.getElementById("code-display");
  const resultDiv = document.getElementById("result-message");
  const classDiv  = document.getElementById("class-select");

  document.querySelectorAll(".keypad-btn[data-value]").forEach(btn => {
    btn.addEventListener("click", () => {
      if (code.length >= 6) return;
      code += btn.dataset.value;
      display.textContent = code.split("").join(" ");
    });
  });

  document.getElementById("clear-btn").addEventListener("click", () => {
    code = "";
    display.textContent = "_";
    resultDiv.className = "hidden w-full";
    classDiv.innerHTML = "";
    classDiv.classList.add("hidden");
  });

  document.getElementById("submit-btn").addEventListener("click", () => {
    if (!code) return;
    fetch("/keypad/checkin", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-CSRF-Token": document.querySelector("meta[name=csrf-token]").content },
      body: JSON.stringify({ code })
    })
    .then(r => r.json())
    .then(data => {
      if (data.action === "select_class") {
        classDiv.classList.remove("hidden");
        classDiv.innerHTML = "<p class='text-sm text-base-content/60 mb-1'>수업 클래스를 선택하세요</p>" +
          data.schedules.map(s =>
            `<button class="btn btn-primary btn-block class-select-btn" data-id="${s.id}">${s.subject} / ${s.teacher}</button>`
          ).join("");
        classDiv.querySelectorAll(".class-select-btn").forEach(btn => {
          btn.addEventListener("click", () => submitCheckin(code, btn.dataset.id));
        });
      } else {
        showResult(data.message || data.error, !!data.message);
        code = "";
        display.textContent = "_";
        classDiv.innerHTML = "";
        classDiv.classList.add("hidden");
      }
    });
  });

  function submitCheckin(code, scheduleId) {
    fetch("/keypad/checkin", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-CSRF-Token": document.querySelector("meta[name=csrf-token]").content },
      body: JSON.stringify({ code, schedule_id: scheduleId })
    })
    .then(r => r.json())
    .then(data => {
      showResult(data.message || data.error, !!data.message);
      code = "";
      display.textContent = "_";
      classDiv.innerHTML = "";
      classDiv.classList.add("hidden");
    });
  }

  function showResult(msg, success) {
    resultDiv.className = `w-full alert ${success ? "alert-success" : "alert-error"}`;
    resultDiv.textContent = msg;
    setTimeout(() => resultDiv.className = "hidden w-full", 3000);
  }

  // ── 전체화면 ──────────────────────────────────────────────
  const fsBtn  = document.getElementById('fs-btn');
  const fsIcon = document.getElementById('fs-icon');

  const ICON_EXPAND = `
    <polyline points="15 3 21 3 21 9"/>
    <polyline points="9 21 3 21 3 15"/>
    <line x1="21" y1="3" x2="14" y2="10"/>
    <line x1="3" y1="21" x2="10" y2="14"/>`;
  const ICON_SHRINK = `
    <polyline points="4 14 10 14 10 20"/>
    <polyline points="20 10 14 10 14 4"/>
    <line x1="10" y1="14" x2="3" y2="21"/>
    <line x1="21" y1="3" x2="14" y2="10"/>`;

  fsBtn.addEventListener('click', () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {});
    } else {
      document.exitFullscreen();
    }
  });

  document.addEventListener('fullscreenchange', () => {
    const isFs = !!document.fullscreenElement;
    document.body.classList.toggle('is-fullscreen', isFs);
    fsIcon.innerHTML = isFs ? ICON_SHRINK : ICON_EXPAND;
    fsBtn.title = isFs ? '전체화면 종료' : '전체화면';
  });
})();
</script>
