<div class="card bg-base-100 shadow-sm">
  <div class="card-body p-4">
    <div class="flex items-center justify-between mb-2">
      <h3 class="card-title text-sm">시간대별 수업</h3>
      <% unless schedules.empty? %>
        <%
          copy_lines = []
          schedules.group_by { |s| s.lesson_time.in_time_zone('Seoul').hour }.sort.each do |hour, hour_schedules|
            copy_lines << "#{hour}시"
            hour_schedules.group_by(&:teacher_id).each_value do |ts|
              ts.each do |s|
                remaining = enrollment_remaining[s.enrollment_id] || 0
                if s.status.in?(%w[attended late])
                  copy_lines << "#{s.student.name} #{remaining + 1}-#{remaining}"
                else
                  copy_lines << "#{s.student.name} #{remaining}"
                end
              end
            end
            copy_lines << ""
          end
          copy_text = copy_lines.join("\n").strip
        %>
        <button
          class="btn btn-xs btn-ghost"
          data-copy-text="<%= copy_text %>"
          onclick="
            navigator.clipboard.writeText(this.dataset.copyText)
              .then(() => { this.textContent = '✓ 복사됨'; setTimeout(() => this.textContent = '복사', 1500); })
              .catch(() => {});
          ">복사</button>
      <% end %>
    </div>

    <% hourly_groups = schedules.group_by { |s| s.lesson_time.in_time_zone('Seoul').hour }.sort %>

    <% if hourly_groups.empty? %>
      <p class="text-sm text-base-content/40">수업이 없습니다.</p>
    <% else %>
      <div class="flex flex-col gap-3 font-mono text-sm leading-snug overflow-y-auto max-h-72">
        <% hourly_groups.each do |hour, hour_schedules| %>
          <div>
            <p class="text-xs font-bold text-base-content/50 mb-1"><%= hour %>시</p>
            <%
              by_teacher = hour_schedules.group_by(&:teacher_id)
              first_teacher = true
            %>
            <% by_teacher.each_value do |ts| %>
              <% unless first_teacher %>
                <div class="h-2"></div>
              <% end %>
              <% first_teacher = false %>

              <p class="text-xs text-base-content/40">[<%= ts.first.teacher.name %>]</p>

              <% ts.each do |s| %>
                <%
                  attended = s.status.in?(%w[attended late])
                  remaining_scheduled = enrollment_remaining[s.enrollment_id] || 0
                  if attended
                    before_count = remaining_scheduled + 1
                    after_count  = remaining_scheduled
                  else
                    before_count = remaining_scheduled
                  end
                %>
                <p>
                  <%= s.student.name %>
                  <% if attended %>
                    <span class="text-base-content/40"><%= before_count %>-<%= after_count %></span>
                  <% else %>
                    <span class="text-base-content/40"><%= before_count %></span>
                  <% end %>
                </p>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
