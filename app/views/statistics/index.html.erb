<% content_for :title, "통계/마감" %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-bold">통계 / 마감</h2>
  <%= form_with url: statistics_daily_path, method: :get, class: "flex gap-2" do |f| %>
    <%= f.date_field :date, value: @date, class: "input input-sm input-bordered" %>
    <%= f.submit "조회", class: "btn btn-sm btn-neutral" %>
  <% end %>
</div>

<div class="grid grid-cols-2 gap-4 mb-4">

  <%# 결제 집계 %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm"><%= @date.strftime("%m월 %d일") %> 결제 현황</h3>
      <table class="table table-xs">
        <tbody>
          <tr><td class="text-base-content/60">총 결제 건수</td><td class="font-bold"><%= @daily_payments.count %>건</td></tr>
          <tr><td class="text-base-content/60">합산 금액</td><td class="font-bold"><%= format_amount(@daily_payments.sum(&:amount)) %></td></tr>
          <tr><td class="text-base-content/60">첫 결제</td><td><%= @first_payments.count %>건</td></tr>
          <tr><td class="text-base-content/60">추가 결제</td><td><%= @extra_payments.count %>건</td></tr>
        </tbody>
      </table>
      <% if @daily_payments.any? %>
        <div class="divider my-1"></div>
        <% @daily_payments.each do |p| %>
          <div class="flex justify-between text-xs text-base-content/70">
            <span><%= p.student.name %> — <%= p.subject %></span>
            <span><%= format_amount(p.amount) %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# 출석/휴퇴원 %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">출석 / 휴퇴원</h3>
      <table class="table table-xs">
        <tbody>
          <tr>
            <td class="text-base-content/60">당일 휴원</td>
            <td>
              <%= @daily_leaves.count %>명
              <% if @daily_leaves.any? %>
                <span class="text-xs text-base-content/50">
                  (시작전 <%= @daily_leaves_before.count %> / 3개월이하 <%= @daily_leaves_short.count %> / 3개월초과 <%= @daily_leaves_long.count %>)
                </span>
              <% end %>
            </td>
          </tr>
          <tr><td class="text-base-content/60">당일 퇴원</td><td><%= @daily_dropouts.count %>명</td></tr>
          <tr><td class="text-base-content/60">당일 복귀</td><td><%= @daily_returns.count %>명</td></tr>
          <tr><td class="text-base-content/60 border-t">연락할 완료</td><td class="border-t"><%= @contact_completed.count %>명</td></tr>
          <% if @otto_students_clean %>
            <tr><td class="text-base-content/60 border-t">오또 재원 (클린)</td><td class="border-t"><%= @otto_students_clean %>명</td></tr>
            <tr><td class="text-base-content/60">오또 재원 (비클린)</td><td><%= @otto_students_nonclean %>명</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%# 마감 톡 자동 생성 %>
<div class="card bg-base-100 shadow-sm">
  <div class="card-body p-4">
    <div class="flex items-center justify-between mb-2">
      <h3 class="card-title text-sm">마감 톡</h3>
      <div class="flex gap-2">
        <button onclick="regenerateMessage()" class="btn btn-xs btn-ghost">새로고침</button>
        <button onclick="copyClosingMessage()" class="btn btn-xs btn-primary">복사</button>
      </div>
    </div>
    <textarea id="closing-message" class="textarea textarea-bordered w-full font-mono text-sm" rows="18"><%= generate_closing_message(assigns) %></textarea>
  </div>
</div>

<script>
function copyClosingMessage() {
  const el = document.getElementById("closing-message");
  navigator.clipboard.writeText(el.value).then(() => {
    const btn = event.target;
    btn.textContent = "복사됨!";
    setTimeout(() => btn.textContent = "복사", 2000);
  });
}
function regenerateMessage() {
  location.reload();
}
</script>
