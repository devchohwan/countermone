<% content_for :title, "#{@student.name} 수정" %>

<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "← #{@student.name}", student_path(@student), class: "text-sm text-gray-500 hover:underline" %>
    <h2 class="text-lg font-bold">수강생 수정</h2>
  </div>
  <%= render "form", student: @student %>
</div>
