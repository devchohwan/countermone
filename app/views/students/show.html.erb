<% content_for :title, @student.name %>

<%# 헤더 %>
<div class="flex items-center gap-3 mb-4">
  <%= link_to "← 목록", students_path, class: "btn btn-ghost btn-sm" %>
  <h2 class="text-xl font-bold"><%= @student.name %></h2>
  <%= status_badge(@student.status) %>
  <div class="ml-auto flex gap-2">
    <button onclick="document.getElementById('gift-voucher-modal').showModal()" class="btn btn-sm btn-outline btn-accent">🎟 지류상품권 발급</button>
    <%= link_to "수정", edit_student_path(@student), class: "btn btn-sm btn-ghost" %>
    <button onclick="document.getElementById('delete-confirm-modal').showModal()" class="btn btn-sm btn-ghost text-error">삭제</button>

    <dialog id="delete-confirm-modal" class="modal">
      <div class="modal-box">
        <h3 class="font-bold text-lg text-error">수강생 삭제</h3>
        <p class="py-3 text-sm"><span class="font-semibold"><%= @student.name %></span> 수강생을 삭제합니다.</p>
        <p class="text-sm text-base-content/60">결제 내역, 수업 이력 등 모든 데이터가 함께 삭제되며 복구할 수 없습니다.</p>
        <div class="modal-action">
          <form method="dialog"><button class="btn btn-sm btn-ghost">취소</button></form>
          <%= button_to "삭제 확인", student_path(@student), method: :delete, class: "btn btn-sm btn-error" %>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <%# 지류상품권 발급 모달 %>
    <dialog id="gift-voucher-modal" class="modal">
      <div class="modal-box max-w-sm">
        <h3 class="font-bold text-base mb-4">🎟 지류상품권 발급</h3>
        <%= form_with url: gift_vouchers_path, method: :post do |f| %>
          <div class="form-control mb-4">
            <label class="label"><span class="label-text text-sm">발급 과목 (클래스)</span></label>
            <%= f.select :enrollment_id,
                  @enrollments.map { |e| ["#{e.subject} — #{e.teacher.name} (#{lesson_day_ko(e.lesson_day)}요일)", e.id] },
                  { prompt: "클래스 선택" },
                  class: "select select-bordered select-sm w-full", required: true %>
          </div>
          <div class="modal-action mt-2">
            <form method="dialog"><button class="btn btn-sm btn-ghost">취소</button></form>
            <%= f.submit "발급", class: "btn btn-sm btn-accent",
                  onclick: "return confirm('지류상품권을 발급하시겠습니까?')" %>
          </div>
        <% end %>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>
  </div>
</div>

<%# 기본정보 카드 3열 %>
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">기본 정보</h3>
      <table class="table table-xs">
        <tbody>
          <tr><td class="text-base-content/50 w-24">전화번호</td><td><%= @student.phone %></td></tr>
          <tr><td class="text-base-content/50">나이</td><td><%= @student.age %>세</td></tr>
          <tr><td class="text-base-content/50">출결코드</td><td class="font-mono font-bold"><%= @student.attendance_code %></td></tr>
          <tr><td class="text-base-content/50">랭크</td><td><%= @student.rank == "first" ? "1차전직" : "2차전직" %></td></tr>
          <tr><td class="text-base-content/50">자차</td><td><%= @student.has_car? ? "✓ 있음" : "-" %></td></tr>
          <% if @student.first_enrolled_at %><tr><td class="text-base-content/50">첫 등록</td><td><%= @student.first_enrolled_at.strftime("%Y.%m.%d") %></td></tr><% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">상담 정보</h3>
      <div class="space-y-2 text-sm">
        <% if @student.reason_for_joining.present? %>
          <div><p class="text-xs text-base-content/50">찾아온 이유</p><p class="text-xs"><%= @student.reason_for_joining %></p></div>
        <% end %>
        <% if @student.own_problem.present? %>
          <div><p class="text-xs text-base-content/50">본인의 문제점</p><p class="text-xs"><%= @student.own_problem %></p></div>
        <% end %>
        <% if @student.desired_goal.present? %>
          <div><p class="text-xs text-base-content/50">하고 싶은 것</p><p class="text-xs"><%= @student.desired_goal %></p></div>
        <% end %>
        <% if @student.memo.present? %>
          <div><p class="text-xs text-base-content/50">메모</p><p class="text-xs"><%= @student.memo %></p></div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body p-4">
      <h3 class="card-title text-sm">할인 / 기타</h3>
      <table class="table table-xs">
        <tbody>
          <tr>
            <td class="text-base-content/50">추천인</td>
            <td>
              <% if @student.referrers.any? %>
                <%= @student.referrers.map { |r| link_to r.name, student_path(r), class: "link link-hover" }.join(', ').html_safe %>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
          <tr>
            <td class="text-base-content/50">내 추천 학생</td>
            <td>
              <% if @student.referred_students.any? %>
                <%= @student.referred_students.map { |s| link_to s.name, student_path(s), class: "link link-hover" }.join(', ').html_safe %>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
          <% referral_discounts = Discount.joins(:payment).where(payments: { student_id: @student.id }, discount_type: 'referral').order(:created_at) %>
          <% pending_count = @student.referral_discount_pending %>
          <tr>
            <td class="text-base-content/50">추천 할인</td>
            <td>
              <% if pending_count == 0 && referral_discounts.none? %>
                <span class="text-base-content/30">-</span>
              <% else %>
                <% if pending_count > 0 %>
                  <span class="text-warning font-medium">대기 <%= pending_count %>건</span>
                  <span class="text-xs text-base-content/50 ml-1">(-<%= number_with_delimiter(pending_count * 50_000) %>원 예정)</span>
                <% end %>
                <% referral_discounts.each do |d| %>
                  <% separator = (pending_count > 0) ? ' · ' : '' %>
                  <%= separator.html_safe %><span class="text-success">사용됨: -<%= number_with_delimiter(d.amount) %>원</span>
                  <span class="text-xs text-base-content/40 ml-1">(<%= d.payment.enrollment.subject %>, <%= d.created_at.strftime('%Y-%m-%d') %>)</span>
                <% end %>
              <% end %>
            </td>
          </tr>
          <tr><td class="text-base-content/50">동의서</td><td><%= @student.consent_form? ? "✓" : %(<span class="badge badge-xs badge-warning">미수령</span>).html_safe %></td></tr>
          <tr><td class="text-base-content/50">2차전직서</td><td><%= @student.second_transfer_form? ? "✓" : "-" %></td></tr>
          <tr><td class="text-base-content/50">후기 할인</td><td><%= @student.review_discount_applied? ? "적용" : "-" %></td></tr>
          <tr><td class="text-base-content/50">인터뷰</td><td><%= @student.interview_completed? ? "완료" : "-" %></td></tr>
          <tr>
            <td class="text-base-content/50">상품권</td>
            <td>
              <% vouchers = @student.gift_vouchers.order(:issued_at) %>
              <% if vouchers.any? %>
                <div class="space-y-0.5">
                  <% vouchers.each do |v| %>
                    <div class="text-xs">
                      <%= v.enrollment.subject %>
                      <% if v.used? %>
                        <span class="text-base-content/40">(사용됨)</span>
                      <% elsif v.expires_at < Date.today %>
                        <span class="text-error">(만료)</span>
                      <% else %>
                        <span class="text-success">(사용가능)</span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <span class="text-base-content/30">-</span>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%# 클래스 탭 — 3개 이하: 탭, 4개 이상: 탭+드롭다운 %>
<div class="flex items-center justify-between mb-3">
  <h3 class="text-lg font-bold">수강 클래스</h3>
  <%= link_to "+ 신규 클래스 추가", new_student_enrollment_path(@student), class: "btn btn-sm btn-primary" %>
</div>

<% if @enrollments.empty? %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body items-center py-10">
      <p class="text-base-content/40">등록된 클래스가 없습니다.</p>
      <%= link_to "첫 클래스 등록하기", new_student_enrollment_path(@student), class: "btn btn-primary btn-sm mt-2" %>
    </div>
  </div>
<% else %>
  <%# 탭 목록 — 최대 3개까지 직접 표시, 이후 드롭다운 %>
  <% visible = @enrollments.first(3) %>
  <% overflow = @enrollments.drop(3) %>

  <% target_tab = params[:tab]&.to_i %>
  <div role="tablist" class="tabs tabs-bordered mb-0">
    <% visible.each_with_index do |enrollment, idx| %>
      <input type="radio" name="enrollment-tabs" role="tab" class="tab"
             id="tab-<%= enrollment.id %>"
             aria-label="<%= enrollment.subject %> (<%= status_badge_text(enrollment.status) %>)"
             <%= (target_tab ? target_tab == enrollment.id : idx == 0) ? "checked" : "" %> />
      <div role="tabpanel" class="tab-content">
        <%= render "enrollment_tab", enrollment: enrollment, student: @student %>
      </div>
    <% end %>

    <% if overflow.any? %>
      <%# 드롭다운 탭 %>
      <div class="dropdown dropdown-end ml-auto">
        <label tabindex="0" class="tab">더보기 (<%= overflow.count %>)</label>
        <ul tabindex="0" class="dropdown-content z-10 menu shadow bg-base-100 rounded-box w-40 border">
          <% overflow.each do |enrollment| %>
            <li><a href="#enrollment-<%= enrollment.id %>" onclick="showEnrollmentPanel('<%= enrollment.id %>')">
              <%= enrollment.subject %> — <%= enrollment.teacher.name %>
            </a></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <%# 오버플로우 enrollment 패널 (숨김 상태로 렌더링) %>
  <% overflow.each do |enrollment| %>
    <div id="enrollment-panel-<%= enrollment.id %>" class="hidden">
      <%= render "enrollment_tab", enrollment: enrollment, student: @student %>
    </div>
  <% end %>
<% end %>

<%# 지류상품권 목록 %>
<% if @student.gift_vouchers.any? %>
  <div class="card bg-base-100 shadow-sm p-4 mt-4">
    <h3 class="font-semibold text-sm mb-3">지류상품권</h3>
    <div class="space-y-3">
      <% @student.gift_vouchers.order(:issued_at).each do |v| %>
        <div class="border rounded p-3 text-sm <%= v.used? ? 'opacity-60' : '' %>">
          <div class="flex items-start gap-3">
            <div class="flex-1 space-y-0.5">
              <div class="font-medium"><%= v.enrollment.subject %> 과목 발급</div>
              <div class="text-xs text-base-content/60">
                발급일: <%= v.issued_at.strftime("%Y.%m.%d") %> /
                만료일: <%= v.expires_at.strftime("%Y.%m.%d") %>
                <% if v.used? %>
                  / <span class="text-success">사용완료 <%= v.used_at&.strftime("%Y.%m.%d") %> (<%= v.used_class %>)</span>
                <% elsif v.expires_at < Date.today %>
                  / <span class="text-error">만료</span>
                <% end %>
              </div>
            </div>
            <% if !v.used? && v.expires_at >= Date.today %>
              <% other_subjects = TeacherSubject::SUBJECTS - [v.enrollment.subject] %>
              <% if other_subjects.any? %>
                <form action="<%= use_gift_voucher_path(v) %>" method="post"
                      onsubmit="return confirm('상품권을 사용 처리하시겠습니까?')">
                  <input type="hidden" name="_method" value="patch">
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <select name="used_class" class="select select-bordered select-xs mr-1" required>
                    <option value="">과목 선택</option>
                    <% other_subjects.each do |subj| %>
                      <option value="<%= subj %>"><%= subj %></option>
                    <% end %>
                  </select>
                  <button type="submit" class="btn btn-xs btn-success">사용처리</button>
                </form>
              <% else %>
                <span class="text-xs text-base-content/40">사용 가능 과목 없음</span>
              <% end %>
            <% end %>
          </div>

          <%# 체험수업 섹션 %>
          <div class="mt-2 pt-2 border-t border-base-200">
            <% trial = v.trial_schedule %>
            <% if trial.nil? %>
              <div class="flex items-center gap-2">
                <span class="text-xs text-base-content/50">체험수업: 미등록</span>
                <button onclick="openTrialModal(<%= v.id %>, '<%= j v.enrollment.subject %>')"
                        class="btn btn-xs btn-outline btn-accent">체험수업 잡기</button>
              </div>
            <% elsif trial.status.in?(%w[attended late makeup_done]) %>
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-success">✓ 체험수업 완료</span>
                <span class="text-xs text-base-content/50">
                  <%= trial.lesson_date.strftime("%m/%d") %>
                  <%= trial.lesson_time.strftime("%H:%M") %>
                  <%= trial.teacher.name %>선생님
                  (<%= trial.subject %>)
                </span>
              </div>
            <% else %>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-xs text-base-content/50">체험수업:</span>
                <span class="text-xs font-medium">
                  <%= "#{trial.lesson_date.strftime('%m/%d')}(#{%w[일 월 화 수 목 금 토][trial.lesson_date.wday]})" %>
                  <%= trial.lesson_time.strftime("%H:%M") %>
                  <%= trial.teacher.name %>선생님
                </span>
                <span class="badge badge-xs badge-info"><%= trial.subject %></span>
                <button onclick="openTrialModal(<%= v.id %>, '<%= j trial.subject %>')"
                        class="btn btn-xs btn-ghost btn-outline">변경</button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# 체험수업 슬롯 모달 %>
  <dialog id="trial-modal" class="modal">
    <div class="modal-box max-w-2xl">
      <h3 class="font-bold text-base mb-3">🎓 체험수업 등록</h3>
      <div id="trial-subject-bar" class="flex items-center gap-2 mb-3 flex-wrap"></div>
      <div id="trial-slot-area" class="min-h-24">
        <p class="text-xs text-base-content/50 py-4 text-center">불러오는 중…</p>
      </div>
      <div class="modal-action mt-2">
        <form method="dialog"><button class="btn btn-sm btn-ghost">닫기</button></form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
  (function() {
    var _trialVoucherId = null;
    var _trialSubject   = null;
    var _trialData      = null;
    var _trialWeekStart = null;
    var _trialTeacherId = null;
    var _csrfToken      = document.querySelector('meta[name="csrf-token"]').content;

    function getMonday(d) {
      var day = d.getDay(), diff = d.getDate() - day + (day === 0 ? -6 : 1);
      return new Date(d.getFullYear(), d.getMonth(), diff);
    }
    function parseDate(s) {
      if (!s) return null;
      var p = s.split('-'); return new Date(+p[0], +p[1]-1, +p[2]);
    }
    function toDateStr(d) {
      var y = d.getFullYear(), m = String(d.getMonth()+1).padStart(2,'0'), day = String(d.getDate()).padStart(2,'0');
      return `${y}-${m}-${day}`;
    }

    window.openTrialModal = function(voucherId, subject) {
      _trialVoucherId = voucherId;
      _trialSubject   = subject;
      _trialData      = null;
      _trialWeekStart = getMonday(new Date());
      _trialTeacherId = null;
      document.getElementById('trial-slot-area').innerHTML =
        '<p class="text-xs text-base-content/50 py-4 text-center">슬롯 불러오는 중…</p>';
      document.getElementById('trial-subject-bar').innerHTML = '';
      document.getElementById('trial-modal').showModal();
      _trialLoadSlots(subject);
    };

    function _trialLoadSlots(subject) {
      var url = `/gift_vouchers/${_trialVoucherId}/trial_slots?subject=${encodeURIComponent(subject)}`;
      fetch(url)
        .then(r => r.json())
        .then(data => {
          _trialData      = data;
          _trialSubject   = data.subject;
          if (!_trialTeacherId && data.teachers.length > 0) {
            _trialTeacherId = data.teachers[0].id;
          }

          // 과목 탭
          var subBar = document.getElementById('trial-subject-bar');
          subBar.innerHTML = '<span class="text-xs text-base-content/50">과목:</span>' +
            data.subjects.map(s => {
              var active = s === _trialSubject;
              return `<button onclick="window._trialChangeSubject('${s}')"
                              class="btn btn-xs ${active ? 'btn-accent' : 'btn-ghost'}">${s}</button>`;
            }).join('');

          window._trialRender();
        });
    }

    window._trialChangeSubject = function(subject) {
      _trialSubject   = subject;
      _trialTeacherId = null;
      document.getElementById('trial-slot-area').innerHTML =
        '<p class="text-xs text-base-content/50 py-4 text-center">슬롯 불러오는 중…</p>';
      _trialLoadSlots(subject);
    };

    window._trialRender = function _trialRender() {
      var data = _trialData;
      var ws   = _trialWeekStart;
      var DAY_KO = ['일','월','화','수','목','금','토'];

      var days = Array.from({length: 7}, (_, i) =>
        new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + i));

      var prevWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() - 7);
      var nextWs   = new Date(ws.getFullYear(), ws.getMonth(), ws.getDate() + 7);
      var today    = new Date(); today.setHours(0,0,0,0);
      var nextDays = Array.from({length:7}, (_,i) => new Date(nextWs.getFullYear(), nextWs.getMonth(), nextWs.getDate()+i));
      var prevOk   = days.some(d => d >= today);
      var nextOk   = true;

      var weekEnd   = days[6];
      var weekLabel = `${ws.getMonth()+1}/${ws.getDate()} ~ ${weekEnd.getMonth()+1}/${weekEnd.getDate()}`;

      // 선생님 탭
      var teacherTabs = data.teachers.map(t => {
        var active = _trialTeacherId === t.id;
        return `<button onclick="window._trialSetTeacher(${t.id})"
                        class="btn btn-xs ${active ? 'btn-primary' : 'btn-ghost'}">${t.name}</button>`;
      }).join('');

      var tid    = String(_trialTeacherId);
      var tGrid  = (data.grid || {})[tid] || {};

      var times = [];
      for (var m = 13 * 60; m <= 22 * 60; m += 60) {
        var h   = String(Math.floor(m/60)).padStart(2,'0');
        var min = String(m%60).padStart(2,'0');
        times.push(`${h}:${min}`);
      }

      var thCells = days.map(d => {
        var past = d < today;
        return `<th class="text-xs font-normal text-center px-1 py-1 ${past ? 'opacity-25' : ''}">
          ${d.getMonth()+1}/${d.getDate()}<br>
          <span class="text-base-content/60">${DAY_KO[d.getDay()]}</span>
        </th>`;
      }).join('');

      var rows = times.map(time => {
        var tds = days.map(d => {
          var past = d < today;
          var ds   = toDateStr(d);
          if (past) return `<td class="text-center opacity-20 text-xs select-none px-1 py-1">—</td>`;
          var slots = ((tGrid[ds] || {})[time]) || 0;
          if (slots >= 3) {
            return `<td class="text-center text-xs select-none px-1 py-1 rounded"
                        style="background:rgba(239,68,68,0.12);color:rgba(239,68,68,0.5);"
                        title="마감 (3/3)">✕</td>`;
          }
          var filled   = '●'.repeat(slots);
          var empty    = '○'.repeat(3 - slots);
          var colorCls = slots === 0 ? 'text-success' : 'text-warning';
          var teacher  = data.teachers.find(t => t.id === _trialTeacherId);
          var tName    = teacher ? teacher.name : '';
          return `<td class="text-center cursor-pointer rounded px-1 py-1"
                      style="background:rgba(34,197,94,0.12);"
                      onmouseover="this.style.background='rgba(34,197,94,0.25)'"
                      onmouseout="this.style.background='rgba(34,197,94,0.12)'"
                      onclick="window._trialConfirm('${ds}',${_trialTeacherId},'${time}','${tName}')"
                      title="${tName} — ${slots}/3명">
                    <span class="font-mono text-xs ${colorCls}">${filled}</span><span class="font-mono text-xs opacity-30">${empty}</span>
                  </td>`;
        }).join('');
        return `<tr>
          <td class="text-xs text-base-content/50 text-right pr-2 py-1 whitespace-nowrap font-mono w-12">${time}</td>
          ${tds}
        </tr>`;
      }).join('');

      document.getElementById('trial-slot-area').innerHTML = `
        <div class="flex flex-wrap gap-1 mb-3">${teacherTabs}</div>
        <div class="flex items-center justify-between mb-2">
          <button onclick="window._trialNav(-1)" class="btn btn-xs btn-ghost" ${!prevOk ? 'disabled' : ''}>←</button>
          <span class="text-sm font-medium">${weekLabel}</span>
          <button onclick="window._trialNav(1)"  class="btn btn-xs btn-ghost">→</button>
        </div>
        <div class="overflow-x-auto">
          <table class="table table-xs w-full">
            <thead><tr><th class="w-12"></th>${thCells}</tr></thead>
            <tbody>${rows}</tbody>
          </table>
        </div>`;
    }

    window._trialSetTeacher = function(id) {
      _trialTeacherId = id;
      window._trialRender();
    };

    window._trialNav = function(dir) {
      _trialWeekStart = new Date(_trialWeekStart.getFullYear(), _trialWeekStart.getMonth(), _trialWeekStart.getDate() + dir * 7);
      window._trialRender();
    };

    window._trialConfirm = function(date, teacherId, time, teacherName) {
      document.getElementById('trial-slot-area').innerHTML = `
        <div class="border rounded-lg p-4 space-y-3">
          <div class="text-sm font-semibold">${date} · ${teacherName} 선생님 · ${_trialSubject}</div>
          <div class="flex items-center gap-2">
            <label class="text-sm text-base-content/60 w-16 shrink-0">시간</label>
            <input type="time" id="trial-confirm-time" value="${time}"
                   class="input input-bordered input-sm flex-1">
          </div>
          <div class="flex gap-2 pt-1">
            <button onclick="window._trialSubmit('${date}',${teacherId})" class="btn btn-sm btn-accent flex-1">체험수업 등록</button>
            <button onclick="window._trialRender()" class="btn btn-sm btn-ghost flex-1">← 취소</button>
          </div>
        </div>`;
    };

    window._trialSubmit = function(date, teacherId) {
      var time = document.getElementById('trial-confirm-time').value;
      var form = document.createElement('form');
      form.method = 'post';
      form.action = `/gift_vouchers/${_trialVoucherId}/schedule_trial`;
      form.innerHTML =
        `<input type="hidden" name="_method" value="patch">` +
        `<input type="hidden" name="authenticity_token" value="${_csrfToken}">` +
        `<input type="hidden" name="date" value="${date}">` +
        `<input type="hidden" name="time" value="${time}">` +
        `<input type="hidden" name="teacher_id" value="${teacherId}">` +
        `<input type="hidden" name="subject" value="${_trialSubject}">`;
      document.body.appendChild(form);
      form.submit();
    };
  })();
  </script>
<% end %>

<%# 메모 %>
<div class="card bg-base-100 shadow-sm p-4 mt-4">
  <div class="flex items-center justify-between mb-2">
    <h3 class="font-semibold text-sm">메모</h3>
    <button type="button" onclick="toggleMemoEdit()" id="memo-edit-btn" class="btn btn-xs btn-ghost">수정</button>
  </div>

  <div id="memo-view">
    <% if @student.memo.present? %>
      <p class="text-sm whitespace-pre-wrap"><%= @student.memo %></p>
    <% else %>
      <p class="text-sm text-base-content/30">메모 없음</p>
    <% end %>
  </div>

  <%= form_with model: @student, url: update_memo_student_path(@student), method: :patch, id: "memo-form", class: "hidden" do |f| %>
    <%= f.text_area :memo, value: @student.memo, rows: 5,
          class: "textarea textarea-bordered w-full text-sm",
          placeholder: "메모를 입력하세요..." %>
    <div class="flex gap-2 mt-2">
      <%= f.submit "저장", class: "btn btn-sm btn-primary" %>
      <button type="button" onclick="toggleMemoEdit()" class="btn btn-sm btn-ghost">취소</button>
    </div>
  <% end %>
</div>

<script>
function toggleMemoEdit() {
  const view = document.getElementById('memo-view');
  const form = document.getElementById('memo-form');
  const btn  = document.getElementById('memo-edit-btn');
  const editing = form.classList.toggle('hidden');
  view.classList.toggle('hidden');
  btn.textContent = editing ? '수정' : '';
}
</script>

<%# 오버플로우 탭 전환 스크립트 %>
<script>
function showEnrollmentPanel(id) {
  document.querySelectorAll('[id^="enrollment-panel-"]').forEach(el => el.classList.add('hidden'));
  document.getElementById('enrollment-panel-' + id)?.classList.remove('hidden');
}
</script>

<%# 복귀 처리 스크립트 %>
<script>
async function handleReturn(event, studentId, currentCode) {
  event.preventDefault();
  try {
    const res  = await fetch(`/students/check_attendance_code?code=${encodeURIComponent(currentCode)}&student_id=${studentId}`);
    const data = await res.json();
    if (!data.available) {
      const newCode = prompt('출결코드 중복입니다. 새 코드를 지정해주세요.', currentCode);
      if (!newCode?.trim()) return false;
      const res2  = await fetch(`/students/check_attendance_code?code=${encodeURIComponent(newCode)}&student_id=${studentId}`);
      const data2 = await res2.json();
      if (!data2.available) { alert(`'${newCode}'도 이미 사용 중입니다.`); return false; }
      const input = document.createElement('input');
      input.type = 'hidden'; input.name = 'new_attendance_code'; input.value = newCode;
      event.target.appendChild(input);
    }
    event.target.submit();
  } catch(e) { event.target.submit(); }
}
</script>
