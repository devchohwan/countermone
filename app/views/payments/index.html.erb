<% content_for :title, "결제 내역" %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-bold">결제 내역</h2>
  <%= link_to "+ 결제 등록", new_payment_path, class: "bg-blue-600 text-white text-sm px-3 py-1.5 rounded hover:bg-blue-700" %>
</div>

<%# 검색 / 날짜 필터 %>
<%= form_with url: payments_path, method: :get, local: true, class: "flex flex-wrap gap-2 mb-4" do |f| %>
  <div class="flex-1 min-w-[160px]">
    <%= f.text_field :q, value: params[:q], placeholder: "수강생 이름 검색",
        class: "input input-bordered input-sm w-full" %>
  </div>
  <div>
    <%= f.date_field :date, value: params[:date],
        class: "input input-bordered input-sm" %>
  </div>
  <%= f.submit "검색", class: "btn btn-sm btn-primary" %>
  <% if params[:q].present? || params[:date].present? %>
    <%= link_to "초기화", payments_path, class: "btn btn-sm btn-ghost" %>
  <% end %>
<% end %>

<div class="bg-base-100 rounded-lg border shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-base-200 border-b text-xs text-base-content/70">
      <tr>
        <th class="px-4 py-2 text-left">수강생</th>
        <th class="px-4 py-2 text-left">과목</th>
        <th class="px-4 py-2 text-left">금액</th>
        <th class="px-4 py-2 text-left">기간</th>
        <th class="px-4 py-2 text-left">완납</th>
        <th class="px-4 py-2 text-left">등록일</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @payments.each do |p| %>
        <tr class="hover:bg-base-200">
          <td class="px-4 py-2.5"><%= link_to p.student.name, student_path(p.student), class: "hover:underline font-medium" %></td>
          <td class="px-4 py-2.5"><%= p.subject %></td>
          <td class="px-4 py-2.5"><%= format_amount(p.amount) %></td>
          <td class="px-4 py-2.5 text-base-content/70 text-xs"><%= p.starts_at.strftime("%Y.%m.%d") %> ~ <%= p.ends_at&.strftime("%m.%d") || "?" %></td>
          <td class="px-4 py-2.5">
            <% if p.fully_paid? %>
              <span class="text-green-600 text-xs">✓ 완납</span>
            <% else %>
              <span class="text-red-500 text-xs">미납</span>
            <% end %>
          </td>
          <td class="px-4 py-2.5 text-base-content/60 text-xs"><%= p.created_at.strftime("%m.%d") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @payments.empty? %>
    <p class="text-center text-base-content/60 py-8 text-sm">결제 내역이 없습니다.</p>
  <% end %>
</div>

<%# 페이지네이션 %>
<% if @pagy.pages > 1 %>
  <div class="flex justify-center mt-4 gap-1 text-sm">
    <% if @pagy.prev %>
      <%= link_to "이전", payments_path(q: params[:q], date: params[:date], page: @pagy.prev),
          class: "px-3 py-1 rounded border hover:bg-base-200" %>
    <% end %>
    <% @pagy.series.each do |item| %>
      <% if item == :gap %>
        <span class="px-3 py-1 text-base-content/40">…</span>
      <% elsif item == @pagy.page %>
        <span class="px-3 py-1 rounded bg-blue-600 text-white font-medium"><%= item %></span>
      <% else %>
        <%= link_to item, payments_path(q: params[:q], date: params[:date], page: item),
            class: "px-3 py-1 rounded border hover:bg-base-200" %>
      <% end %>
    <% end %>
    <% if @pagy.next %>
      <%= link_to "다음", payments_path(q: params[:q], date: params[:date], page: @pagy.next),
          class: "px-3 py-1 rounded border hover:bg-base-200" %>
    <% end %>
  </div>
  <p class="text-center text-xs text-base-content/50 mt-2"><%= @pagy.count %>건 중 <%= @pagy.from %>–<%= @pagy.to %></p>
<% end %>
