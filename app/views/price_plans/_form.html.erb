<%= form_with model: price_plan, class: "space-y-4" do |f| %>
  <% if price_plan.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
      <% price_plan.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
    </div>
  <% end %>

  <div class="bg-base-100 rounded-lg border shadow-sm p-4 space-y-4">
    <div>
      <%= f.label :subject, "과목", class: "block text-sm font-medium text-base-content mb-1" %>
      <%= f.select :subject, PricePlan::SUBJECTS, {}, class: "select select-bordered w-full text-sm" %>
    </div>
    <div>
      <%= f.label :months, "개월", class: "block text-sm font-medium text-base-content mb-1" %>
      <%= f.number_field :months, class: "input input-bordered w-full text-sm" %>
    </div>
    <div>
      <%= f.label :amount, "금액 (원)", class: "block text-sm font-medium text-base-content mb-1" %>
      <%= f.number_field :amount, class: "input input-bordered w-full text-sm" %>
    </div>
    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :active %> 활성
    </label>
  </div>

  <div class="flex gap-3">
    <%= f.submit "저장", class: "btn btn-primary btn-sm" %>
    <%= link_to "취소", price_plans_path, class: "btn btn-ghost btn-sm" %>
  </div>
<% end %>
